@inherits LayoutComponentBase
@inject StarterWorkspace Workspace
@inject W3ToastService Toasts
@inject IJSRuntime JS
@implements IAsyncDisposable

<W3ThemeProvider Theme="Workspace.Theme" Dark="@Workspace.DarkThemeEnabled">
    <W3AppShell SidebarOpen="@sidebarOpen"
                SidebarOpenChanged="value => sidebarOpen = value"
                SidebarOverlay="false"
                SidebarWidth="240"
                HeaderColor="W3Color.Primary"
                HeaderTextColor="W3Color.White"
                SidebarColor="W3Color.Surface"
                SidebarTextColor="W3Color.Black"
                MainClass="starter-main">
        <Header>
            <W3AppBar Color="W3Color.Primary"
                      TextColor="W3Color.White"
                      Title="Starter Kit"
                      Subtitle="W3Css.Blazor adoption sample"
                      ShowMenuButton="true"
                      MenuExpanded="@sidebarOpen"
                      MenuControls="starter-sidebar"
                      OnMenuClick="ToggleSidebar"
                      ActionsClass="starter-appbar-actions">
                <Actions>
                    <W3ToggleIconButton States="@Workspace.ThemeModeStates"
                                        Value="@Workspace.ThemeModeValue"
                                        ValueChanged="SetThemeModeValue"
                                        Border="true"
                                        TextColor="W3Color.White"
                                        Round="W3Round.Medium" />
                    <W3Button Border="true" TextColor="W3Color.White" Round="W3Round.Medium" OnClick="ShowReleaseToast">0.5.0 Ready</W3Button>
                </Actions>
            </W3AppBar>
        </Header>
        <Sidebar>
            <nav id="starter-sidebar" class="w3-bar-block starter-sidebar" aria-label="Starter kit sections">
                <NavLink class="w3-bar-item w3-button" Match="NavLinkMatch.All" href="">Dashboard</NavLink>
                <NavLink class="w3-bar-item w3-button" href="settings">Settings</NavLink>
                <NavLink class="w3-bar-item w3-button" href="customers">Customers</NavLink>
                <NavLink class="w3-bar-item w3-button" href="workflow">Workflow</NavLink>
            </nav>
        </Sidebar>
        <ChildContent>
            @Body
        </ChildContent>
    </W3AppShell>

    <W3ToastProvider Position="W3ToastPosition.TopRight" />
</W3ThemeProvider>

@code {
    private bool sidebarOpen = true;
    private IJSObjectReference? themeModule;
    private DotNetObjectReference<MainLayout>? dotNetReference;

    private void ToggleSidebar(MouseEventArgs _)
    {
        sidebarOpen = !sidebarOpen;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        themeModule = await JS.InvokeAsync<IJSObjectReference>("import", "./starterTheme.js");
        dotNetReference = DotNetObjectReference.Create(this);
        var prefersDark = await themeModule.InvokeAsync<bool>("initializeThemePreference", dotNetReference);
        Workspace.SetSystemPrefersDark(prefersDark);
        StateHasChanged();
    }

    private void SetThemeModeValue(string? value)
    {
        Workspace.SetThemeModeValue(value);
    }

    [JSInvokable]
    public Task SetSystemPrefersDark(bool prefersDark)
    {
        Workspace.SetSystemPrefersDark(prefersDark);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ShowReleaseToast(MouseEventArgs _)
    {
        Toasts.ShowSuccess("Starter kit release path is wired.", "0.5.0");
    }

    public async ValueTask DisposeAsync()
    {
        if (themeModule is not null)
        {
            await themeModule.InvokeVoidAsync("disposeThemePreference");
            await themeModule.DisposeAsync();
        }

        dotNetReference?.Dispose();
    }
}
