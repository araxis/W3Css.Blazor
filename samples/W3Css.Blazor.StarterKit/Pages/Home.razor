@page "/"
@page "/dashboard"
@inject StarterWorkspace Workspace
@inject W3ToastService Toasts

<PageTitle>Starter Kit Dashboard</PageTitle>

<W3Container Class="w3-padding-24">
    <W3Stack Horizontal="true" Wrap="true" AlignCenter="true" JustifyBetween="true" Gap="16">
        <div>
            <h1>Dashboard</h1>
            <p class="w3-large">A first app screen built from the package primitives.</p>
        </div>
        <W3ActionRow Label="Dashboard actions">
            <W3Button Border="true" Round="W3Round.Medium" OnClick="RefreshDashboard">Refresh</W3Button>
            <W3Button Color="W3Color.Primary" TextColor="W3Color.White" Round="W3Round.Medium" OnClick="CreateTask">New task</W3Button>
        </W3ActionRow>
    </W3Stack>

    <W3Row Padding="true" Class="w3-margin-top">
        @foreach (var metric in Workspace.Metrics)
        {
            <W3Column @key="metric.Label" Small="12" Medium="4" Large="4" Class="w3-margin-bottom">
                <W3Card Depth="W3CardDepth.Two" Round="W3Round.Medium" BodyClass="w3-padding-16">
                    <p class="w3-small w3-text-grey">@metric.Label</p>
                    <p class="w3-xxlarge w3-margin-0">@metric.Value</p>
                    <p>@metric.Detail</p>
                </W3Card>
            </W3Column>
        }
    </W3Row>

    <W3Row Padding="true" Class="w3-margin-top">
        <W3Column Small="12" Medium="6" Large="6" Class="w3-margin-bottom">
            <W3Card Depth="W3CardDepth.Two" Round="W3Round.Medium" BodyClass="w3-padding-24">
                <h2 class="w3-large">Customer plan mix</h2>
                <p class="w3-opacity">Accounts grouped by their current subscription plan.</p>
                <W3Chart ChartType="W3ChartType.Bar"
                         Series="@Workspace.CustomerPlanSeries"
                         Labels="@Workspace.CustomerPlanLabels"
                         Height="240"
                         AriaLabel="Customer accounts by plan" />
            </W3Card>
        </W3Column>

        <W3Column Small="12" Medium="6" Large="6" Class="w3-margin-bottom">
            <W3Card Depth="W3CardDepth.Two" Round="W3Round.Medium" BodyClass="w3-padding-24">
                <h2 class="w3-large">Customer health</h2>
                <p class="w3-opacity">Current accounts grouped by adoption state.</p>
                <W3Chart ChartType="W3ChartType.Donut"
                         Series="@Workspace.CustomerHealthSeries"
                         Labels="@Workspace.CustomerHealthLabels"
                         Height="240"
                         HoleColor="var(--w3-surface)"
                         AriaLabel="Customer health distribution" />
            </W3Card>
        </W3Column>
    </W3Row>

    <W3DataTable TItem="WorkItem"
                 Items="@Workspace.WorkItems"
                 Searchable="false"
                 Pageable="false"
                 AriaLabel="Open work items"
                 Class="w3-margin-top">
        <Toolbar>
            <W3ActionRow Label="Work item actions" JustifyStart="true">
                <W3Button Border="true" Round="W3Round.Medium" OnClick="RefreshDashboard">Reload queue</W3Button>
            </W3ActionRow>
        </Toolbar>
        <ChildContent>
            <W3DataColumn TItem="WorkItem" Title="Task" CellText="@((WorkItem item) => item.Name)" />
            <W3DataColumn TItem="WorkItem" Title="Owner" CellText="@((WorkItem item) => item.Owner)" />
            <W3DataColumn TItem="WorkItem" Title="State" CellText="@((WorkItem item) => item.State)" />
        </ChildContent>
        <RowActions Context="item">
            <W3Button Size="W3Size.Small" Border="true" Round="W3Round.Medium" OnClick="@(_ => OpenTask(item))">Open</W3Button>
        </RowActions>
    </W3DataTable>

    <W3EmptyState Title="Starter kit ready"
                  Description="Use this screen as a copyable baseline for shell, data, action spacing, and status feedback."
                  Kind="W3EmptyStateKind.Success"
                  Compact="true"
                  Class="w3-margin-top">
        <Actions>
            <NavLink class="w3-button w3-border w3-round-medium" href="settings">Review settings</NavLink>
            <NavLink class="w3-button w3-primary w3-round-medium" href="customers">Open customers</NavLink>
        </Actions>
    </W3EmptyState>
</W3Container>

@code {
    private void RefreshDashboard(MouseEventArgs _)
    {
        Toasts.ShowInfo("Dashboard data refreshed.", "Dashboard");
    }

    private void CreateTask(MouseEventArgs _)
    {
        Toasts.ShowSuccess("New task action is wired.", "Action ready");
    }

    private void OpenTask(WorkItem item)
    {
        Toasts.ShowInfo($"{item.Name} opened.", "Task");
    }
}
