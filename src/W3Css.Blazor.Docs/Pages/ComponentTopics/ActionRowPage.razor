@page "/components/action-row"

<PageTitle>W3ActionRow</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3ActionRow</h1>
    <DocPager PreviousHref="components/button-group" PreviousText="Button Group" NextHref="components/alert" NextText="Alert" />

    <p class="w3-large">`W3ActionRow` provides a small, reusable command row for forms, cards, tables, and dialog footers.</p>
    <p>Use it when actions need predictable gaps, wrapping, and right alignment without adding one-off margin classes.</p>

    <DocExample Title="Form Actions" Description="The default alignment keeps primary form commands on the trailing edge while preserving an 8px gap." Code="@FormActionsCode">
        <W3ActionRow Label="Profile actions" Class="w3-margin-top">
            <W3Button Border="true" Round="W3Round.Medium">Cancel</W3Button>
            <W3Button Color="W3Color.Teal" TextColor="W3Color.White" Round="W3Round.Medium">Save</W3Button>
        </W3ActionRow>
    </DocExample>

    <DocExample Title="Responsive Row Actions" Description="Use wrapping for table cells, list suffixes, and compact app surfaces that may run out of horizontal space." Code="@ResponsiveActionsCode">
        <W3ActionRow Label="Row actions" Gap="6" JustifyStart="true">
            <W3Button Size="W3Size.Small" Border="true">Open</W3Button>
            <W3Button Size="W3Size.Small" Border="true">Assign</W3Button>
            <W3Button Size="W3Size.Small" Color="W3Color.PaleRed" TextColor="W3Color.Black">Archive</W3Button>
        </W3ActionRow>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Action buttons, links, menus, or icon buttons</td></tr>
                <tr><td>Label</td><td>string</td><td>Actions</td><td>`aria-label` when `AriaLabelledBy` is not set</td></tr>
                <tr><td>AriaLabelledBy</td><td>string?</td><td>null</td><td>`aria-labelledby` on the action row</td></tr>
                <tr><td>Role</td><td>string</td><td>group</td><td>Semantic role on the root element</td></tr>
                <tr><td>Wrap</td><td>bool</td><td>true</td><td>Allows actions to wrap instead of touching or overflowing</td></tr>
                <tr><td>JustifyStart</td><td>bool</td><td>false</td><td>Start-aligns actions</td></tr>
                <tr><td>JustifyCenter</td><td>bool</td><td>false</td><td>Center-aligns actions</td></tr>
                <tr><td>JustifyBetween</td><td>bool</td><td>false</td><td>Spaces actions across the row</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Gap</td><td>int</td><td>8</td><td>Action gap in pixels</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional action-row classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline styles on the action row</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the action-row root</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/button-group">Button Group</NavLink> connects related segmented commands. <NavLink href="components/stack">Stack</NavLink> remains the general-purpose layout primitive for broader spacing.</p>
    </section>

    <DocPager PreviousHref="components/button-group" PreviousText="Button Group" NextHref="components/alert" NextText="Alert" />
</W3Container>

@code {
    private const string FormActionsCode = """
<W3ActionRow Label="Profile actions" Class="w3-margin-top">
    <W3Button Border="true" Round="W3Round.Medium">Cancel</W3Button>
    <W3Button Color="W3Color.Teal" TextColor="W3Color.White" Round="W3Round.Medium">Save</W3Button>
</W3ActionRow>
""";

    private const string ResponsiveActionsCode = """
<W3ActionRow Label="Row actions" Gap="6" JustifyStart="true">
    <W3Button Size="W3Size.Small" Border="true">Open</W3Button>
    <W3Button Size="W3Size.Small" Border="true">Assign</W3Button>
    <W3Button Size="W3Size.Small" Color="W3Color.PaleRed" TextColor="W3Color.Black">Archive</W3Button>
</W3ActionRow>
""";
}
