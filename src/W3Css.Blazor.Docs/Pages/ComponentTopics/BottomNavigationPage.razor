@page "/components/bottom-navigation"

<PageTitle>W3BottomNavigation</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3BottomNavigation</h1>
    <DocPager PreviousHref="components/nav-menu" PreviousText="Nav Menu" NextHref="components/breadcrumb" NextText="Breadcrumb" />

    <p class="w3-large">`W3BottomNavigation` provides mobile-first app navigation with W3.CSS bar and button styling.</p>
    <p>Use it for phone layouts, PWAs, dashboards, and app shells where the main destinations should stay reachable at the bottom of the screen.</p>

    <DocExample Title="Mobile App Navigation" Description="Contained mode lets docs and app previews demonstrate fixed-bottom behavior without covering the whole page." Code="@MobileCode">
        <div class="bottom-nav-phone w3-border w3-white">
            <div class="w3-bar w3-teal">
                <span class="w3-bar-item">Workspace</span>
                <span class="w3-bar-item w3-right">Online</span>
            </div>

            <main class="bottom-nav-phone-main">
                <h3>@CurrentMobileTitle</h3>
                <p>@CurrentMobileText</p>
                <div class="w3-panel w3-pale-blue w3-leftbar w3-border-blue">
                    <p>Current section: <strong>@MobileSection</strong></p>
                </div>
            </main>

            <W3BottomNavigation Label="Workspace mobile navigation"
                                @bind-Value="MobileSection"
                                Contained="true"
                                Border="true"
                                Card="true"
                                ActiveColor="W3Color.Teal"
                                ActiveTextColor="W3Color.White">
                <W3BottomNavigationItem Value="home" Text="Home" IconClass="fa fa-home" />
                <W3BottomNavigationItem Value="search" Text="Search" IconClass="fa fa-search" Badge="2" />
                <W3BottomNavigationItem Value="tasks" Text="Tasks" IconClass="fa fa-check-square-o" />
                <W3BottomNavigationItem Value="settings" Text="Settings" IconClass="fa fa-cog" />
            </W3BottomNavigation>
        </div>
    </DocExample>

    <DocExample Title="Dense Icon Rail" Description="Hide visual labels for compact app tools while keeping accessible labels on each item." Code="@DenseCode">
        <div class="bottom-nav-toolbar-preview w3-border w3-white">
            <div class="bottom-nav-toolbar-content">
                <h3>Preview canvas</h3>
                <p>Dense icon-only navigation is useful for inspectors, editors, and compact mobile app states.</p>
            </div>

            <W3BottomNavigation Label="Editor tools"
                                @bind-Value="ToolSection"
                                Contained="true"
                                Dense="true"
                                ShowLabels="false"
                                Color="W3Color.Black"
                                TextColor="W3Color.White"
                                ActiveColor="W3Color.Amber"
                                ActiveTextColor="W3Color.Black">
                <W3BottomNavigationItem Value="layers" Text="Layers" IconClass="fa fa-clone" />
                <W3BottomNavigationItem Value="assets" Text="Assets" IconClass="fa fa-image" Badge="5" />
                <W3BottomNavigationItem Value="comments" Text="Comments" IconClass="fa fa-comment-o" />
                <W3BottomNavigationItem Text="Locked" IconClass="fa fa-lock" Disabled="true" />
            </W3BottomNavigation>
        </div>
    </DocExample>

    <section class="doc-section">
        <h2>W3BottomNavigation Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Label</td><td>string</td><td>Bottom navigation</td><td>`aria-label` on the nav element</td></tr>
                <tr><td>Value</td><td>string?</td><td>null</td><td>Current selected item value</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;string?&gt;</td><td>none</td><td>Raised when an item with `Value` is clicked</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>`W3BottomNavigationItem` children</td></tr>
                <tr><td>Fixed</td><td>bool</td><td>false</td><td>Fixed viewport bottom placement</td></tr>
                <tr><td>Contained</td><td>bool</td><td>false</td><td>Absolute bottom placement inside a positioned parent</td></tr>
                <tr><td>EqualWidth</td><td>bool</td><td>true</td><td>Even item widths through scoped flex CSS</td></tr>
                <tr><td>Dense</td><td>bool</td><td>false</td><td>Compact item height and spacing</td></tr>
                <tr><td>ShowLabels</td><td>bool</td><td>true</td><td>Visual labels remain accessible when hidden</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Card and CardDepth</td><td>bool / W3CardDepth</td><td>false / Two</td><td>W3.CSS card shadow</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded utility class</td></tr>
                <tr><td>Color and TextColor</td><td>W3Color</td><td>Surface and Black</td><td>Bar color classes</td></tr>
                <tr><td>ActiveColor and ActiveTextColor</td><td>W3Color</td><td>Primary and White</td><td>Inherited active item colors</td></tr>
                <tr><td>HoverColor and HoverTextColor</td><td>W3Color</td><td>LightGrey and None</td><td>Inherited hover classes for inactive items</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional nav classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style on the nav</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra attributes on the nav root</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>W3BottomNavigationItem Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>string?</td><td>null</td><td>Selection value passed to the owner</td></tr>
                <tr><td>Text</td><td>string?</td><td>null</td><td>Label text and fallback accessible name</td></tr>
                <tr><td>AriaLabel</td><td>string?</td><td>null</td><td>Accessible label override</td></tr>
                <tr><td>Href and Target</td><td>string?</td><td>null</td><td>Anchor rendering when `Href` is set</td></tr>
                <tr><td>IconClass</td><td>string?</td><td>null</td><td>Consumer icon class pass-through</td></tr>
                <tr><td>Badge</td><td>string?</td><td>null</td><td>Optional W3.CSS badge over the icon</td></tr>
                <tr><td>BadgeColor and BadgeTextColor</td><td>W3Color</td><td>Red and White</td><td>Badge color classes</td></tr>
                <tr><td>Active</td><td>bool</td><td>false</td><td>Manual active state with `aria-current="page"`</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>Non-interactive text rendering</td></tr>
                <tr><td>Type</td><td>string</td><td>button</td><td>Button type when `Href` is not set</td></tr>
                <tr><td>Color and TextColor</td><td>W3Color</td><td>None</td><td>Inactive item color overrides</td></tr>
                <tr><td>ActiveColor and ActiveTextColor</td><td>W3Color</td><td>Owner values</td><td>Active item color overrides</td></tr>
                <tr><td>HoverColor and HoverTextColor</td><td>W3Color</td><td>Owner values</td><td>Inactive hover class overrides</td></tr>
                <tr><td>OnClick</td><td>EventCallback&lt;MouseEventArgs&gt;</td><td>none</td><td>Raised after selection</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Custom label content</td></tr>
                <tr><td>Class / Style / AdditionalAttributes</td><td>string? / dictionary?</td><td>null</td><td>Extra classes, style, and attributes on the rendered item</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/nav-menu">Nav Menu</NavLink> covers grouped side navigation.</p>
        <p><NavLink href="components/navbar">Navbar</NavLink> covers horizontal primary navigation.</p>
        <p><NavLink href="components/app-shell">App Shell</NavLink> shows how app frames can host navigation surfaces.</p>
    </section>

    <DocPager PreviousHref="components/nav-menu" PreviousText="Nav Menu" NextHref="components/breadcrumb" NextText="Breadcrumb" />
</W3Container>

@code {
    private string MobileSection { get; set; } = "home";
    private string ToolSection { get; set; } = "layers";

    private string CurrentMobileTitle => MobileSection switch
    {
        "search" => "Search",
        "tasks" => "Tasks",
        "settings" => "Settings",
        _ => "Home"
    };

    private string CurrentMobileText => MobileSection switch
    {
        "search" => "Find components, saved layouts, and team references.",
        "tasks" => "Review work, approvals, and release checklist items.",
        "settings" => "Adjust workspace preferences and display options.",
        _ => "Monitor recent work and jump back into active projects."
    };

    private const string MobileCode = """
<W3BottomNavigation Label="Workspace mobile navigation"
                    @bind-Value="mobileSection"
                    Contained="true"
                    Border="true"
                    Card="true">
    <W3BottomNavigationItem Value="home" Text="Home" IconClass="fa fa-home" />
    <W3BottomNavigationItem Value="search" Text="Search" IconClass="fa fa-search" Badge="2" />
    <W3BottomNavigationItem Value="tasks" Text="Tasks" IconClass="fa fa-check-square-o" />
    <W3BottomNavigationItem Value="settings" Text="Settings" IconClass="fa fa-cog" />
</W3BottomNavigation>
""";

    private const string DenseCode = """
<W3BottomNavigation Label="Editor tools"
                    @bind-Value="toolSection"
                    Contained="true"
                    Dense="true"
                    ShowLabels="false"
                    Color="W3Color.Black"
                    TextColor="W3Color.White"
                    ActiveColor="W3Color.Amber"
                    ActiveTextColor="W3Color.Black">
    <W3BottomNavigationItem Value="layers" Text="Layers" IconClass="fa fa-clone" />
    <W3BottomNavigationItem Value="assets" Text="Assets" IconClass="fa fa-image" Badge="5" />
    <W3BottomNavigationItem Value="comments" Text="Comments" IconClass="fa fa-comment-o" />
    <W3BottomNavigationItem Text="Locked" IconClass="fa fa-lock" Disabled="true" />
</W3BottomNavigation>
""";
}
