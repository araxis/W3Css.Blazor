        OwnMessageColor="W3Color.PaleGreen"
        OwnMessageTextColor="W3Color.Black">
    <W3ChatMessage Author="Design" Time="10:20" Text="Use a denser stream for table comments." Compact="true" />
    <W3ChatMessage Author="Build" Time="10:22" Text="The app owns persistence and sending." Own="true" Compact="true" />
</W3Chat>
""";
}
