    <W3ChatMessage Author="You" Initials="YO" Time="09:14" Text="Nice. Please keep the docs page refreshed." Own="true" Status="Seen" />
    <W3ChatMessage Author="Mira" Initials="MI" Time="09:18">
        <strong>Done.</strong> The docs app is running.
    </W3ChatMessage>
</W3Chat>
""";

    private const string CompactCode = """
<W3Chat Label="Comment stream"
