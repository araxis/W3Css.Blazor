@page "/components/checkbox"

<PageTitle>W3Checkbox</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Checkbox</h1>
    <DocPager PreviousHref="components/select" PreviousText="Select" NextHref="components/radio" NextText="Radio" />

    <p class="w3-large">`W3Checkbox` renders a Blazor boolean input with the W3.CSS `w3-check` class.</p>
    <p>Use `Label` or child content to render a simple clickable label.</p>

    <DocExample Title="Checkbox With Label" Code="@BasicCode">
        <EditForm Model="@CheckboxModel">
            <W3Checkbox @bind-Value="CheckboxModel.Accepted" Label="I accept the terms" />
        </EditForm>
    </DocExample>

    <DocExample Title="Custom Label Content" Code="@CustomCode">
        <W3Checkbox @bind-Value="CheckboxModel.Updates">
            Receive product updates
        </W3Checkbox>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>bool</td><td>false</td><td>Checked state</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;bool&gt;</td><td>none</td><td>Raised when the checked state changes</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;bool&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Label</td><td>string?</td><td>null</td><td>Label text</td></tr>
                <tr><td>LabelClass</td><td>string?</td><td>null</td><td>Additional wrapper label classes</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Custom label content</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional input classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style on the input</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the checkbox input</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/select" PreviousText="Select" NextHref="components/radio" NextText="Radio" />
</W3Container>

@code {
    private readonly CheckboxExampleModel CheckboxModel = new();

    private const string BasicCode = """
<W3Checkbox @bind-Value="model.Accepted" Label="I accept the terms" />
""";

    private const string CustomCode = """
<W3Checkbox @bind-Value="model.Updates">
    Receive product updates
</W3Checkbox>
""";

    private sealed class CheckboxExampleModel
    {
        public bool Accepted { get; set; }
        public bool Updates { get; set; } = true;
    }
}
