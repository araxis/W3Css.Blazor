@page "/components/collapse"

<PageTitle>W3Collapse</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Collapse</h1>
    <DocPager PreviousHref="components/accordion" PreviousText="Accordion" NextHref="components/navbar" NextText="Navbar" />

    <p class="w3-large">`W3Collapse` is a simple disclosure surface for animated show/hide content.</p>
    <p>Pair it with `Expanded` or `IsExpanded` state for simple panels, form sections, and filter areas.</p>

    <DocExample Title="Bound Expansion State" Code="@BasicCode">
        <W3Button Color="W3Color.Teal" TextColor="W3Color.White" Round="W3Round.Medium" OnClick="@(() => isExpanded = !isExpanded)">Toggle details</W3Button>
        <W3Collapse @bind-Expanded="isExpanded"
                    Border="true"
                    Round="W3Round.Small"
                    Color="W3Color.PaleBlue"
                    TextColor="W3Color.Black"
                    Class="w3-margin-top">
            <W3Container Class="w3-padding">
                <p>This content is only present in the DOM when expanded.</p>
            </W3Container>
        </W3Collapse>
    </DocExample>

    <DocExample Title="Alternative State Binding" Code="@AliasCode">
        <W3Button Color="W3Color.Black" TextColor="W3Color.White" Round="W3Round.Small" OnClick="@(() => aliasExpanded = !aliasExpanded)">Toggle alias value</W3Button>
        <W3Collapse @bind-IsExpanded="aliasExpanded" Animate="false">
            <p>Use <code>IsExpanded</code> when the surrounding model already uses that state name.</p>
        </W3Collapse>
        <p>Current alias state: <strong>@aliasExpanded</strong></p>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Expanded</td><td>bool</td><td>false</td><td>Primary expanded state when <code>IsExpanded</code> is not provided.</td></tr>
                <tr><td>ExpandedChanged</td><td>EventCallback&lt;bool&gt;</td><td>empty</td><td>Raised when expanded state changes.</td></tr>
                <tr><td>IsExpanded</td><td>bool?</td><td>null</td><td>Alternative expanded state (takes precedence over <code>Expanded</code> when set).</td></tr>
                <tr><td>IsExpandedChanged</td><td>EventCallback&lt;bool&gt;</td><td>empty</td><td>Raised when <code>IsExpanded</code> mode is used.</td></tr>
                <tr><td>Animate</td><td>bool</td><td>true</td><td>Includes <code>w3-animate-opacity</code> when true.</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>Adds/removes <code>w3-border</code>.</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Round utility class.</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class.</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class.</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Content rendered only while expanded.</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional wrapper classes.</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style on the wrapper.</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra attributes on the wrapper.</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/accordion" PreviousText="Accordion" NextHref="components/navbar" NextText="Navbar" />
</W3Container>

@code {
    private bool isExpanded = true;
    private bool aliasExpanded = true;

    private const string BasicCode = """
<W3Button OnClick="@(() => isExpanded = !isExpanded)">Toggle details</W3Button>
<W3Collapse @bind-Expanded="isExpanded"
            Border="true"
            Round="W3Round.Small"
            Color="W3Color.PaleBlue"
            TextColor="W3Color.Black">
    <W3Container Class="w3-padding">
        <p>This content is only present in the DOM when expanded.</p>
    </W3Container>
</W3Collapse>
""";

    private const string AliasCode = """
<W3Button OnClick="@(() => aliasExpanded = !aliasExpanded)">Toggle alias value</W3Button>
<W3Collapse @bind-IsExpanded="aliasExpanded" Animate="false">
    <p>Use IsExpanded when the surrounding model already uses that state name.</p>
</W3Collapse>
<p>Current alias state: @aliasExpanded</p>
""";
}
