@page "/components/column"

<PageTitle>W3Column</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Column</h1>
    <DocPager PreviousHref="components/row" PreviousText="Row" NextHref="components/grid" NextText="Grid" />

    <p class="w3-large">`W3Column` renders W3.CSS responsive column classes.</p>
    <p>Use `Small`, `Medium`, and `Large` values from 1 to 12 to map the column width at each breakpoint.</p>

    <DocExample Title="Breakpoint Columns" Code="@BreakpointCode">
        <W3Row Padding="true">
            <W3Column Small="12" Medium="6" Large="3">
                <W3Panel Color="W3Color.PaleBlue" TextColor="W3Color.Black" Border="true">s12 m6 l3</W3Panel>
            </W3Column>
            <W3Column Small="12" Medium="6" Large="9">
                <W3Panel Color="W3Color.PaleGreen" TextColor="W3Color.Black" Border="true">s12 m6 l9</W3Panel>
            </W3Column>
        </W3Row>
    </DocExample>

    <DocExample Title="Rest Column" Code="@RestCode">
        <W3Row>
            <W3Column Small="3"><W3Container Color="W3Color.Teal" TextColor="W3Color.White">Fixed</W3Container></W3Column>
            <W3Column Rest="true"><W3Container Color="W3Color.LightGrey">Remaining width</W3Container></W3Column>
        </W3Row>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Small</td><td>int</td><td>0</td><td>`s1` through `s12` when 1-12</td></tr>
                <tr><td>Medium</td><td>int</td><td>0</td><td>`m1` through `m12` when 1-12</td></tr>
                <tr><td>Large</td><td>int</td><td>0</td><td>`l1` through `l12` when 1-12</td></tr>
                <tr><td>Rest</td><td>bool</td><td>false</td><td>`w3-rest` instead of `w3-col`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Column body content</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional root column classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Root column inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra attributes on the column root</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/case-study">Case Study</NavLink> shows responsive columns as part of a complete page.</p>
    </section>

    <DocPager PreviousHref="components/row" PreviousText="Row" NextHref="components/grid" NextText="Grid" />
</W3Container>

@code {
    private const string BreakpointCode = """
<W3Row Padding="true">
    <W3Column Small="12" Medium="6" Large="3">s12 m6 l3</W3Column>
    <W3Column Small="12" Medium="6" Large="9">s12 m6 l9</W3Column>
</W3Row>
""";

    private const string RestCode = """
<W3Row>
    <W3Column Small="3">Fixed</W3Column>
    <W3Column Rest="true">Remaining width</W3Column>
</W3Row>
""";
}
