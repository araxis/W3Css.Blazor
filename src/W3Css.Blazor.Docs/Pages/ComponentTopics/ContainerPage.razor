@page "/components/container"

<PageTitle>W3Container</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Container</h1>
    <DocPager PreviousHref="components/footer" PreviousText="Footer" NextHref="components/panel" NextText="Panel" />

    <p class="w3-large">`W3Container` wraps content with the W3.CSS `w3-container` class.</p>
    <p>Use it for page sections, examples, cards, forms, and any content block that should follow W3.CSS container spacing.</p>

    <DocExample Title="Basic Use" Code="@BasicCode">
        <W3Container Color="W3Color.PaleBlue" TextColor="W3Color.Black">
            <h2 class="w3-large">Container heading</h2>
            <p>Containers add consistent horizontal padding around content.</p>
        </W3Container>
    </DocExample>

    <DocExample Title="With Custom Classes" Description="Use `Class` for additional W3.CSS utilities." Code="@ClassCode">
        <W3Container Color="W3Color.White" Class="w3-border w3-round w3-padding-16">
            <p>Extra utility classes are appended to the generated class list.</p>
        </W3Container>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Container body content</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra attributes on the container root</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/case-study">Case Study</NavLink> shows containers inside full page compositions.</p>
        <p><NavLink href="components/material-design">Material Design</NavLink> shows containers as themed surfaces and action areas.</p>
        <p><NavLink href="components/app-shell">App Shell</NavLink> uses containers inside complete app and site frames.</p>
        <p><NavLink href="components/panel">Panel</NavLink> and <NavLink href="components/card">Card</NavLink> build on the same container spacing idea.</p>
    </section>

    <DocPager PreviousHref="components/footer" PreviousText="Footer" NextHref="components/panel" NextText="Panel" />
</W3Container>

@code {
    private const string BasicCode = """
<W3Container Color="W3Color.PaleBlue" TextColor="W3Color.Black">
    <h2 class="w3-large">Container heading</h2>
    <p>Containers add consistent horizontal padding around content.</p>
</W3Container>
""";

    private const string ClassCode = """
<W3Container Color="W3Color.White" Class="w3-border w3-round w3-padding-16">
    <p>Extra utility classes are appended to the generated class list.</p>
</W3Container>
""";
}
