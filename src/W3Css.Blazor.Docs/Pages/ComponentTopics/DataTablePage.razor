    </section>

    <DocPager PreviousHref="components/table" PreviousText="Table" NextHref="components/tree-view" NextText="Tree View" />
</W3Container>

@code {
    private string? ProjectSearch { get; set; }

    private ProjectRow? SelectedProject { get; set; }

    private static readonly ProjectRow[] Projects =
    [
        new("Atlas", "Ada", "Active", 14, new DateOnly(2026, 5, 20)),
        new("Borealis", "Grace", "Review", 7, new DateOnly(2026, 5, 18)),
        new("Cygnus", "Linus", "Blocked", 3, new DateOnly(2026, 5, 12)),
        new("Delta", "Katherine", "Active", 22, new DateOnly(2026, 5, 24)),
        new("Equinox", "Barbara", "Review", 5, new DateOnly(2026, 5, 9))
    ];

    private static readonly ProjectRow[] EmptyProjects = [];

    private static W3Color GetStatusColor(string status)
    {
        return status switch
        {
            "Active" => W3Color.Teal,
            "Review" => W3Color.Indigo,
            "Blocked" => W3Color.Red,
            _ => W3Color.Grey
        };
    }

    private sealed record ProjectRow(string Name, string Owner, string Status, int Tasks, DateOnly Updated);

    private const string BasicCode = """
<W3DataTable TItem="ProjectRow"
             Items="Projects"
             PageSize="3"
             SearchPlaceholder="Search projects"
             @bind-SearchText="projectSearch">
    <ChildContent>
        <W3DataColumn TItem="ProjectRow"
                      Title="Project"
                      CellText="@((ProjectRow project) => project.Name)"
                      SortKey="@((ProjectRow project) => project.Name)" />
        <W3DataColumn TItem="ProjectRow"
                      Title="Owner"
                      CellText="@((ProjectRow project) => project.Owner)"
                      SearchValue="@((ProjectRow project) => project.Owner)" />
        <W3DataColumn TItem="ProjectRow"
                      Title="Tasks"
                      Align="W3TextAlignment.Right"
                      CellText="@((ProjectRow project) => project.Tasks)"
                      SortKey="@((ProjectRow project) => project.Tasks)" />
    </ChildContent>
</W3DataTable>
""";

    private const string TemplateCode = """
<W3DataTable TItem="ProjectRow"
             Items="Projects"
             PageSize="4"
             Searchable="false"
             Selectable="true"
             @bind-SelectedItem="selectedProject">
    <ChildContent>
        <W3DataColumn TItem="ProjectRow"
                      Title="Project"
                      CellText="@((ProjectRow project) => project.Name)"
                      SortKey="@((ProjectRow project) => project.Name)" />
        <W3DataColumn TItem="ProjectRow"
                      Title="Status"
                      CellText="@((ProjectRow project) => project.Status)"
                      SortKey="@((ProjectRow project) => project.Status)">
            <CellTemplate Context="project">
                <W3Tag Color="@GetStatusColor(project.Status)" TextColor="W3Color.White" Round="W3Round.Medium">@project.Status</W3Tag>
            </CellTemplate>
        </W3DataColumn>
        <W3DataColumn TItem="ProjectRow"
                      Title="Updated"
                      CellText="@((ProjectRow project) => project.Updated.ToString("MMM d"))"
                      SortKey="@((ProjectRow project) => project.Updated)" />
    </ChildContent>
    <RowActions Context="project">
        <W3Button Size="W3Size.Small" Border="true" Round="W3Round.Medium">Open</W3Button>
        <W3Button Size="W3Size.Small" Color="W3Color.Primary" TextColor="W3Color.White" Round="W3Round.Medium">Assign</W3Button>
    </RowActions>
</W3DataTable>
""";

    private const string StatesCode = """
<W3DataTable TItem="ProjectRow"
             Loading="true"
             LoadingText="Loading project rows">
    <ChildContent>
        <W3DataColumn TItem="ProjectRow" Title="Project" CellText="@((ProjectRow project) => project.Name)" />
    </ChildContent>
</W3DataTable>

<W3DataTable TItem="ProjectRow"
             Items="Array.Empty<ProjectRow>()"
             EmptyText="No projects match this view"
             EmptyDescription="Clear the filters or create a new project."
             Searchable="false">
    <ChildContent>
        <W3DataColumn TItem="ProjectRow" Title="Project" CellText="@((ProjectRow project) => project.Name)" />
    </ChildContent>
</W3DataTable>

<W3DataTable TItem="ProjectRow"
             Error="true"
             ErrorText="Projects could not load"
             ErrorDescription="Check the connection and retry."
             Searchable="false">
    <ChildContent>
        <W3DataColumn TItem="ProjectRow" Title="Project" CellText="@((ProjectRow project) => project.Name)" />
    </ChildContent>
</W3DataTable>
""";
}
