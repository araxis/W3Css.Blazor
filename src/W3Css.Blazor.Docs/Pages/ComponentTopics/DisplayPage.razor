@page "/components/display"

<PageTitle>W3Display</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Display</h1>
    <DocPager PreviousHref="components/cells" PreviousText="Cells" NextHref="components/visibility" NextText="Visibility" />

    <p class="w3-large">`W3DisplayContainer` and `W3Display` render W3.CSS positioned display helpers.</p>
    <p>Use them for image captions, card badges, slideshow controls, and content that needs a stable position inside a container.</p>

    <DocExample Title="Image Caption" Code="@CaptionCode">
        <W3DisplayContainer Class="w3-white w3-border" Style="max-width: 360px;">
            <W3Image Src="assets/w3css-blazor-mark.svg" Alt="W3Css.Blazor mark" Width="360" Height="180" Responsive="true" />
            <W3Display Position="W3DisplayPosition.BottomRight" Color="W3Color.Black" TextColor="W3Color.White" Class="w3-padding">
                Bottom right
            </W3Display>
        </W3DisplayContainer>
    </DocExample>

    <DocExample Title="Hover Overlay" Code="@HoverCode">
        <W3DisplayContainer Class="w3-white w3-border" Style="max-width: 360px;">
            <W3Image Src="assets/w3css-blazor-mark.svg" Alt="Hover mark" Width="360" Height="180" Responsive="true" Effect="W3ImageEffect.OpacityMin" />
            <W3Display Position="W3DisplayPosition.Middle" ShowOnHover="true" Color="W3Color.Teal" TextColor="W3Color.White" Class="w3-padding">
                Hover caption
            </W3Display>
        </W3DisplayContainer>
    </DocExample>

    <section class="doc-section">
        <h2>W3DisplayContainer Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Visibility</td><td>W3Visibility</td><td>Default</td><td>Optional visibility class</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string</td><td>null</td><td>Additional root display-container classes</td></tr>
                <tr><td>Style</td><td>string</td><td>null</td><td>Root display-container inline style</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment</td><td>null</td><td>Content inside `w3-display-container`</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>W3Display Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Position</td><td>W3DisplayPosition</td><td>None</td><td>`w3-display-*` position class</td></tr>
                <tr><td>ShowOnHover</td><td>bool</td><td>false</td><td>`w3-display-hover`</td></tr>
                <tr><td>Visibility</td><td>W3Visibility</td><td>Default</td><td>Optional show or hide class</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string</td><td>null</td><td>Additional root display classes</td></tr>
                <tr><td>Style</td><td>string</td><td>null</td><td>Custom position style when `Position` is `Custom`</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment</td><td>null</td><td>Content inside the display region</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/cells" PreviousText="Cells" NextHref="components/visibility" NextText="Visibility" />
</W3Container>

@code {
    private const string CaptionCode = """
<W3DisplayContainer>
    <W3Image Src="assets/w3css-blazor-mark.svg" Alt="W3Css.Blazor mark" />
    <W3Display Position="W3DisplayPosition.BottomRight" Color="W3Color.Black" TextColor="W3Color.White">
        Bottom right
    </W3Display>
</W3DisplayContainer>
""";

    private const string HoverCode = """
<W3DisplayContainer>
    <W3Image Src="assets/w3css-blazor-mark.svg" Alt="Hover mark" Effect="W3ImageEffect.OpacityMin" />
    <W3Display Position="W3DisplayPosition.Middle" ShowOnHover="true" Color="W3Color.Teal" TextColor="W3Color.White">
        Hover caption
    </W3Display>
</W3DisplayContainer>
""";
}
