@page "/components/fab"

<PageTitle>W3Fab</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Fab</h1>
    <DocPager PreviousHref="components/icon-button" PreviousText="Icon Button" NextHref="components/button-group" NextText="Button Group" />

    <p class="w3-large">`W3Fab` renders a prominent floating action button for the primary action on a page, app surface, or design tool.</p>
    <p>Use it when one action should stay highly available, such as creating an item, adding a node, opening capture, or starting a workflow.</p>

    <DocExample Title="Primary FABs" Description="Icon-only FABs still require a `Label`; the icon remains decorative for assistive technology." Code="@PrimaryCode">
        <W3Fab Label="Create item" Title="Create" IconClass="fa fa-plus" Class="w3-margin-right" />
        <W3Fab Label="Open command palette" Title="Commands" IconClass="fa fa-bolt" Mini="true" Color="W3Color.Black" TextColor="W3Color.White" />
    </DocExample>

    <DocExample Title="Extended FAB" Description="Use `Extended` when the primary command needs a short visible verb beside the icon." Code="@ExtendedCode">
        <W3Fab Label="Create workflow" Title="Create workflow" IconClass="fa fa-plus" Extended="true" Color="W3Color.Green" TextColor="W3Color.White">New workflow</W3Fab>
    </DocExample>

    <DocExample Title="Anchored App Action" Description="Use `Position` inside a relatively positioned app preview, or add `Fixed` to anchor the FAB to the viewport." Code="@AnchoredCode">
        <div class="w3-display-container w3-border w3-light-grey" style="position:relative; min-height:220px;">
            <div class="w3-container w3-padding-24">
                <h3 class="w3-margin-top">Task Board</h3>
                <W3Panel Color="W3Color.White" Round="W3Round.Medium" Class="w3-margin-bottom">
                    <strong>Design review</strong>
                    <p class="w3-small w3-margin-bottom">Ready for assignment</p>
                </W3Panel>
                <W3Panel Color="W3Color.White" Round="W3Round.Medium">
                    <strong>Prototype polish</strong>
                    <p class="w3-small w3-margin-bottom">Needs owner</p>
                </W3Panel>
            </div>
            <W3Fab Label="Create task" Title="Create task" IconClass="fa fa-plus" Position="W3FabPosition.BottomRight" Offset="18" />
        </div>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Label</td><td>string</td><td>Floating action</td><td>Required button `aria-label` fallback</td></tr>
                <tr><td>Title</td><td>string?</td><td>null</td><td>Optional native title tooltip</td></tr>
                <tr><td>IconClass</td><td>string?</td><td>null</td><td>Classes passed to the inner `W3Icon`</td></tr>
                <tr><td>IconElementClass</td><td>string?</td><td>null</td><td>Additional class on the inner icon element</td></tr>
                <tr><td>IconContent</td><td>RenderFragment?</td><td>null</td><td>Icon text for icon fonts such as Material Icons</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Visible label content when `Extended` is true</td></tr>
                <tr><td>Extended</td><td>bool</td><td>false</td><td>Shows a rounded label button instead of a circle</td></tr>
                <tr><td>Mini</td><td>bool</td><td>false</td><td>Smaller square/circle FAB sizing</td></tr>
                <tr><td>Position</td><td>W3FabPosition</td><td>Inline</td><td>Placement class for anchored or fixed buttons</td></tr>
                <tr><td>Fixed</td><td>bool</td><td>false</td><td>`position: fixed` instead of absolute placement</td></tr>
                <tr><td>Offset</td><td>int</td><td>24</td><td>Corner offset in pixels through `--w3-fab-offset`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>Teal</td><td>Button background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>White</td><td>Button text color class</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Large</td><td>Button text/icon size class</td></tr>
                <tr><td>Depth</td><td>W3CardDepth</td><td>Four</td><td>W3.CSS card shadow class</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` plus `w3-disabled`</td></tr>
                <tr><td>Type</td><td>string</td><td>button</td><td>Button type attribute</td></tr>
                <tr><td>OnClick</td><td>EventCallback&lt;MouseEventArgs&gt;</td><td>empty</td><td>Click callback</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional root classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style on the button</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the floating action button element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/icon-button">Icon Button</NavLink> covers compact inline icon-only commands, and <NavLink href="components/button">Button</NavLink> covers standard text actions.</p>
    </section>

    <DocPager PreviousHref="components/icon-button" PreviousText="Icon Button" NextHref="components/button-group" NextText="Button Group" />
</W3Container>

@code {
    private const string PrimaryCode = """
<W3Fab Label="Create item" Title="Create" IconClass="fa fa-plus" />
<W3Fab Label="Open command palette" Title="Commands" IconClass="fa fa-bolt" Mini="true" Color="W3Color.Black" TextColor="W3Color.White" />
""";

    private const string ExtendedCode = """
<W3Fab Label="Create workflow" Title="Create workflow" IconClass="fa fa-plus" Extended="true" Color="W3Color.Green" TextColor="W3Color.White">
    New workflow
</W3Fab>
""";

    private const string AnchoredCode = """
<div class="w3-display-container" style="position:relative; min-height:220px;">
    <W3Fab Label="Create task" Title="Create task" IconClass="fa fa-plus" Position="W3FabPosition.BottomRight" Offset="18" />
</div>
""";
}
