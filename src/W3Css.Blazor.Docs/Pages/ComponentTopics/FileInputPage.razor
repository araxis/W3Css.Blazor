@page "/components/file-input"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>W3FileInput</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3FileInput</h1>
    <DocPager PreviousHref="components/color-input" PreviousText="Color Input" NextHref="components/drop-zone" NextText="Drop Zone" />

    <p class="w3-large">`W3FileInput` wraps Blazor's `InputFile` with W3.CSS input styling and file-selection ergonomics.</p>
    <p>Use it for uploads, imports, attachments, and design tools that need a native file picker while staying script-free.</p>

    <DocExample Title="Single File" Description="Handle the normal Blazor InputFile change event and keep upload logic in your app code." Code="@SingleCode">
        <W3FileInput Id="file-avatar"
                     Accept="image/*"
                     Border="true"
                     Round="W3Round.Medium"
                     OnChange="HandleSingleFile" />
        @if (!string.IsNullOrWhiteSpace(LastFileName))
        {
            <p class="w3-small">Selected: <strong>@LastFileName</strong></p>
        }
    </DocExample>

    <DocExample Title="Multiple Files" Description="Use Multiple and ShowSelectedFiles when users need to confirm a small batch before upload." Code="@MultipleCode">
        <W3FileInput Id="file-assets"
                     Accept=".png,.jpg,.svg"
                     Multiple="true"
                     ShowSelectedFiles="true"
                     Border="true"
                     Round="W3Round.Medium"
                     Color="W3Color.White" />
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>OnChange</td><td>EventCallback&lt;InputFileChangeEventArgs&gt;</td><td>none</td><td>Blazor file selection event</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Name</td><td>string?</td><td>null</td><td>`name` attribute</td></tr>
                <tr><td>Accept</td><td>string?</td><td>null</td><td>`accept` attribute</td></tr>
                <tr><td>Multiple</td><td>bool</td><td>false</td><td>`multiple` attribute</td></tr>
                <tr><td>ShowSelectedFiles</td><td>bool</td><td>false</td><td>Renders a small selected-file list after change</td></tr>
                <tr><td>MaximumFileCount</td><td>int</td><td>10</td><td>Maximum files read for the selected-file list</td></tr>
                <tr><td>SelectedFilesClass</td><td>string?</td><td>null</td><td>Additional selected-file list classes</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional input classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/field">Field</NavLink> wraps labels, help text, and validation messages.</p>
        <p><NavLink href="components/drop-zone">Drop Zone</NavLink> covers larger upload and import surfaces.</p>
        <p><NavLink href="components/button">Button</NavLink> covers upload action buttons.</p>
        <p><NavLink href="components/color-input">Color Input</NavLink> covers native color values.</p>
    </section>

    <DocPager PreviousHref="components/color-input" PreviousText="Color Input" NextHref="components/drop-zone" NextText="Drop Zone" />
</W3Container>

@code {
    private string? LastFileName { get; set; }

    private void HandleSingleFile(InputFileChangeEventArgs args)
    {
        LastFileName = args.File.Name;
    }

    private const string SingleCode = """
<W3FileInput Id="file-avatar"
             Accept="image/*"
             Border="true"
             Round="W3Round.Medium"
             OnChange="HandleSingleFile" />

@code {
    private string? lastFileName;

    private void HandleSingleFile(InputFileChangeEventArgs args)
    {
        lastFileName = args.File.Name;
    }
}
""";

    private const string MultipleCode = """
<W3FileInput Id="file-assets"
             Accept=".png,.jpg,.svg"
             Multiple="true"
             ShowSelectedFiles="true"
             Border="true"
             Round="W3Round.Medium"
             Color="W3Color.White" />
""";
}
