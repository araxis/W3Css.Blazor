@page "/components/icons"

<PageTitle>W3Icon</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Icon</h1>
    <DocPager PreviousHref="components/avatar-group" PreviousText="Avatar Group" NextHref="components/image" NextText="Image" />

    <p class="w3-large">`W3Icon` renders built-in inline SVG icons with W3.CSS color and size utilities.</p>
    <p>Use `IconName` for first-party icons that work without extra assets. `IconClass` remains available for app-owned icon styles.</p>

    <DocExample Title="Icon Buttons" Code="@ButtonCode">
        <div class="w3-bar w3-border w3-white">
            <W3Button Class="w3-bar-item">
                <W3Icon IconName="W3IconName.Home" Class="w3-margin-right" />
                Home
            </W3Button>
            <W3Button Class="w3-bar-item">
                <W3Icon IconName="W3IconName.Search" Class="w3-margin-right" />
                Search
            </W3Button>
            <W3Button Class="w3-bar-item">
                <W3Icon IconName="W3IconName.Refresh" Class="w3-margin-right" />
                Refresh
            </W3Button>
        </div>
    </DocExample>

    <DocExample Title="Sized And Accessible Icons" Code="@AccessibleCode">
        <p>
            <W3Icon IconName="W3IconName.Home" Size="W3Size.XXLarge" TextColor="W3Color.Teal" Label="Home" Class="w3-margin-right" />
            <W3Icon IconName="W3IconName.Search" Size="W3Size.XXLarge" TextColor="W3Color.Blue" Label="Search" Class="w3-margin-right" />
            <W3Icon IconName="W3IconName.Delete" Size="W3Size.XXLarge" TextColor="W3Color.Red" Label="Delete" />
        </p>
    </DocExample>

    <section class="doc-section">
        <h2>Built-in Catalog</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Group</th><th>Names</th></tr>
            </thead>
            <tbody>
                <tr><td>Navigation</td><td>`Home`, `Menu`, `Search`, `ChevronLeft`, `ChevronRight`, `ArrowUp`, `ArrowDown`</td></tr>
                <tr><td>Actions</td><td>`Add`, `Edit`, `Save`, `Delete`, `Copy`, `Download`, `Upload`, `Refresh`, `Undo`, `Redo`</td></tr>
                <tr><td>Status</td><td>`Info`, `Success`, `Warning`, `Error`, `Bell`, `Lock`, `Star`, `StarOutline`</td></tr>
                <tr><td>App</td><td>`Dashboard`, `Table`, `Tasks`, `Workflow`, `Settings`, `Users`, `Monitor`, `Sun`, `Moon`</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>IconName</td><td>W3IconName</td><td>None</td><td>Built-in SVG icon name</td></tr>
                <tr><td>IconClass</td><td>string?</td><td>null</td><td>Optional app-owned icon classes</td></tr>
                <tr><td>Label</td><td>string?</td><td>null</td><td>`role="img"` and `aria-label`; omitted icons render `aria-hidden="true"`</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Custom icon content when not using `IconName`</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Default</td><td>W3.CSS size class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional classes on the icon element</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline styles on the icon element</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the icon element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related W3.CSS</h2>
        <p><a href="https://www.w3schools.com/w3css/w3css_icons.asp" target="_blank" rel="noopener">W3.CSS Icons</a></p>
    </section>

    <DocPager PreviousHref="components/avatar-group" PreviousText="Avatar Group" NextHref="components/image" NextText="Image" />
</W3Container>

@code {
    private const string ButtonCode = """
<div class="w3-bar w3-border w3-white">
    <W3Button Class="w3-bar-item">
        <W3Icon IconName="W3IconName.Home" Class="w3-margin-right" />
        Home
    </W3Button>

    <W3Button Class="w3-bar-item">
        <W3Icon IconName="W3IconName.Search" Class="w3-margin-right" />
        Search
    </W3Button>

    <W3Button Class="w3-bar-item">
        <W3Icon IconName="W3IconName.Refresh" Class="w3-margin-right" />
        Refresh
    </W3Button>
</div>
""";

    private const string AccessibleCode = """
<W3Icon IconName="W3IconName.Home"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Teal"
        Label="Home"
        Class="w3-margin-right" />

<W3Icon IconName="W3IconName.Search"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Blue"
        Label="Search"
        Class="w3-margin-right" />

<W3Icon IconName="W3IconName.Delete"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Red"
        Label="Delete" />
""";
