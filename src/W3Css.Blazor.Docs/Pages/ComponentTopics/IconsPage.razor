@page "/components/icons"

<PageTitle>W3Icon</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Icon</h1>
    <DocPager PreviousHref="components/avatar-group" PreviousText="Avatar Group" NextHref="components/image" NextText="Image" />

    <p class="w3-large">`W3Icon` renders an inline icon element for the icon library you choose.</p>
    <p>The component does not bundle an icon font. Add the icon stylesheet to your app, then pass the library classes through `IconClass`.</p>

    <DocExample Title="Icon Buttons" Code="@ButtonCode">
        <div class="w3-bar w3-border w3-white">
            <W3Button Class="w3-bar-item">
                <W3Icon IconClass="fa fa-home" Class="w3-margin-right" />
                Home
            </W3Button>
            <W3Button Class="w3-bar-item">
                <W3Icon IconClass="fa fa-search" Class="w3-margin-right" />
                Search
            </W3Button>
            <W3Button Class="w3-bar-item">
                <W3Icon IconClass="fa fa-refresh" Class="w3-margin-right" />
                Refresh
            </W3Button>
        </div>
    </DocExample>

    <DocExample Title="Sized And Accessible Icons" Code="@AccessibleCode">
        <p>
            <W3Icon IconClass="fa fa-home" Size="W3Size.XXLarge" TextColor="W3Color.Teal" Label="Home" Class="w3-margin-right" />
            <W3Icon IconClass="fa fa-search" Size="W3Size.XXLarge" TextColor="W3Color.Blue" Label="Search" Class="w3-margin-right" />
            <W3Icon IconClass="fa fa-trash" Size="W3Size.XXLarge" TextColor="W3Color.Red" Label="Delete" />
        </p>
    </DocExample>

    <section class="doc-section">
        <h2>Library Setup</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Library</th><th>Include</th><th>Use with `W3Icon`</th></tr>
            </thead>
            <tbody>
                <tr><td>Font Awesome</td><td>`font-awesome.min.css`</td><td>`IconClass="fa fa-home"`</td></tr>
                <tr><td>Google Material Icons</td><td>`https://fonts.googleapis.com/icon?family=Material+Icons`</td><td>`IconClass="material-icons"` with child content such as `home`</td></tr>
                <tr><td>Bootstrap Icons</td><td>Your selected Bootstrap Icons stylesheet</td><td>`IconClass="bi bi-search"`</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>IconClass</td><td>string?</td><td>null</td><td>Classes from the selected icon library</td></tr>
                <tr><td>Label</td><td>string?</td><td>null</td><td>`role="img"` and `aria-label`; omitted icons render `aria-hidden="true"`</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Inner text for icon sets such as Material Icons</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Default</td><td>W3.CSS size class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional classes on the icon element</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline styles on the icon element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related W3.CSS</h2>
        <p><a href="https://www.w3schools.com/w3css/w3css_icons.asp" target="_blank" rel="noopener">W3.CSS Icons</a></p>
    </section>

    <DocPager PreviousHref="components/avatar-group" PreviousText="Avatar Group" NextHref="components/image" NextText="Image" />
</W3Container>

@code {
    private const string ButtonCode = """
<div class="w3-bar w3-border w3-white">
    <W3Button Class="w3-bar-item">
        <W3Icon IconClass="fa fa-home" Class="w3-margin-right" />
        Home
    </W3Button>

    <W3Button Class="w3-bar-item">
        <W3Icon IconClass="fa fa-search" Class="w3-margin-right" />
        Search
    </W3Button>

    <W3Button Class="w3-bar-item">
        <W3Icon IconClass="fa fa-refresh" Class="w3-margin-right" />
        Refresh
    </W3Button>
</div>
""";

    private const string AccessibleCode = """
<W3Icon IconClass="fa fa-home"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Teal"
        Label="Home"
        Class="w3-margin-right" />

<W3Icon IconClass="fa fa-search"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Blue"
        Label="Search"
        Class="w3-margin-right" />

<W3Icon IconClass="fa fa-trash"
        Size="W3Size.XXLarge"
        TextColor="W3Color.Red"
        Label="Delete" />
""";
}
