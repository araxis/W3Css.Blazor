@page "/components/input"

<PageTitle>W3Input</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Input</h1>
    <DocPager PreviousHref="components/mobile" PreviousText="Mobile" NextHref="components/mask" NextText="Mask" />

    <p class="w3-large">`W3Input` renders a validation-friendly Blazor input with the W3.CSS `w3-input` class.</p>
    <p>Use it inside <code>EditForm</code> with <code>@@bind-Value</code> for normal Blazor validation behavior.</p>

    <DocExample Title="Basic Input" Code="@BasicCode">
        <EditForm Model="@InputModel">
            <W3Field TValue="string" Label="Name" ForId="input-name" For="@(() => InputModel.Name)" HelpText="Type a display name.">
                <W3Input Id="input-name" @bind-Value="InputModel.Name" Placeholder="Ada Lovelace" Border="true" Round="W3Round.Medium" />
            </W3Field>
        </EditForm>
    </DocExample>

    <DocExample Title="Email Input" Code="@EmailCode">
        <W3Input Type="email" @bind-Value="InputModel.Email" Placeholder="name@example.com" Border="true" Color="W3Color.White" />
    </DocExample>

    <DocExample Title="Animated Input" Code="@AnimatedCode">
        <W3Input Animation="W3Animation.Input" @bind-Value="InputModel.Search" Placeholder="Focus to expand" Border="true" Style="width: 12rem; max-width: 100%;" />
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>string</td><td>null</td><td>Blazor input value</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;string?&gt;</td><td>none</td><td>Raised when the bound value changes</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;string?&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Type</td><td>string</td><td>text</td><td>Input type attribute</td></tr>
                <tr><td>Placeholder</td><td>string</td><td>null</td><td>Placeholder attribute</td></tr>
                <tr><td>Animation</td><td>W3Animation</td><td>None</td><td>Optional animation class, including `w3-animate-input`</td></tr>
                <tr><td>UpdateOnInput</td><td>bool</td><td>false</td><td>Updates `Value` on `input` instead of `change`</td></tr>
                <tr><td>ReadOnly</td><td>bool</td><td>false</td><td>`readonly` attribute</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional CSS classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the input element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/mobile" PreviousText="Mobile" NextHref="components/mask" NextText="Mask" />
</W3Container>

@code {
    private readonly InputExampleModel InputModel = new();

    private const string BasicCode = """
<EditForm Model="@model">
    <W3Field TValue="string" Label="Name" ForId="input-name" For="@(() => model.Name)" HelpText="Type a display name.">
        <W3Input Id="input-name" @bind-Value="model.Name" Placeholder="Ada Lovelace" Border="true" Round="W3Round.Medium" />
    </W3Field>
</EditForm>
""";

    private const string EmailCode = """
<W3Input Type="email" @bind-Value="model.Email" Placeholder="name@example.com" Border="true" Color="W3Color.White" />
""";

    private const string AnimatedCode = """
<W3Input Animation="W3Animation.Input"
         @bind-Value="model.Search"
         Placeholder="Focus to expand"
         Border="true"
         Style="width: 12rem; max-width: 100%;" />
""";

    private sealed class InputExampleModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Search { get; set; } = string.Empty;
    }
}
