@page "/components/link"

<PageTitle>W3Link</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Link</h1>
    <DocPager PreviousHref="components/page-content-navigation" PreviousText="Page Content Navigation" NextHref="components/dropdown" NextText="Dropdown" />

    <p class="w3-large">
        <code>W3Link</code> is a tiny navigation primitive for links, command buttons, and quick MudBlazor migration paths.
    </p>
    <p>Use it anywhere you need one typed component for both hyperlinks and command-style buttons while keeping W3.CSS class control localized.</p>

    <DocExample Title="Hyperlink" Description="Provide a URL and render a standard link by default." Code="@LinkCode">
        <W3Link Href="components" Text="Open component catalog" TextColor="W3Color.Teal" />
    </DocExample>

    <DocExample Title="Button-Style Command" Description="Enable button styling for command links in toolbars and tables." Code="@ButtonCode">
        <W3Link Button="true"
                 Href="components/drop-zone"
                 Color="W3Color.Teal"
                 TextColor="W3Color.White"
                 Round="W3Round.Medium">
            Upload workflow
        </W3Link>
    </DocExample>

    <DocExample Title="Disabled Link" Description="Render a non-interactive state without navigation." Code="@DisabledCode">
        <W3Link Href="components/menu" Disabled="true" Text="Unavailable" />
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Text</td><td>string?</td><td>null</td><td>Plain text content when no <code>ChildContent</code> is supplied</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Custom child markup</td></tr>
                <tr><td>Href</td><td>string?</td><td>null</td><td>Anchor target URL</td></tr>
                <tr><td>Button</td><td>bool</td><td>false</td><td>Renders as <code>&lt;button&gt;</code> when no anchor URL is provided, and keeps button styling</td></tr>
                <tr><td>Target</td><td>string?</td><td>null</td><td>Anchor <code>target</code> attribute</td></tr>
                <tr><td>Rel</td><td>string?</td><td>null</td><td>Anchor <code>rel</code> attribute</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>Renders non-interactive <code>span</code> with <code>aria-disabled</code></td></tr>
                <tr><td>Underline</td><td>bool</td><td>true</td><td>When false, removes decoration with inline style</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Button background when <code>Button</code> is true</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Default</td><td>Button size class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Corner style class</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>Button/disabled border style</td></tr>
                <tr><td>Block</td><td>bool</td><td>false</td><td><code>w3-block</code> for full-width button mode</td></tr>
                <tr><td>OnClick</td><td>EventCallback&lt;MouseEventArgs&gt;</td><td>empty</td><td>Raised in anchor and button modes</td></tr>
                <tr><td>Type</td><td>string</td><td>button</td><td>Button type attribute</td></tr>
                <tr><td>Class / Style</td><td>string?</td><td>null</td><td>Additional root classes and inline style</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/bar">Bar</NavLink> and <NavLink href="components/breadcrumb">Breadcrumb</NavLink> are higher-level navigation compositions.</p>
        <p><NavLink href="components/nav-menu">Nav Menu</NavLink> adds grouped route-aware sections and icon/badge affordances.</p>
        <p><NavLink href="components/dropdown">Dropdown</NavLink> is useful when command links need open-state behavior.</p>
    </section>

    <DocPager PreviousHref="components/page-content-navigation" PreviousText="Page Content Navigation" NextHref="components/dropdown" NextText="Dropdown" />
</W3Container>

@code {
    private const string LinkCode = """
<W3Link Href="components" Text="Open component catalog" TextColor="W3Color.Teal" />
""";

    private const string ButtonCode = """
<W3Link Button="true"
         Href="components/drop-zone"
         Color="W3Color.Teal"
         TextColor="W3Color.White"
         Round="W3Round.Medium">
    Upload workflow
</W3Link>
""";

    private const string DisabledCode = """
<W3Link Href="components/menu" Disabled="true" Text="Unavailable" />
""";
}
