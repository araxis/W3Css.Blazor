               Min="0"
               Max="999"
               Step="0.01"
               Placeholder="0.00"
               Border="true"
               Color="W3Color.White" />
""";

    private const string RequiredCode = """
@using System.ComponentModel.DataAnnotations

<EditForm Model="@model" OnValidSubmit="HandleSubmit" OnInvalidSubmit="HandleSubmit" novalidate>
    <DataAnnotationsValidator />
    <W3Field TValue="int" Label="Seats" ForId="required-seats" For="@(() => model.Seats)" HelpText="Choose between 1 and 12 seats.">
        <W3NumberInput TValue="int"
                       Id="required-seats"
                       @bind-Value="model.Seats"
                       Min="1"
                       Max="12"
                       Step="1"
                       Required="true"
                       UpdateOnInput="true"
                       Border="true"
                       Round="W3Round.Medium" />
    </W3Field>
    <W3Button Type="submit" Color="W3Color.Teal" TextColor="W3Color.White">Validate</W3Button>
</EditForm>

