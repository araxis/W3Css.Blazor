    private const string IntegerCode = """
<W3Field TValue="int" Label="Seats" ForId="number-seats" For="@(() => model.Seats)" HelpText="Choose between 1 and 12 seats.">
    <W3NumberInput TValue="int"
                   Id="number-seats"
                   @bind-Value="model.Seats"
                   Min="1"
                   Max="12"
                   Step="1"
                   Border="true"
                   Round="W3Round.Medium" />
</W3Field>
""";

    private const string DecimalCode = """
<W3NumberInput TValue="decimal"
