@page "/components/rating"
@using System.ComponentModel.DataAnnotations

<PageTitle>W3Rating</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Rating</h1>
    <DocPager PreviousHref="components/slider" PreviousText="Slider" NextHref="components/switch" NextText="Switch" />

    <p class="w3-large">`W3Rating` renders a compact icon rating control for reviews, preference scoring, and quick feedback forms.</p>
    <p>Use it when a bounded score is easier to pick with icons than with a numeric input or slider. Add `novalidate` on the form when validation messages should handle required feedback.</p>

    <DocExample Title="Interactive Rating" Code="@InteractiveCode">
        <W3Rating @bind-Value="ReviewRating"
                  Label="Review score"
                  Clearable="true"
                  ShowValue="true" />
        <p class="w3-small">Selected score: <strong>@ReviewRating</strong></p>
    </DocExample>

    <DocExample Title="Read Only Score" Code="@ReadOnlyCode">
        <W3Rating Value="4"
                  Label="Average customer rating"
                  ReadOnly="true"
                  ShowValue="true"
                  Color="W3Color.Teal"
                  Size="W3Size.XLarge" />
    </DocExample>

    <DocExample Title="Required Rating" Description="Use Required with a validation expression and a range rule when a score must be chosen." Code="@RequiredCode">
        <EditForm Model="@RequiredRatingModel" OnValidSubmit="HandleRequiredSubmit" OnInvalidSubmit="HandleRequiredSubmit" novalidate>
            <DataAnnotationsValidator />
            <W3Field TValue="int" Label="Satisfaction" For="@(() => RequiredRatingModel.Score)" HelpText="Choose a score before continuing.">
                <W3Rating Value="@RequiredRatingModel.Score"
                          ValueChanged="@((int next) => RequiredRatingModel.Score = next)"
                          ValueExpression="@(() => RequiredRatingModel.Score)"
                          Label="Satisfaction score"
                          Required="true"
                          Clearable="true"
                          ShowValue="true" />
            </W3Field>
            <W3Button Type="submit" Color="W3Color.Teal" TextColor="W3Color.White">Validate</W3Button>
        </EditForm>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>int</td><td>0</td><td>Current selected rating</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;int&gt;</td><td>empty</td><td><code>@@bind-Value</code> support</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;int&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Max</td><td>int</td><td>5</td><td>Number of rating buttons</td></tr>
                <tr><td>Label</td><td>string</td><td>Rating</td><td>`aria-label` on the radiogroup</td></tr>
                <tr><td>ReadOnly</td><td>bool</td><td>false</td><td>Disables interaction while keeping the value visible</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`aria-disabled`, `disabled`, and `w3-disabled`</td></tr>
                <tr><td>Required</td><td>bool</td><td>false</td><td>`aria-required` on the rating group</td></tr>
                <tr><td>Clearable</td><td>bool</td><td>false</td><td>Clicking the selected score clears to zero</td></tr>
                <tr><td>ShowValue</td><td>bool</td><td>false</td><td>Displays `Value / Max` text beside the icons</td></tr>
                <tr><td>IconClass</td><td>string</td><td>fa fa-star</td><td>Selected icon class</td></tr>
                <tr><td>EmptyIconClass</td><td>string</td><td>fa fa-star-o</td><td>Unselected icon class</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>Amber</td><td>Selected icon text color</td></tr>
                <tr><td>EmptyColor</td><td>W3Color</td><td>Grey</td><td>Unselected icon text color</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Large</td><td>W3.CSS text size class on icon buttons</td></tr>
                <tr><td>Gap</td><td>int</td><td>2</td><td>Gap in pixels between icons</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional classes on the rating group</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline styles on the rating group</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra attributes on the rating group</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/slider" PreviousText="Slider" NextHref="components/switch" NextText="Switch" />
</W3Container>

@code {
    private int ReviewRating { get; set; } = 3;
    private readonly RequiredRatingExampleModel RequiredRatingModel = new();

    private const string InteractiveCode = """
<W3Rating @bind-Value="reviewRating"
          Label="Review score"
          Clearable="true"
          ShowValue="true" />
""";

    private const string ReadOnlyCode = """
<W3Rating Value="4"
          Label="Average customer rating"
          ReadOnly="true"
          ShowValue="true"
          Color="W3Color.Teal"
          Size="W3Size.XLarge" />
""";

    private const string RequiredCode = """
@using System.ComponentModel.DataAnnotations

<EditForm Model="@model" OnValidSubmit="HandleSubmit" OnInvalidSubmit="HandleSubmit" novalidate>
    <DataAnnotationsValidator />
    <W3Field TValue="int" Label="Satisfaction" For="@(() => model.Score)" HelpText="Choose a score before continuing.">
        <W3Rating Value="@model.Score"
                  ValueChanged="@((int next) => model.Score = next)"
                  ValueExpression="@(() => model.Score)"
                  Label="Satisfaction score"
                  Required="true"
                  Clearable="true"
                  ShowValue="true" />
    </W3Field>
    <W3Button Type="submit" Color="W3Color.Teal" TextColor="W3Color.White">Validate</W3Button>
</EditForm>

@code {
    private readonly RequiredRatingExampleModel model = new();

    private void HandleSubmit()
    {
    }

    private sealed class RequiredRatingExampleModel
    {
        [Range(1, 5, ErrorMessage = "Choose a satisfaction score.")]
        public int Score { get; set; }
    }
}
""";

    private sealed class RequiredRatingExampleModel
    {
        [Range(1, 5, ErrorMessage = "Choose a satisfaction score.")]
        public int Score { get; set; }
    }

    private void HandleRequiredSubmit()
    {
    }
}
