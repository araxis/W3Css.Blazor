@page "/components/select"

<PageTitle>W3Select</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Select</h1>
    <DocPager PreviousHref="components/autocomplete" PreviousText="Autocomplete" NextHref="components/select-item" NextText="Select Item" />

    <p class="w3-large">`W3Select` renders a generic Blazor select control with the W3.CSS `w3-select` class.</p>
    <p>Use `TValue` to match the bound value type, and set `Placeholder` when an empty first option should guide required selections.</p>

    <DocExample Title="Basic Select" Code="@BasicCode">
        <EditForm Model="@SelectModel">
            <W3Field TValue="string" Label="Size" ForId="select-size" For="@(() => SelectModel.Size)">
                <W3Select TValue="string" Id="select-size" @bind-Value="SelectModel.Size" Placeholder="Choose a size" Border="true">
                    <W3SelectItem TValue="string" Value="@("small")">Small</W3SelectItem>
                    <W3SelectItem TValue="string" Value="@("medium")">Medium</W3SelectItem>
                    <W3SelectItem TValue="string" Value="@("large")">Large</W3SelectItem>
                </W3Select>
            </W3Field>
        </EditForm>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>TValue</td><td>type</td><td>required</td><td>Bound value type</td></tr>
                <tr><td>Value</td><td>TValue</td><td>default</td><td>Blazor input value</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;TValue&gt;</td><td>none</td><td>Raised when the selected value changes</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;TValue&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Placeholder</td><td>string?</td><td>null</td><td>Empty first option label</td></tr>
                <tr><td>PlaceholderDisabled</td><td>bool</td><td>true</td><td>Controls whether the placeholder option is disabled</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>`W3SelectItem` elements</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional CSS classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the select element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/autocomplete" PreviousText="Autocomplete" NextHref="components/select-item" NextText="Select Item" />
</W3Container>

@code {
    private readonly SelectExampleModel SelectModel = new();

    private const string BasicCode = """
<W3Select TValue="string" @bind-Value="model.Size" Placeholder="Choose a size" Border="true">
    <W3SelectItem TValue="string" Value="@("small")">Small</W3SelectItem>
    <W3SelectItem TValue="string" Value="@("medium")">Medium</W3SelectItem>
    <W3SelectItem TValue="string" Value="@("large")">Large</W3SelectItem>
</W3Select>
""";

    private sealed class SelectExampleModel
    {
        public string Size { get; set; } = string.Empty;
    }

}
