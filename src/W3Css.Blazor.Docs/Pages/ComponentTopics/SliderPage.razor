@page "/components/slider"

<PageTitle>W3Slider</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Slider</h1>
    <DocPager PreviousHref="components/time-input" PreviousText="Time Input" NextHref="components/rating" NextText="Rating" />

    <p class="w3-large"><code>W3Slider&lt;TValue&gt;</code> renders a native range input with W3.CSS form styling and Blazor validation.</p>
    <p>Use it for filters, volume controls, sizing settings, and other bounded numeric values where dragging is faster than typing.</p>

    <DocExample Title="Range Setting" Description="Range inputs update on input by default so nearby preview text stays live while the thumb moves." Code="@RangeCode">
        <EditForm Model="@SliderModel">
            <W3Field TValue="int" Label="Volume" ForId="slider-volume" For="@(() => SliderModel.Volume)" HelpText="Drag between 0 and 100 percent.">
                <W3Slider TValue="int"
                          Id="slider-volume"
                          @bind-Value="SliderModel.Volume"
                          Label="Volume"
                          ValueText="@($"{SliderModel.Volume} percent")"
                          Min="0"
                          Max="100"
                          Step="5"
                          Border="true" />
            </W3Field>
            <p class="w3-small">Current volume: <strong>@SliderModel.Volume%</strong></p>
        </EditForm>
    </DocExample>

    <DocExample Title="Decimal Filter" Description="Decimal steps work well for dashboard filters and design controls." Code="@DecimalCode">
        <W3Panel Color="W3Color.White" Border="true" Round="W3Round.Medium" Class="w3-padding">
            <W3Slider TValue="decimal"
                      @bind-Value="SliderModel.Risk"
                      Min="0"
                      Max="1"
                      Step="0.05"
                      Color="W3Color.White" />
            <p class="w3-small w3-margin-top">Risk threshold: <strong>@SliderModel.Risk.ToString("0.00")</strong></p>
        </W3Panel>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>TValue</td><td>numeric type</td><td>required</td><td>Bound range value type</td></tr>
                <tr><td>Value</td><td>TValue</td><td>default</td><td>Blazor input value</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;TValue&gt;</td><td>none</td><td>Raised when the slider value changes</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;TValue&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Label</td><td>string?</td><td>null</td><td>`aria-label` when no visible field label is available</td></tr>
                <tr><td>ValueText</td><td>string?</td><td>null</td><td>`aria-valuetext` for friendly spoken values</td></tr>
                <tr><td>Min</td><td>TValue</td><td>default</td><td>`min` attribute</td></tr>
                <tr><td>Max</td><td>TValue</td><td>default</td><td>`max` attribute</td></tr>
                <tr><td>Step</td><td>string?</td><td>null</td><td>`step` attribute</td></tr>
                <tr><td>UpdateOnInput</td><td>bool</td><td>true</td><td>Updates while dragging instead of waiting for `change`</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional CSS classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the range input</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Related</h2>
        <p><NavLink href="components/number-input">Number Input</NavLink> covers typed numeric entry.</p>
        <p><NavLink href="components/field">Field</NavLink> wraps labels, help text, and validation messages.</p>
        <p><NavLink href="components/switch">Switch</NavLink> covers boolean settings.</p>
    </section>

    <DocPager PreviousHref="components/time-input" PreviousText="Time Input" NextHref="components/rating" NextText="Rating" />
</W3Container>

@code {
    private readonly SliderExampleModel SliderModel = new();

    private const string RangeCode = """
<W3Field TValue="int" Label="Volume" ForId="slider-volume" For="@(() => model.Volume)" HelpText="Drag between 0 and 100 percent.">
    <W3Slider TValue="int"
              Id="slider-volume"
              @bind-Value="model.Volume"
              Label="Volume"
              ValueText="@($"{model.Volume} percent")"
              Min="0"
              Max="100"
              Step="5"
              Border="true" />
</W3Field>
<p>Current volume: <strong>@model.Volume%</strong></p>
""";

    private const string DecimalCode = """
<W3Slider TValue="decimal"
          @bind-Value="model.Risk"
          Min="0"
          Max="1"
          Step="0.05"
          Color="W3Color.White" />
""";

    private sealed class SliderExampleModel
    {
        public int Volume { get; set; } = 45;
        public decimal Risk { get; set; } = 0.35m;
    }
}
