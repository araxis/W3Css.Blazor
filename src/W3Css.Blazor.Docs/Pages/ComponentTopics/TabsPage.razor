@page "/components/tabs"

<PageTitle>W3Tabs</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Tabs</h1>
    <DocPager PreviousHref="components/validation" PreviousText="Validation" NextHref="components/accordion" NextText="Accordion" />

    <p class="w3-large">`W3Tabs` renders W3.CSS bar buttons and a Blazor-controlled active panel.</p>
    <p>Use `W3TabPanel` children for each tab. Bind `ActiveValue` when the parent needs to control the selected tab.</p>

    <DocExample Title="Basic Tabs" Code="@BasicCode">
        <W3Tabs @bind-ActiveValue="ActiveTab" ActiveColor="W3Color.Teal" ActiveTextColor="W3Color.White">
            <W3TabPanel Value="overview" Title="Overview">
                <p>Lightweight components over W3.CSS classes.</p>
            </W3TabPanel>
            <W3TabPanel Value="install" Title="Install">
                <p>Reference the package and add the stylesheet.</p>
            </W3TabPanel>
            <W3TabPanel Value="disabled" Title="Disabled" Disabled="true">
                <p>This panel cannot be selected.</p>
            </W3TabPanel>
        </W3Tabs>
    </DocExample>

    <DocExample Title="Add And Close Tabs" Code="@DynamicCode">
        <W3Tabs @bind-ActiveValue="DynamicActiveTab"
                ShowAddButton="true"
                Closeable="true"
                AddButtonLabel="Add workspace tab"
                CloseButtonLabel="Close tab"
                OnAddTab="AddWorkspaceTab"
                OnCloseTab="CloseWorkspaceTab"
                ActiveColor="W3Color.Teal"
                ActiveTextColor="W3Color.White">
            @foreach (var tab in DynamicTabs)
            {
                <W3TabPanel Value="@tab.Value" Title="@tab.Title">
                    <p>@tab.Body</p>
                </W3TabPanel>
            }
        </W3Tabs>
        <p class="doc-muted">Open tabs: @(DynamicTabs.Count == 0 ? "none" : string.Join(", ", DynamicTabs.Select(tab => tab.Title)))</p>
        <p class="doc-muted">Last closed: @(LastClosedTab ?? "none")</p>
    </DocExample>

    <section class="doc-section">
        <h2>W3Tabs Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>`W3TabPanel` children</td></tr>
                <tr><td>ActiveValue</td><td>string?</td><td>null</td><td>Selected panel value</td></tr>
                <tr><td>ActiveValueChanged</td><td>EventCallback&lt;string&gt;</td><td>empty</td><td>`@@bind-ActiveValue` change callback</td></tr>
                <tr><td>Border</td><td>bool</td><td>true</td><td>`w3-border` on the tab bar</td></tr>
                <tr><td>PanelBorder</td><td>bool</td><td>true</td><td>`w3-border` on the panel</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Tab bar background</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Tab bar text color</td></tr>
                <tr><td>ActiveColor</td><td>W3Color</td><td>Primary</td><td>Active tab background</td></tr>
                <tr><td>ActiveTextColor</td><td>W3Color</td><td>Black</td><td>Active tab text color</td></tr>
                <tr><td>PanelColor</td><td>W3Color</td><td>Surface</td><td>Panel background</td></tr>
                <tr><td>PanelTextColor</td><td>W3Color</td><td>None</td><td>Panel text color</td></tr>
                <tr><td>ShowAddButton</td><td>bool</td><td>false</td><td>Trailing add button</td></tr>
                <tr><td>ShowCloseButtons</td><td>bool</td><td>true</td><td>Allows close buttons to render</td></tr>
                <tr><td>Closeable</td><td>bool</td><td>false</td><td>Marks every tab closeable</td></tr>
                <tr><td>AddButtonLabel</td><td>string</td><td>Add tab</td><td>Add button accessible label</td></tr>
                <tr><td>CloseButtonLabel</td><td>string</td><td>Close</td><td>Close button accessible label prefix</td></tr>
                <tr><td>OnAddTab</td><td>EventCallback</td><td>empty</td><td>Add button callback</td></tr>
                <tr><td>OnCloseTab</td><td>EventCallback&lt;string&gt;</td><td>empty</td><td>Close button callback with panel value</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional root classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style on the root wrapper</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string, object&gt;?</td><td>null</td><td>Extra root attributes</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>W3TabPanel Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>string</td><td>required</td><td>Tab identity</td></tr>
                <tr><td>Title</td><td>string</td><td>required</td><td>Tab button text</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>Disabled tab button</td></tr>
                <tr><td>Closeable</td><td>bool</td><td>false</td><td>Shows this panel's close button when close buttons are enabled</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Active panel content</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/validation" PreviousText="Validation" NextHref="components/accordion" NextText="Accordion" />
</W3Container>

@code {
    private string ActiveTab { get; set; } = "overview";
    private readonly List<WorkspaceTab> DynamicTabs =
    [
        new("workspace-1", "Workspace 1", "Plan the release checklist."),
        new("workspace-2", "Workspace 2", "Review package consumer notes.")
    ];

    private string DynamicActiveTab { get; set; } = "workspace-1";
    private string? LastClosedTab { get; set; }
    private int nextWorkspaceNumber = 3;

    private const string BasicCode = """
<W3Tabs @bind-ActiveValue="activeTab" ActiveColor="W3Color.Teal" ActiveTextColor="W3Color.White">
    <W3TabPanel Value="overview" Title="Overview">
        <p>Lightweight components over W3.CSS classes.</p>
    </W3TabPanel>
    <W3TabPanel Value="install" Title="Install">
        <p>Reference the package and add the stylesheet.</p>
    </W3TabPanel>
</W3Tabs>
""";

    private const string DynamicCode = """
<W3Tabs @bind-ActiveValue="activeTab"
        ShowAddButton="true"
        Closeable="true"
        AddButtonLabel="Add workspace tab"
        CloseButtonLabel="Close tab"
        OnAddTab="AddWorkspaceTab"
        OnCloseTab="CloseWorkspaceTab">
    @foreach (var tab in tabs)
    {
        <W3TabPanel Value="@tab.Value" Title="@tab.Title">
            <p>@tab.Body</p>
        </W3TabPanel>
    }
</W3Tabs>
""";

    private void AddWorkspaceTab()
    {
        var number = nextWorkspaceNumber++;
        var value = $"workspace-{number}";
        DynamicTabs.Add(new(value, $"Workspace {number}", $"Draft content for workspace {number}."));
        DynamicActiveTab = value;
    }

    private void CloseWorkspaceTab(string value)
    {
        LastClosedTab = value;
        var index = DynamicTabs.FindIndex(tab => string.Equals(tab.Value, value, StringComparison.Ordinal));
        if (index < 0)
        {
            return;
        }

        DynamicTabs.RemoveAt(index);

        if (string.Equals(DynamicActiveTab, value, StringComparison.Ordinal))
        {
            DynamicActiveTab = DynamicTabs.FirstOrDefault()?.Value ?? string.Empty;
        }
    }

    private sealed record WorkspaceTab(string Value, string Title, string Body);
}
