@page "/components/tag"

<PageTitle>W3Tag</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3Tag</h1>
    <DocPager PreviousHref="components/badge" PreviousText="Badge" NextHref="components/chip" NextText="Chip" />

    <p class="w3-large">`W3Tag` renders inline label content with the W3.CSS `w3-tag` class.</p>
    <p>Use tags for labels, categories, release states, and compact metadata.</p>

    <DocExample Title="Basic Tags" Code="@BasicCode">
        <W3Tag Color="W3Color.Black" TextColor="W3Color.White" Round="W3Round.Medium" Class="w3-margin-right">Stable</W3Tag>
        <W3Tag Color="W3Color.Teal" TextColor="W3Color.White" Round="W3Round.Medium" Class="w3-margin-right">Lightweight</W3Tag>
        <W3Tag Color="W3Color.Amber" TextColor="W3Color.Black" Round="W3Round.Medium">CSS first</W3Tag>
    </DocExample>

    <DocExample Title="Large Tag" Code="@LargeCode">
        <W3Tag Color="W3Color.Cobalt" TextColor="W3Color.White" Size="W3Size.Large" Round="W3Round.Large">W3Css.Blazor</W3Tag>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>ChildContent</td><td>RenderFragment?</td><td>null</td><td>Tag content</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Size</td><td>W3Size</td><td>Default</td><td>Size class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional classes on the tag</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline styles on the tag</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/badge" PreviousText="Badge" NextHref="components/chip" NextText="Chip" />
</W3Container>

@code {
    private const string BasicCode = """
<W3Tag Color="W3Color.Black" TextColor="W3Color.White" Round="W3Round.Medium">Stable</W3Tag>
<W3Tag Color="W3Color.Teal" TextColor="W3Color.White" Round="W3Round.Medium">Lightweight</W3Tag>
<W3Tag Color="W3Color.Amber" TextColor="W3Color.Black" Round="W3Round.Medium">CSS first</W3Tag>
""";

    private const string LargeCode = """
<W3Tag Color="W3Color.Cobalt" TextColor="W3Color.White" Size="W3Size.Large" Round="W3Round.Large">
    W3Css.Blazor
</W3Tag>
""";
}
