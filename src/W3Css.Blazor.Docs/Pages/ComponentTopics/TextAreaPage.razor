@page "/components/text-area"

<PageTitle>W3TextArea</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>W3TextArea</h1>
    <DocPager PreviousHref="components/radio" PreviousText="Radio" NextHref="components/field" NextText="Field" />

    <p class="w3-large">`W3TextArea` renders a Blazor text area with the W3.CSS `w3-input` class.</p>
    <p>Use it for multi-line text while keeping Blazor validation and binding behavior.</p>

    <DocExample Title="Message Field" Code="@BasicCode">
        <EditForm Model="@TextAreaModel">
            <W3Field TValue="string" Label="Message" ForId="message" For="@(() => TextAreaModel.Message)">
                <W3TextArea Id="message" @bind-Value="TextAreaModel.Message" Rows="4" Placeholder="Write a short message" Border="true" />
            </W3Field>
        </EditForm>
    </DocExample>

    <section class="doc-section">
        <h2>Parameters</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Name</th><th>Type</th><th>Default</th><th>Maps to</th></tr>
            </thead>
            <tbody>
                <tr><td>Value</td><td>string?</td><td>null</td><td>Blazor input value</td></tr>
                <tr><td>ValueChanged</td><td>EventCallback&lt;string?&gt;</td><td>none</td><td>Raised when the bound value changes</td></tr>
                <tr><td>ValueExpression</td><td>Expression&lt;Func&lt;string?&gt;&gt;?</td><td>null</td><td>Validation expression for EditForm scenarios</td></tr>
                <tr><td>Id</td><td>string?</td><td>null</td><td>`id` attribute</td></tr>
                <tr><td>Rows</td><td>int?</td><td>null</td><td>Rows attribute</td></tr>
                <tr><td>Placeholder</td><td>string?</td><td>null</td><td>Placeholder attribute</td></tr>
                <tr><td>ReadOnly</td><td>bool</td><td>false</td><td>`readonly` attribute</td></tr>
                <tr><td>Disabled</td><td>bool</td><td>false</td><td>`disabled` attribute</td></tr>
                <tr><td>Border</td><td>bool</td><td>false</td><td>`w3-border`</td></tr>
                <tr><td>Color</td><td>W3Color</td><td>None</td><td>Background color class</td></tr>
                <tr><td>TextColor</td><td>W3Color</td><td>None</td><td>Text color class</td></tr>
                <tr><td>Round</td><td>W3Round</td><td>None</td><td>Rounded corner class</td></tr>
                <tr><td>Class</td><td>string?</td><td>null</td><td>Additional CSS classes</td></tr>
                <tr><td>Style</td><td>string?</td><td>null</td><td>Inline style</td></tr>
                <tr><td>AdditionalAttributes</td><td>IReadOnlyDictionary&lt;string,object&gt;?</td><td>null</td><td>Extra attributes on the textarea element</td></tr>
            </tbody>
        </W3Table>
    </section>

    <DocPager PreviousHref="components/radio" PreviousText="Radio" NextHref="components/field" NextText="Field" />
</W3Container>

@code {
    private readonly TextAreaExampleModel TextAreaModel = new();

    private const string BasicCode = """
<W3Field TValue="string" Label="Message" ForId="message" For="@(() => model.Message)">
    <W3TextArea Id="message" @bind-Value="model.Message" Rows="4" Placeholder="Write a short message" Border="true" />
</W3Field>
""";

    private sealed class TextAreaExampleModel
    {
        public string Message { get; set; } = string.Empty;
    }
}
