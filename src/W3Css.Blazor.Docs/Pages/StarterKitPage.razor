@page "/starter-kit"

<PageTitle>Starter Kit</PageTitle>

<W3Container Class="w3-padding-32">
    <h1>Starter Kit</h1>
    <DocPager PreviousHref="installation" PreviousText="Installation" NextHref="patterns" NextText="Patterns" />

    <p class="w3-large">The starter kit is a small Blazor WebAssembly app in the repository that shows the package primitives working together in a realistic first screen.</p>
    <p>Use it when you want a copyable baseline for app shell layout, settings forms, searchable data, modal workflows, and toast feedback before building your own screens.</p>

    <section class="doc-section">
        <h2>Run The Sample</h2>
        <pre><code>dotnet restore W3Css.Blazor.slnx
dotnet run --project samples/W3Css.Blazor.StarterKit</code></pre>
        <W3Alert Kind="W3AlertKind.Note" Round="W3Round.Medium">
            The sample references the local library project so changes to the package are visible immediately while developing.
        </W3Alert>
    </section>

    <section class="doc-section">
        <h2>Included Routes</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Route</th><th>What it demonstrates</th></tr>
            </thead>
            <tbody>
                <tr><td><code>/</code></td><td>Dashboard shell, app bar, Light/Dark/Auto theme modes, sidebar, metric cards, table actions, empty state, and toast feedback.</td></tr>
                <tr><td><code>/settings</code></td><td>Validated settings form with field help, validation summary, select input, busy state, and wrapping actions.</td></tr>
                <tr><td><code>/customers</code></td><td>Searchable customer data table with error and empty states plus compact row actions.</td></tr>
                <tr><td><code>/workflow</code></td><td>Modal editing flow, message-box confirmation, and consistent dialog action spacing.</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Expected Files</h2>
        <W3Table Striped="true" Bordered="true" Responsive="true" Class="doc-reference-table">
            <thead>
                <tr><th>Area</th><th>Purpose</th></tr>
            </thead>
            <tbody>
                <tr><td><code>samples/W3Css.Blazor.StarterKit</code></td><td>Standalone sample app using <code>net10.0</code> and a local project reference.</td></tr>
                <tr><td><code>Layout/MainLayout.razor</code></td><td>Shared app shell, app bar, sidebar navigation, theme provider, theme mode switch, and toast provider.</td></tr>
                <tr><td><code>Services/StarterWorkspace.cs</code></td><td>Small scoped state object for demo data, settings, table state, and workflow state.</td></tr>
                <tr><td><code>wwwroot/css/app.css</code></td><td>Sample-only layout polish; package styling still comes from <code>w3css-blazor.css</code>.</td></tr>
            </tbody>
        </W3Table>
    </section>

    <section class="doc-section">
        <h2>Starter Markup</h2>
        <p>The layout starts with one bundled stylesheet and the W3Css.Blazor services:</p>
        <pre><code>@StylesheetCode</code></pre>
        <pre><code>@ServiceCode</code></pre>
    </section>

    <section class="doc-section">
        <h2>Related Guidance</h2>
        <div class="w3-bar w3-border w3-white">
            <NavLink class="w3-bar-item w3-button" href="installation">Installation</NavLink>
            <NavLink class="w3-bar-item w3-button" href="patterns">Patterns</NavLink>
            <NavLink class="w3-bar-item w3-button" href="components/theming">Theming</NavLink>
            <NavLink class="w3-bar-item w3-button" href="components/versions">Versions</NavLink>
        </div>
    </section>

    <DocPager PreviousHref="installation" PreviousText="Installation" NextHref="patterns" NextText="Patterns" />
</W3Container>

@code {
    private const string StylesheetCode = """
<link rel="stylesheet" href="_content/W3Css.Blazor/w3css-blazor.css" />
""";

    private const string ServiceCode = """
builder.Services.AddW3CssBlazor();
builder.Services.AddScoped<StarterWorkspace>();
""";
}
