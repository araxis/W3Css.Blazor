@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@Style">
    <button type="button"
            class="@ButtonCssClass"
            aria-expanded="@AriaExpanded"
            disabled="@Disabled"
            @onclick="ToggleAsync">
        @Title
    </button>

    @if (Expanded)
    {
        <div class="@ContentCssClass">
            @ChildContent
        </div>
    }
</div>

@code {
    private string CssClass => BuildClass("w3-section");

    private string ButtonCssClass => new W3ClassBuilder()
        .Add("w3-button")
        .Add("w3-block")
        .Add("w3-left-align")
        .Add(ButtonColor.ToBackgroundClass())
        .Add(ButtonTextColor.ToTextClass())
        .AddIf(Disabled, "w3-disabled")
        .ToString();

    private string ContentCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .AddIf(Border, "w3-border")
        .Add(ContentColor.ToBackgroundClass())
        .Add(ContentTextColor.ToTextClass())
        .ToString();

    private string AriaExpanded => Expanded ? "true" : "false";

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public bool Expanded { get; set; }

    [Parameter]
    public EventCallback<bool> ExpandedChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Border { get; set; } = true;

    [Parameter]
    public W3Color ButtonColor { get; set; } = W3Color.LightGrey;

    [Parameter]
    public W3Color ButtonTextColor { get; set; } = W3Color.Black;

    [Parameter]
    public W3Color ContentColor { get; set; } = W3Color.Surface;

    [Parameter]
    public W3Color ContentTextColor { get; set; } = W3Color.None;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private async Task ToggleAsync()
    {
        if (Disabled)
        {
            return;
        }

        Expanded = !Expanded;
        await ExpandedChanged.InvokeAsync(Expanded);
    }
}
