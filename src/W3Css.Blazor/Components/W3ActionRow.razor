@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@StyleValue"
     role="@Role"
     aria-label="@AriaLabel"
     aria-labelledby="@AriaLabelledBy">
    @ChildContent
</div>

@code {
    private string CssClass => BuildClass(
        "w3-action-row",
        Wrap ? "w3-action-row-wrap" : null,
        JustifyStart ? "w3-action-row-start" : null,
        JustifyCenter ? "w3-action-row-center" : null,
        JustifyBetween ? "w3-action-row-between" : null,
        !JustifyStart && !JustifyCenter && !JustifyBetween ? "w3-action-row-end" : null,
        Border ? "w3-border" : null,
        Round.ToClass(),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string? StyleValue => CombineStyle(Gap >= 0 ? $"--w3-action-row-gap:{Gap}px" : null, Style);

    private string? AriaLabel => string.IsNullOrWhiteSpace(AriaLabelledBy) ? Label : null;

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Accessible label applied to the action group when <see cref="AriaLabelledBy"/> is not set.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Actions";

    /// <summary>
    /// Gets or sets the AriaLabelledBy attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabelledBy { get; set; }

    /// <summary>
    /// Gets or sets the role value.
    /// </summary>
    [Parameter]
    public string Role { get; set; } = "group";

    /// <summary>
    /// Gets or sets the wrap value.
    /// </summary>
    [Parameter]
    public bool Wrap { get; set; } = true;

    /// <summary>
    /// Gets or sets the justify start value.
    /// </summary>
    [Parameter]
    public bool JustifyStart { get; set; }

    /// <summary>
    /// Gets or sets the justify center value.
    /// </summary>
    [Parameter]
    public bool JustifyCenter { get; set; }

    /// <summary>
    /// Gets or sets the justify between value.
    /// </summary>
    [Parameter]
    public bool JustifyBetween { get; set; }

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    /// <summary>
    /// Gets or sets the gap value.
    /// </summary>
    [Parameter]
    public int Gap { get; set; } = 8;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
