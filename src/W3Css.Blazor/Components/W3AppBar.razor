@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<header @attributes="AdditionalAttributes"
        class="@CssClass"
        style="@Style">
    @if (ShowMenuButton || Leading is not null)
    {
        <div class="@LeadingCssClass">
            @if (ShowMenuButton)
            {
                <button type="button"
                        class="@MenuButtonCssClass"
                        aria-label="@MenuButtonAriaLabel"
                        aria-expanded="@MenuExpandedValue"
                        aria-controls="@MenuControls"
                        @onclick="OnMenuClick">
                    @if (!string.IsNullOrWhiteSpace(MenuIconClass))
                    {
                        <span class="@MenuIconClass" aria-hidden="true"></span>
                    }

                    @if (MenuButtonContent is not null)
                    {
                        @MenuButtonContent
                    }
                    else if (!MenuIconOnly && !string.IsNullOrWhiteSpace(MenuText))
                    {
                        <span>@MenuText</span>
                    }
                </button>
            }

            @Leading
        </div>
    }

    @if (HasTitle)
    {
        <div class="@TitleCssClass">
            @if (!string.IsNullOrWhiteSpace(TitleHref))
            {
                <a href="@TitleHref"
                   target="@TitleTarget"
                   class="w3-app-bar-title-link">
                    @TitleBody
                </a>
            }
            else
            {
                <div class="w3-app-bar-title-text">
                    @TitleBody
                </div>
            }

            @if (SubtitleContent is not null || !string.IsNullOrWhiteSpace(Subtitle))
            {
                <div class="w3-app-bar-subtitle">
                    @if (SubtitleContent is not null)
                    {
                        @SubtitleContent
                    }
                    else
                    {
                        @Subtitle
                    }
                </div>
            }
        </div>
    }

    @if (ChildContent is not null)
    {
        <nav class="@NavCssClass" aria-label="@NavigationLabel">
            @ChildContent
        </nav>
    }

    @if (Actions is not null)
    {
        <div class="@ActionsCssClass">
            @Actions
        </div>
    }
</header>

@code {
    private bool HasTitle =>
        TitleContent is not null ||
        !string.IsNullOrWhiteSpace(Title) ||
        SubtitleContent is not null ||
        !string.IsNullOrWhiteSpace(Subtitle);

    private RenderFragment TitleBody => builder =>
    {
        if (TitleContent is not null)
        {
            builder.AddContent(0, TitleContent);
        }
        else
        {
            builder.AddContent(1, Title);
        }
    };

    private string CssClass => BuildClass(
        "w3-bar",
        "w3-app-bar",
        ShowMenuButton || Leading is not null ? "w3-app-bar-has-leading" : null,
        HasTitle ? "w3-app-bar-has-title" : null,
        ChildContent is not null ? "w3-app-bar-has-nav" : null,
        Actions is not null ? "w3-app-bar-has-actions" : null,
        Dense ? "w3-app-bar-dense" : null,
        Prominent ? "w3-app-bar-prominent" : null,
        Mobile ? "w3-app-bar-mobile" : null,
        Border ? "w3-border" : null,
        Card ? CardDepth.ToClass() : null,
        Round.ToClass(),
        PositionCssClass,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string LeadingCssClass => BuildSlotClass("w3-app-bar-leading", LeadingClass);

    private string TitleCssClass => BuildSlotClass(
        "w3-bar-item",
        "w3-app-bar-title",
        SubtitleContent is null && string.IsNullOrWhiteSpace(Subtitle) ? "w3-app-bar-title-single" : null,
        TitleClass);

    private string NavCssClass => BuildSlotClass("w3-app-bar-nav", NavClass);

    private string ActionsCssClass => BuildSlotClass("w3-app-bar-actions", ActionsClass);

    private string MenuButtonCssClass => BuildSlotClass(
        "w3-button",
        "w3-bar-item",
        "w3-app-bar-menu-button",
        MenuButtonClass);

    private string? PositionCssClass => Position switch
    {
        W3AppBarPosition.Top => "w3-top",
        W3AppBarPosition.Bottom => "w3-bottom",
        W3AppBarPosition.Sticky => "w3-app-bar-sticky",
        _ => null
    };

    private string? MenuExpandedValue => MenuExpanded?.ToString().ToLowerInvariant();

    /// <summary>
    /// Gets or sets the leading value.
    /// </summary>
    [Parameter]
    public RenderFragment? Leading { get; set; }

    /// <summary>
    /// Gets or sets the title content value.
    /// </summary>
    [Parameter]
    public RenderFragment? TitleContent { get; set; }

    /// <summary>
    /// Gets or sets the subtitle content value.
    /// </summary>
    [Parameter]
    public RenderFragment? SubtitleContent { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the actions value.
    /// </summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }

    /// <summary>
    /// Gets or sets the menu button content value.
    /// </summary>
    [Parameter]
    public RenderFragment? MenuButtonContent { get; set; }

    /// <summary>
    /// Text title rendered in the app bar when <see cref="TitleContent"/> is not supplied.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the subtitle value.
    /// </summary>
    [Parameter]
    public string? Subtitle { get; set; }

    /// <summary>
    /// Gets or sets the title href value.
    /// </summary>
    [Parameter]
    public string? TitleHref { get; set; }

    /// <summary>
    /// Gets or sets the title target value.
    /// </summary>
    [Parameter]
    public string? TitleTarget { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string NavigationLabel { get; set; } = "App bar navigation";

    /// <summary>
    /// Gets or sets the show menu button value.
    /// </summary>
    [Parameter]
    public bool ShowMenuButton { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string MenuButtonAriaLabel { get; set; } = "Toggle navigation";

    /// <summary>
    /// Gets or sets the menu text value.
    /// </summary>
    [Parameter]
    public string MenuText { get; set; } = "Menu";

    /// <summary>
    /// Gets or sets the menu icon class value.
    /// </summary>
    [Parameter]
    public string? MenuIconClass { get; set; } = "fa fa-bars";

    /// <summary>
    /// Gets or sets the menu icon only value.
    /// </summary>
    [Parameter]
    public bool MenuIconOnly { get; set; }

    /// <summary>
    /// Gets or sets the menu expanded value.
    /// </summary>
    [Parameter]
    public bool? MenuExpanded { get; set; }

    /// <summary>
    /// Gets or sets the menu controls value.
    /// </summary>
    [Parameter]
    public string? MenuControls { get; set; }

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnMenuClick { get; set; }

    /// <summary>
    /// Gets or sets the mobile value.
    /// </summary>
    [Parameter]
    public bool Mobile { get; set; }

    /// <summary>
    /// Gets or sets the dense value.
    /// </summary>
    [Parameter]
    public bool Dense { get; set; }

    /// <summary>
    /// Gets or sets the prominent value.
    /// </summary>
    [Parameter]
    public bool Prominent { get; set; }

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; }

    /// <summary>
    /// Gets or sets the card depth value.
    /// </summary>
    [Parameter]
    public W3CardDepth CardDepth { get; set; } = W3CardDepth.Four;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    /// <summary>
    /// Gets or sets the position value.
    /// </summary>
    [Parameter]
    public W3AppBarPosition Position { get; set; } = W3AppBarPosition.Static;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the leading class value.
    /// </summary>
    [Parameter]
    public string? LeadingClass { get; set; }

    /// <summary>
    /// Gets or sets the title class value.
    /// </summary>
    [Parameter]
    public string? TitleClass { get; set; }

    /// <summary>
    /// Gets or sets the nav class value.
    /// </summary>
    [Parameter]
    public string? NavClass { get; set; }

    /// <summary>
    /// Gets or sets the actions class value.
    /// </summary>
    [Parameter]
    public string? ActionsClass { get; set; }

    /// <summary>
    /// Gets or sets the menu button class value.
    /// </summary>
    [Parameter]
    public string? MenuButtonClass { get; set; }

    private static string BuildSlotClass(params string?[] classes)
    {
        var builder = new W3ClassBuilder();

        foreach (var cssClass in classes)
        {
            builder.Add(cssClass);
        }

        return builder.ToString();
    }
}
