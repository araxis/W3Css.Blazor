@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@RootCssClass"
     style="@RootStyle">
    @if (Header is not null)
    {
        <header class="@HeaderCssClass" style="@HeaderStyleValue">
            @Header
        </header>
    }

    <div class="@BodyCssClass" style="@BodyStyle">
        @if (Sidebar is not null)
        {
            @if (SidebarOverlay && SidebarOpen)
            {
                <div class="@OverlayCssClass"
                     style="@OverlayStyleValue"
                     aria-hidden="true"
                     @onclick="CloseSidebarAsync"></div>
            }

            <aside class="@SidebarCssClass"
                   style="@SidebarStyleValue"
                   aria-label="@SidebarLabel"
                   aria-hidden="@SidebarAriaHidden">
                @Sidebar
            </aside>
        }

        <main id="@MainId"
              class="@MainCssClass"
              style="@MainStyleValue">
            @ChildContent
        </main>
    </div>

    @if (Footer is not null)
    {
        <footer class="@FooterCssClass" style="@FooterStyleValue">
            @Footer
        </footer>
    }
</div>

@code {
    private int EffectiveSidebarWidth => SidebarWidth <= 0 ? 200 : SidebarWidth;

    private string RootCssClass => BuildClass(
        "w3-app-shell",
        Sidebar is not null ? "w3-app-shell-has-sidebar" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string? RootStyle => CombineStyle(Contained ? "position:relative;overflow:hidden" : null, Style);

    private string HeaderCssClass => BuildSlotClass(
        "w3-app-shell-header",
        HeaderColor.ToBackgroundClass(),
        HeaderTextColor.ToTextClass(),
        HeaderClass);

    private string BodyCssClass => BuildSlotClass("w3-app-shell-body", BodyClass);

    private string SidebarCssClass => BuildSlotClass(
        "w3-sidebar",
        SidebarOpen ? "w3-show" : "w3-hide",
        SidebarCollapse ? "w3-collapse" : null,
        SidebarAnimate ? SidebarAnimationClass : null,
        SidebarColor.ToBackgroundClass(),
        SidebarTextColor.ToTextClass(),
        SidebarClass);

    private string OverlayCssClass => BuildSlotClass(
        "w3-overlay",
        "w3-show",
        "w3-app-shell-overlay",
        OverlayClass);

    private string MainCssClass => BuildSlotClass(
        "w3-main",
        "w3-app-shell-main",
        MainPadded ? "w3-container" : null,
        MainClass);

    private string FooterCssClass => BuildSlotClass(
        "w3-app-shell-footer",
        FooterColor.ToBackgroundClass(),
        FooterTextColor.ToTextClass(),
        FooterClass);

    private string SidebarAnimationClass => SidebarPosition == W3SidebarPosition.Right
        ? "w3-animate-right"
        : "w3-animate-left";

    private string SidebarPositionStyle => SidebarPosition == W3SidebarPosition.Right ? "right:0" : "left:0";

    private string? SidebarStyleValue => CombineStyle(
        $"width:{EffectiveSidebarWidth}px",
        SidebarPositionStyle,
        "z-index:3",
        Contained ? "position:absolute!important;height:100%" : null,
        SidebarOpen ? null : "display:none!important",
        SidebarStyle);

    private string? OverlayStyleValue => CombineStyle(
        Contained ? "position:absolute!important" : null,
        OverlayStyle);

    private string? MainStyleValue => CombineStyle(MainOffsetStyle, MainStyle);

    private string? MainOffsetStyle
    {
        get
        {
            if (Sidebar is null || !SidebarOpen)
            {
                return null;
            }

            return SidebarPosition == W3SidebarPosition.Right
                ? $"margin-right:{EffectiveSidebarWidth}px"
                : $"margin-left:{EffectiveSidebarWidth}px";
        }
    }

    private string? HeaderStyleValue => CombineStyle(HeaderStyle);

    private string? FooterStyleValue => CombineStyle(FooterStyle);

    private string SidebarAriaHidden => SidebarOpen ? "false" : "true";

    /// <summary>
    /// Content rendered in the shell header region.
    /// </summary>
    [Parameter]
    public RenderFragment? Header { get; set; }

    /// <summary>
    /// Gets or sets the sidebar value.
    /// </summary>
    [Parameter]
    public RenderFragment? Sidebar { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the footer value.
    /// </summary>
    [Parameter]
    public RenderFragment? Footer { get; set; }

    /// <summary>
    /// Controls whether the sidebar is visible.
    /// </summary>
    [Parameter]
    public bool SidebarOpen { get; set; } = true;

    /// <summary>
    /// Gets or sets the callback raised when the sidebar open value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> SidebarOpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the sidebar overlay value.
    /// </summary>
    [Parameter]
    public bool SidebarOverlay { get; set; }

    /// <summary>
    /// Gets or sets the sidebar collapse value.
    /// </summary>
    [Parameter]
    public bool SidebarCollapse { get; set; } = true;

    /// <summary>
    /// Gets or sets the sidebar animate value.
    /// </summary>
    [Parameter]
    public bool SidebarAnimate { get; set; } = true;

    /// <summary>
    /// Sidebar width in pixels. Values less than or equal to zero fall back to the default width.
    /// </summary>
    [Parameter]
    public int SidebarWidth { get; set; } = 260;

    /// <summary>
    /// Gets or sets the sidebar position value.
    /// </summary>
    [Parameter]
    public W3SidebarPosition SidebarPosition { get; set; } = W3SidebarPosition.Left;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string SidebarLabel { get; set; } = "Sidebar";

    /// <summary>
    /// Gets or sets the main id value.
    /// </summary>
    [Parameter]
    public string MainId { get; set; } = "main";

    /// <summary>
    /// Gets or sets the main padded value.
    /// </summary>
    [Parameter]
    public bool MainPadded { get; set; } = true;

    /// <summary>
    /// Gets or sets the contained value.
    /// </summary>
    [Parameter]
    public bool Contained { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the header color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the header text color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the sidebar color value.
    /// </summary>
    [Parameter]
    public W3Color SidebarColor { get; set; } = W3Color.White;

    /// <summary>
    /// Gets or sets the sidebar text color value.
    /// </summary>
    [Parameter]
    public W3Color SidebarTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the footer color value.
    /// </summary>
    [Parameter]
    public W3Color FooterColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the footer text color value.
    /// </summary>
    [Parameter]
    public W3Color FooterTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the header class value.
    /// </summary>
    [Parameter]
    public string? HeaderClass { get; set; }

    /// <summary>
    /// Gets or sets the body class value.
    /// </summary>
    [Parameter]
    public string? BodyClass { get; set; }

    /// <summary>
    /// Gets or sets the sidebar class value.
    /// </summary>
    [Parameter]
    public string? SidebarClass { get; set; }

    /// <summary>
    /// Gets or sets the overlay class value.
    /// </summary>
    [Parameter]
    public string? OverlayClass { get; set; }

    /// <summary>
    /// Gets or sets the main class value.
    /// </summary>
    [Parameter]
    public string? MainClass { get; set; }

    /// <summary>
    /// Gets or sets the footer class value.
    /// </summary>
    [Parameter]
    public string? FooterClass { get; set; }

    /// <summary>
    /// Gets or sets the header style value.
    /// </summary>
    [Parameter]
    public string? HeaderStyle { get; set; }

    /// <summary>
    /// Gets or sets the body style value.
    /// </summary>
    [Parameter]
    public string? BodyStyle { get; set; }

    /// <summary>
    /// Gets or sets the sidebar style value.
    /// </summary>
    [Parameter]
    public string? SidebarStyle { get; set; }

    /// <summary>
    /// Gets or sets the overlay style value.
    /// </summary>
    [Parameter]
    public string? OverlayStyle { get; set; }

    /// <summary>
    /// Gets or sets the main style value.
    /// </summary>
    [Parameter]
    public string? MainStyle { get; set; }

    /// <summary>
    /// Gets or sets the footer style value.
    /// </summary>
    [Parameter]
    public string? FooterStyle { get; set; }

    private async Task CloseSidebarAsync()
    {
        if (!SidebarOpen)
        {
            return;
        }

        SidebarOpen = false;
        await SidebarOpenChanged.InvokeAsync(false);
    }

    private static string BuildSlotClass(params string?[] classes)
    {
        var builder = new W3ClassBuilder();

        foreach (var cssClass in classes)
        {
            builder.Add(cssClass);
        }

        return builder.ToString();
    }

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
