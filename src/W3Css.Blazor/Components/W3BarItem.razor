@using W3Css.Blazor.Internal
@inherits W3ComponentBase

@if (!string.IsNullOrWhiteSpace(Href))
{
    <a @attributes="AdditionalAttributes"
       href="@ResolvedHref"
       target="@Target"
       aria-disabled="@AriaDisabled"
       class="@CssClass"
       style="@Style"
       @onclick="OnClick">
        @ChildContent
    </a>
}
else
{
    @if (Button)
    {
        <button @attributes="AdditionalAttributes"
                type="@Type"
                disabled="@Disabled"
                class="@CssClass"
                style="@Style"
                @onclick="OnClick">
            @ChildContent
        </button>
    }
    else
    {
        <span @attributes="AdditionalAttributes"
              aria-disabled="@AriaDisabled"
              class="@CssClass"
              style="@Style">
            @ChildContent
        </span>
    }
}

@code {
    private string? AriaDisabled => Disabled ? "true" : null;
    private string? ResolvedHref => Disabled ? null : Href;

    private string CssClass => BuildClass(
        "w3-bar-item",
        Button ? "w3-button" : null,
        Mobile ? "w3-mobile" : null,
        Disabled ? "w3-disabled" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public bool Button { get; set; } = true;

    [Parameter]
    public bool Mobile { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Type { get; set; } = "button";

    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }
}
