@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@Style">
    @ChildContent
</div>

@code {
    private string CssClass => BuildClass(
        Border.ToClass(),
        Bar.ToClass(),
        BorderColor.ToBorderClass(),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass(),
        Round.ToClass());

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public W3BorderSide Border { get; set; } = W3BorderSide.All;

    /// <summary>
    /// Gets or sets the bar value.
    /// </summary>
    [Parameter]
    public W3BorderBar Bar { get; set; } = W3BorderBar.None;

    /// <summary>
    /// Gets or sets the border color value.
    /// </summary>
    [Parameter]
    public W3Color BorderColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;
}
