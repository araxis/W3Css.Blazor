@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<CascadingValue Value="this">
    <nav @attributes="AdditionalAttributes"
         class="@CssClass"
         style="@Style"
         aria-label="@Label"
         @onkeydown="HandleKeyDownAsync">
        @ChildContent
    </nav>
</CascadingValue>

@code {
    private readonly List<W3BottomNavigationItem> items = [];

    private string CssClass => BuildClass(
        "w3-bar",
        "w3-bottom-navigation",
        Fixed ? "w3-bottom-navigation-fixed" : null,
        Contained ? "w3-bottom-navigation-contained" : null,
        EqualWidth ? "w3-bottom-navigation-equal" : null,
        Dense ? "w3-bottom-navigation-dense" : null,
        Border ? "w3-border" : null,
        Card ? CardDepth.ToClass() : null,
        Round.ToClass(),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    [Parameter]
    public string Label { get; set; } = "Bottom navigation";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool Fixed { get; set; }

    [Parameter]
    public bool Contained { get; set; }

    [Parameter]
    public bool EqualWidth { get; set; } = true;

    [Parameter]
    public bool Dense { get; set; }

    [Parameter]
    public bool ShowLabels { get; set; } = true;

    [Parameter]
    public bool Border { get; set; }

    [Parameter]
    public bool Card { get; set; }

    [Parameter]
    public W3CardDepth CardDepth { get; set; } = W3CardDepth.Two;

    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    [Parameter]
    public W3Color Color { get; set; } = W3Color.Surface;

    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.Black;

    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.Primary;

    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.White;

    [Parameter]
    public W3Color HoverColor { get; set; } = W3Color.LightGrey;

    [Parameter]
    public W3Color HoverTextColor { get; set; } = W3Color.None;

    internal bool IsActive(string? value)
    {
        return !string.IsNullOrWhiteSpace(value)
            && string.Equals(Value, value, StringComparison.Ordinal);
    }

    internal void Register(W3BottomNavigationItem item)
    {
        if (items.Contains(item))
        {
            return;
        }

        items.Add(item);
        _ = InvokeAsync(StateHasChanged);
    }

    internal void Unregister(W3BottomNavigationItem item)
    {
        if (items.Remove(item))
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    internal async Task SelectAsync(string? value)
    {
        if (string.Equals(Value, value, StringComparison.Ordinal))
        {
            return;
        }

        Value = value;
        await ValueChanged.InvokeAsync(value);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        switch (args.Key)
        {
            case "ArrowRight":
            case "Right":
            case "ArrowDown":
            case "Down":
                await SelectAdjacentAsync(1);
                break;
            case "ArrowLeft":
            case "Left":
            case "ArrowUp":
            case "Up":
                await SelectAdjacentAsync(-1);
                break;
            case "Home":
                await SelectBoundaryAsync(first: true);
                break;
            case "End":
                await SelectBoundaryAsync(first: false);
                break;
        }
    }

    private async Task SelectAdjacentAsync(int offset)
    {
        var selectableItems = GetSelectableItems();

        if (selectableItems.Length == 0)
        {
            return;
        }

        var currentIndex = Array.FindIndex(selectableItems, item => IsActive(item.Value));
        var nextIndex = currentIndex < 0
            ? 0
            : (currentIndex + offset + selectableItems.Length) % selectableItems.Length;

        await SelectAsync(selectableItems[nextIndex].Value);
    }

    private Task SelectBoundaryAsync(bool first)
    {
        var selectableItems = GetSelectableItems();
        var item = first ? selectableItems.FirstOrDefault() : selectableItems.LastOrDefault();

        return item is null ? Task.CompletedTask : SelectAsync(item.Value);
    }

    private W3BottomNavigationItem[] GetSelectableItems()
    {
        return items
            .Where(item => !item.Disabled && !string.IsNullOrWhiteSpace(item.Value))
            .ToArray();
    }
}
