@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<CascadingValue Value="this" IsFixed="true">
    <nav @attributes="AdditionalAttributes"
         class="@CssClass"
         style="@Style"
         aria-label="@Label">
        <ol class="@ListCssClass">
            @ChildContent
        </ol>
    </nav>
</CascadingValue>

@code {
    private string CssClass => BuildClass(
        "w3-breadcrumb",
        Border ? "w3-border" : null,
        Card ? CardDepth.ToClass() : null,
        Round.ToClass(),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string ListCssClass => new W3ClassBuilder()
        .Add("w3-breadcrumb-list")
        .Add("w3-bar")
        .AddIf(Small, "w3-small")
        .Add(ListClass)
        .ToString();

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Breadcrumb";

    /// <summary>
    /// Gets or sets the separator value.
    /// </summary>
    [Parameter]
    public string Separator { get; set; } = "/";

    /// <summary>
    /// Gets or sets the list class value.
    /// </summary>
    [Parameter]
    public string? ListClass { get; set; }

    /// <summary>
    /// Gets or sets the small value.
    /// </summary>
    [Parameter]
    public bool Small { get; set; } = true;

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; }

    /// <summary>
    /// Gets or sets the card depth value.
    /// </summary>
    [Parameter]
    public W3CardDepth CardDepth { get; set; } = W3CardDepth.Two;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;
}
