@typeparam TValue
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<button @attributes="AdditionalAttributes"
        type="button"
        class="@CssClass"
        style="@Style"
        role="option"
        aria-selected="@AriaSelected"
        disabled="@IsDisabled"
        @onclick="SelectAsync">
    @if (!string.IsNullOrWhiteSpace(IconClass))
    {
        <span class="@IconClass" aria-hidden="true"></span>
    }
    <span class="w3-chip-label">@ChildContent</span>
</button>

@code {
    [CascadingParameter]
    internal W3ChipSet<TValue>? Owner { get; set; }

    private bool IsSelected => Owner?.IsSelected(Value) == true || Active;

    private bool IsDisabled => Disabled || Owner?.Disabled == true;

    private string AriaSelected => IsSelected ? "true" : "false";

    private string CssClass => BuildClass(
        "w3-chip",
        "w3-button",
        "w3-tag",
        IsSelected ? "w3-chip-selected" : null,
        IsDisabled ? "w3-disabled" : null,
        EffectiveColor.ToBackgroundClass(),
        EffectiveTextColor.ToTextClass(),
        Size.ToClass(),
        Round.ToClass(),
        Border ? "w3-border" : null);

    private W3Color EffectiveColor => IsSelected
        ? ActiveColor == W3Color.None ? Owner?.ActiveColor ?? W3Color.Teal : ActiveColor
        : Color == W3Color.None ? Owner?.Color ?? W3Color.None : Color;

    private W3Color EffectiveTextColor => IsSelected
        ? ActiveTextColor == W3Color.None ? Owner?.ActiveTextColor ?? W3Color.White : ActiveTextColor
        : TextColor == W3Color.None ? Owner?.TextColor ?? W3Color.None : TextColor;

    [Parameter, EditorRequired]
    public TValue Value { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? IconClass { get; set; }

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Border { get; set; } = true;

    [Parameter]
    public W3Size Size { get; set; } = W3Size.Default;

    [Parameter]
    public W3Round Round { get; set; } = W3Round.XXLarge;

    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.None;

    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.None;

    [Parameter]
    public EventCallback<TValue> OnSelected { get; set; }

    private async Task SelectAsync()
    {
        if (IsDisabled)
        {
            return;
        }

        if (Owner is not null)
        {
            await Owner.ToggleAsync(Value);
        }

        await OnSelected.InvokeAsync(Value);
    }
}
