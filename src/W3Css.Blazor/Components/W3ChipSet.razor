@typeparam TValue
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<CascadingValue Value="this" IsFixed="false">
    <div @attributes="AdditionalAttributes"
         class="@CssClass"
         style="@StyleValue"
         role="listbox"
         aria-label="@Label"
         aria-multiselectable="@AriaMultiSelectable">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private string CssClass => BuildClass(
        "w3-chip-set",
        Wrap ? "w3-chip-set-wrap" : null,
        Disabled ? "w3-disabled" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string? StyleValue => CombineStyle(Gap >= 0 ? $"--w3-chip-set-gap:{Gap}px" : null, Style);

    private string AriaMultiSelectable => MultiSelect ? "true" : "false";

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Chip set";

    /// <summary>
    /// Gets or sets the multi select value.
    /// </summary>
    [Parameter]
    public bool MultiSelect { get; set; }

    /// <summary>
    /// Gets or sets the selected value value.
    /// </summary>
    [Parameter]
    public TValue? SelectedValue { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the selected value value changes.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the selected values value.
    /// </summary>
    [Parameter]
    public IReadOnlyCollection<TValue> SelectedValues { get; set; } = [];

    /// <summary>
    /// Gets or sets the callback raised when the selected values value changes.
    /// </summary>
    [Parameter]
    public EventCallback<IReadOnlyCollection<TValue>> SelectedValuesChanged { get; set; }

    /// <summary>
    /// Gets or sets the wrap value.
    /// </summary>
    [Parameter]
    public bool Wrap { get; set; } = true;

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the gap value.
    /// </summary>
    [Parameter]
    public int Gap { get; set; } = 8;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.Primary;

    /// <summary>
    /// Gets or sets the active text color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.White;

    internal bool IsSelected(TValue value)
    {
        return MultiSelect
            ? SelectedValues.Contains(value, EqualityComparer<TValue>.Default)
            : EqualityComparer<TValue?>.Default.Equals(SelectedValue, value);
    }

    internal async Task ToggleAsync(TValue value)
    {
        if (Disabled)
        {
            return;
        }

        if (MultiSelect)
        {
            var next = SelectedValues.ToList();
            var index = next.FindIndex(item => EqualityComparer<TValue>.Default.Equals(item, value));

            if (index >= 0)
            {
                next.RemoveAt(index);
            }
            else
            {
                next.Add(value);
            }

            SelectedValues = next;
            await SelectedValuesChanged.InvokeAsync(next);
            await InvokeAsync(StateHasChanged);
            return;
        }

        SelectedValue = value;
        await SelectedValueChanged.InvokeAsync(value);
        await InvokeAsync(StateHasChanged);
    }

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
