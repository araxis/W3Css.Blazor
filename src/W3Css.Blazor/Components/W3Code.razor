@inherits W3ComponentBase

@if (Inline)
{
    <code @attributes="AdditionalAttributes"
          class="@InlineCssClass"
          style="@Style">@Content@ChildContent</code>
}
else
{
    <pre @attributes="AdditionalAttributes"
         class="@BlockCssClass"
         style="@Style"><code>@Content@ChildContent</code></pre>
}

@code {
    private string InlineCssClass => BuildClass("w3-codespan");
    private string BlockCssClass => BuildClass("w3-code");

    private string? Content => Code;

    /// <summary>
    /// Gets or sets the code value.
    /// </summary>
    [Parameter]
    public string? Code { get; set; }

    /// <summary>
    /// Gets or sets the inline value.
    /// </summary>
    [Parameter]
    public bool Inline { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
