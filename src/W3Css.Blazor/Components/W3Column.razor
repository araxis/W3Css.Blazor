@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@Style">
    @ChildContent
</div>

@code {
    private string CssClass => BuildClass(
        Rest ? "w3-rest" : "w3-col",
        Rest ? null : ToColumnClass("s", Small),
        Rest ? null : ToColumnClass("m", Medium),
        Rest ? null : ToColumnClass("l", Large),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the small value.
    /// </summary>
    [Parameter]
    public int Small { get; set; }

    /// <summary>
    /// Gets or sets the medium value.
    /// </summary>
    [Parameter]
    public int Medium { get; set; }

    /// <summary>
    /// Gets or sets the large value.
    /// </summary>
    [Parameter]
    public int Large { get; set; }

    /// <summary>
    /// Gets or sets the rest value.
    /// </summary>
    [Parameter]
    public bool Rest { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    private static string? ToColumnClass(string prefix, int span)
    {
        return span is >= 1 and <= 12 ? $"{prefix}{span}" : null;
    }
}
