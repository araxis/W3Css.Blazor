@using W3Css.Blazor.Internal
@inherits W3ComponentBase

@if (ShowOverlay)
{
    <div class="@OverlayCssClass"
         aria-hidden="true"
         @onclick="CloseFromOverlayAsync"></div>
}

<aside @attributes="AdditionalAttributes"
       id="@Id"
       class="@DrawerCssClass"
       style="@DrawerStyle"
       role="@Role"
       aria-modal="@AriaModal"
       aria-hidden="@AriaHidden"
       aria-labelledby="@AriaLabelledByValue"
       aria-label="@AriaLabelValue"
       tabindex="-1"
       @onkeydown="HandleKeyDownAsync">
    @if (ShowHeader)
    {
        <div class="@HeaderCssClass">
            <div class="w3-drawer-header-content">
                @if (Header is not null)
                {
                    @Header
                }
                else if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h2 id="@TitleId" class="w3-drawer-title">@Title</h2>
                }
            </div>

            @if (ShowCloseButton)
            {
                <button type="button"
                        class="w3-button w3-drawer-close"
                        aria-label="@CloseButtonLabel"
                        @onclick="CloseAsync">
                    &times;
                </button>
            }
        </div>
    }

    <div class="@BodyCssClass">
        @ChildContent
    </div>

    @if (Footer is not null)
    {
        <div class="@FooterCssClass">
            @Footer
        </div>
    }
</aside>

@code {
    private readonly string generatedTitleId = $"w3-drawer-title-{Guid.NewGuid():N}";

    private bool IsTemporary => Variant == W3DrawerVariant.Temporary;

    private bool ShowOverlay => Open && IsTemporary && Overlay;

    private bool ShowHeader => Header is not null || !string.IsNullOrWhiteSpace(Title) || ShowCloseButton;

    private string TitleId => string.IsNullOrWhiteSpace(Id) ? generatedTitleId : $"{Id}-title";

    private string? AriaLabelledByValue => !string.IsNullOrWhiteSpace(AriaLabelledBy)
        ? AriaLabelledBy
        : !string.IsNullOrWhiteSpace(Title) ? TitleId : null;

    private string? AriaLabelValue => string.IsNullOrWhiteSpace(AriaLabelledByValue) ? AriaLabel : null;

    private string AriaHidden => Open ? "false" : "true";

    private string? AriaModal => IsTemporary ? Open.ToString().ToLowerInvariant() : null;

    private string Role => IsTemporary ? "dialog" : "complementary";

    private string DrawerCssClass => BuildClass(
        "w3-sidebar",
        "w3-drawer",
        Position == W3SidebarPosition.Right ? "w3-drawer-right" : "w3-drawer-left",
        IsTemporary ? "w3-drawer-temporary" : "w3-drawer-persistent",
        Contained ? "w3-drawer-contained" : null,
        Open ? "w3-show" : "w3-hide",
        Animate ? AnimationClass : null,
        Card ? "w3-card-4" : null,
        Border ? "w3-border" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string OverlayCssClass => new W3ClassBuilder()
        .Add("w3-overlay")
        .Add("w3-show")
        .Add("w3-drawer-overlay")
        .Add(Contained ? "w3-drawer-overlay-contained" : null)
        .ToString();

    private string HeaderCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .Add("w3-drawer-header")
        .Add(HeaderColor.ToBackgroundClass())
        .Add(HeaderTextColor.ToTextClass())
        .Add(HeaderClass)
        .ToString();

    private string BodyCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .Add("w3-drawer-body")
        .Add(BodyClass)
        .ToString();

    private string FooterCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .Add("w3-drawer-footer")
        .Add(FooterColor.ToBackgroundClass())
        .Add(FooterTextColor.ToTextClass())
        .Add(FooterClass)
        .ToString();

    private string DrawerStyle
    {
        get
        {
            var width = Width <= 0 ? 280 : Width;
            var positionStyle = Position == W3SidebarPosition.Right ? "right:0" : "left:0";
            var baseStyle = $"width:{width}px;max-width:100vw;top:0;bottom:0;{positionStyle}";
            return string.IsNullOrWhiteSpace(Style) ? baseStyle : $"{baseStyle};{Style}";
        }
    }

    private string AnimationClass => Position == W3SidebarPosition.Right ? "w3-animate-right" : "w3-animate-left";

    /// <summary>
    /// Gets or sets the rendered element id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the open value.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the open value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the variant value.
    /// </summary>
    [Parameter]
    public W3DrawerVariant Variant { get; set; } = W3DrawerVariant.Temporary;

    /// <summary>
    /// Gets or sets the overlay value.
    /// </summary>
    [Parameter]
    public bool Overlay { get; set; } = true;

    /// <summary>
    /// Gets or sets the close on overlay value.
    /// </summary>
    [Parameter]
    public bool CloseOnOverlay { get; set; } = true;

    /// <summary>
    /// Gets or sets the close on escape value.
    /// </summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    /// <summary>
    /// Gets or sets the show close button value.
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string CloseButtonLabel { get; set; } = "Close drawer";

    /// <summary>
    /// Gets or sets the contained value.
    /// </summary>
    [Parameter]
    public bool Contained { get; set; }

    /// <summary>
    /// Gets or sets the animate value.
    /// </summary>
    [Parameter]
    public bool Animate { get; set; } = true;

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; } = true;

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the width value.
    /// </summary>
    [Parameter]
    public int Width { get; set; } = 280;

    /// <summary>
    /// Gets or sets the position value.
    /// </summary>
    [Parameter]
    public W3SidebarPosition Position { get; set; } = W3SidebarPosition.Left;

    /// <summary>
    /// Gets or sets the title value.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the AriaLabel attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>
    /// Gets or sets the AriaLabelledBy attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabelledBy { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the header color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderColor { get; set; } = W3Color.Teal;

    /// <summary>
    /// Gets or sets the header text color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderTextColor { get; set; } = W3Color.White;

    /// <summary>
    /// Gets or sets the footer color value.
    /// </summary>
    [Parameter]
    public W3Color FooterColor { get; set; } = W3Color.LightGrey;

    /// <summary>
    /// Gets or sets the footer text color value.
    /// </summary>
    [Parameter]
    public W3Color FooterTextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the header class value.
    /// </summary>
    [Parameter]
    public string? HeaderClass { get; set; }

    /// <summary>
    /// Gets or sets the body class value.
    /// </summary>
    [Parameter]
    public string? BodyClass { get; set; }

    /// <summary>
    /// Gets or sets the footer class value.
    /// </summary>
    [Parameter]
    public string? FooterClass { get; set; }

    /// <summary>
    /// Gets or sets the header value.
    /// </summary>
    [Parameter]
    public RenderFragment? Header { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the footer value.
    /// </summary>
    [Parameter]
    public RenderFragment? Footer { get; set; }

    private async Task CloseAsync()
    {
        if (!Open)
        {
            return;
        }

        Open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private Task CloseFromOverlayAsync()
    {
        return CloseOnOverlay ? CloseAsync() : Task.CompletedTask;
    }

    private Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        return CloseOnEscape && args.Key == "Escape" ? CloseAsync() : Task.CompletedTask;
    }
}
