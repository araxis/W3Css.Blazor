@using Microsoft.AspNetCore.Components.Forms
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<InputFile @attributes="AdditionalAttributes"
           id="@Id"
           name="@Name"
           class="@InputCssClass"
           style="@Style"
           accept="@Accept"
           multiple="@Multiple"
           disabled="@Disabled"
           required="@Required"
           aria-label="@AriaLabel"
           aria-required="@AriaRequired"
           OnChange="@HandleChange" />

@if (ShowSelectedFiles && SelectedFiles.Count > 0)
{
    <ul class="@SelectedListCssClass" aria-live="polite" aria-label="@SelectedFilesLabel">
        @foreach (var file in SelectedFiles)
        {
            <li>@file.Name</li>
        }
    </ul>
}

@code {
    private IReadOnlyList<IBrowserFile> SelectedFiles { get; set; } = [];
    private string? AriaRequired => Required ? "true" : null;

    private string InputCssClass => new W3ClassBuilder()
        .Add("w3-input")
        .Add("w3-file-input")
        .Add(Color.ToBackgroundClass())
        .Add(TextColor.ToTextClass())
        .Add(Round.ToClass())
        .AddIf(Border, "w3-border")
        .Add(Class)
        .ToString();

    private string SelectedListCssClass => new W3ClassBuilder()
        .Add("w3-ul")
        .Add("w3-border")
        .Add("w3-small")
        .Add("w3-margin-top")
        .Add(SelectedFilesClass)
        .ToString();

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Accept { get; set; }

    [Parameter]
    public bool Multiple { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    [Parameter]
    public bool Border { get; set; }

    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    [Parameter]
    public bool ShowSelectedFiles { get; set; }

    [Parameter]
    public int MaximumFileCount { get; set; } = 10;

    [Parameter]
    public string? SelectedFilesClass { get; set; }

    [Parameter]
    public string SelectedFilesLabel { get; set; } = "Selected files";

    [Parameter]
    public EventCallback<InputFileChangeEventArgs> OnChange { get; set; }

    private async Task HandleChange(InputFileChangeEventArgs args)
    {
        SelectedFiles = Multiple ? args.GetMultipleFiles(MaximumFileCount) : [args.File];

        if (OnChange.HasDelegate)
        {
            await OnChange.InvokeAsync(args);
        }
    }
}
