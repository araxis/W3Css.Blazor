@using Microsoft.JSInterop
@using W3Css.Blazor.Internal
@inherits W3ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<div @attributes="AdditionalAttributes"
     @ref="RootElement"
     class="@CssClass"
     style="@Style"
     tabindex="@TabIndex"
     aria-label="@AriaLabel">
    @ChildContent
</div>

@code {
    private ElementReference RootElement { get; set; }

    private W3FocusTrapInterop? focusTrap;

    private string CssClass => BuildClass("w3-focus-trap");

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the active value.
    /// </summary>
    [Parameter]
    public bool Active { get; set; } = true;

    /// <summary>
    /// Gets or sets the auto focus value.
    /// </summary>
    [Parameter]
    public bool AutoFocus { get; set; } = true;

    /// <summary>
    /// Gets or sets the restore focus value.
    /// </summary>
    [Parameter]
    public bool RestoreFocus { get; set; } = true;

    /// <summary>
    /// Gets or sets the initial focus selector value.
    /// </summary>
    [Parameter]
    public string? InitialFocusSelector { get; set; }

    /// <summary>
    /// Gets or sets the AriaLabel attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>
    /// Gets or sets the tab index value.
    /// </summary>
    [Parameter]
    public int? TabIndex { get; set; } = -1;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        focusTrap ??= new W3FocusTrapInterop(JS);
        await focusTrap.SyncAsync(RootElement, Active, AutoFocus, RestoreFocus, InitialFocusSelector);
    }

    public async ValueTask DisposeAsync()
    {
        if (focusTrap is not null)
        {
            await focusTrap.DisposeAsync();
        }
    }
}
