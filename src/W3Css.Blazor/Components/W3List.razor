@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<ul @attributes="AdditionalAttributes"
    class="@CssClass"
    style="@Style">
    @ChildContent
</ul>

@code {
    private string CssClass => BuildClass(
        "w3-ul",
        Color.ToBackgroundClass(),
        TextColor.ToTextClass(),
        Border ? "w3-border" : null,
        Hoverable ? "w3-hoverable" : null,
        Centered ? "w3-center" : null);

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the hoverable value.
    /// </summary>
    [Parameter]
    public bool Hoverable { get; set; }

    /// <summary>
    /// Gets or sets the centered value.
    /// </summary>
    [Parameter]
    public bool Centered { get; set; }
}
