@using Microsoft.AspNetCore.Components.Web
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<li @attributes="AdditionalAttributes"
    class="@ContainerClass"
    style="@Style"
    role="listitem">

    @if (Disabled)
    {
        <span class="@ActionClass" aria-current="@AriaCurrent" aria-disabled="true" role="button">
            @ListItemContent
        </span>
    }
    else if (!string.IsNullOrWhiteSpace(Href))
    {
        <a class="@ActionClass"
           href="@Href"
           target="@Target"
           rel="@Rel"
           aria-current="@AriaCurrent"
           @onclick="HandleClick">
            @ListItemContent
        </a>
    }
    else
    {
        <button class="@ActionClass"
                type="@Type"
                aria-current="@AriaCurrent"
                @onclick="HandleClick">
            @ListItemContent
        </button>
    }
</li>

@code {
    private string ContainerClass => BuildClass(
        "w3-list-item",
        Dense ? "w3-list-item-dense" : null,
        Divider ? "w3-border-bottom" : null,
        Active ? "w3-list-item-active" : null,
        Disabled ? "w3-list-item-disabled" : null,
        Class);

    private string ActionClass => BuildClass(
        "w3-bar-item",
        "w3-button",
        "w3-list-item-action",
        Dense ? "w3-list-item-action-dense" : null,
        Disabled ? "w3-disabled" : null,
        ResolveBackgroundColor.ToBackgroundClass(),
        ResolveTextColor.ToTextClass(),
        ResolveHoverCssClass());

    private RenderFragment ListItemContent => builder =>
    {
        var index = 0;

        if (StartContent is not null || !string.IsNullOrWhiteSpace(ResolvedStartIconClass))
        {
            builder.OpenElement(index++, "span");
            builder.AddAttribute(index++, "class", "w3-list-item-start");

            if (StartContent is not null)
            {
                builder.AddContent(index++, StartContent);
            }
            else
            {
                builder.OpenElement(index++, "span");
                builder.AddAttribute(index++, "class", StartIconClass);
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.OpenElement(index++, "span");
        builder.AddAttribute(index++, "class", "w3-list-item-label");

        if (ChildContent is not null)
        {
            builder.AddContent(index++, ChildContent);
        }
        else
        {
            builder.AddContent(index++, Text ?? string.Empty);
        }

        builder.CloseElement();

        if (EndContent is not null)
        {
            builder.OpenElement(index++, "span");
            builder.AddAttribute(index++, "class", "w3-list-item-end");
            builder.AddContent(index++, EndContent);
            builder.CloseElement();
        }
    };

    private string? AriaCurrent => Active ? "page" : null;

    private W3Color ResolveBackgroundColor => Active
        ? ActiveColor != W3Color.None ? ActiveColor : W3Color.None
        : Color;

    private W3Color ResolveTextColor => Active
        ? ActiveTextColor != W3Color.None ? ActiveTextColor : TextColor
        : TextColor;

    private string ResolveHoverCssClass()
    {
        if (Active || Disabled)
        {
            return string.Empty;
        }

        return new W3ClassBuilder()
            .Add(HoverColor.ToHoverBackgroundClass())
            .Add(HoverTextColor.ToHoverTextClass())
            .ToString();
    }

    private string StartIconClass => new W3ClassBuilder()
        .Add("w3-list-item-icon")
        .Add(ResolvedStartIconClass)
        .ToString();

    private string ResolvedStartIconClass => IconClass ?? StartIconClassName ?? string.Empty;

    private Task HandleClick(MouseEventArgs args)
    {
        return OnClick.InvokeAsync(args);
    }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the text value.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    /// <summary>
    /// Gets or sets the start icon class name value.
    /// </summary>
    [Parameter]
    public string? StartIconClassName { get; set; }

    /// <summary>
    /// Gets or sets the start content value.
    /// </summary>
    [Parameter]
    public RenderFragment? StartContent { get; set; }

    /// <summary>
    /// Gets or sets the end content value.
    /// </summary>
    [Parameter]
    public RenderFragment? EndContent { get; set; }

    /// <summary>
    /// Gets or sets the icon class value.
    /// </summary>
    [Parameter]
    public string? IconClass { get; set; }

    /// <summary>
    /// Gets or sets the link target URL.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the link target browsing context.
    /// </summary>
    [Parameter]
    public string? Target { get; set; }

    /// <summary>
    /// Gets or sets the rel value.
    /// </summary>
    [Parameter]
    public string? Rel { get; set; }

    /// <summary>
    /// Gets or sets the dense value.
    /// </summary>
    [Parameter]
    public bool Dense { get; set; }

    /// <summary>
    /// Gets or sets the divider value.
    /// </summary>
    [Parameter]
    public bool Divider { get; set; }

    /// <summary>
    /// Gets or sets the active value.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the rendered button type.
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "button";

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active text color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the hover color value.
    /// </summary>
    [Parameter]
    public W3Color HoverColor { get; set; } = W3Color.LightGrey;

    /// <summary>
    /// Gets or sets the hover text color value.
    /// </summary>
    [Parameter]
    public W3Color HoverTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }
}
