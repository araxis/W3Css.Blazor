@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using W3Css.Blazor.Internal
@inherits W3ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<div @attributes="AdditionalAttributes"
     @ref="RootElement"
     class="@CssClass"
     style="@StyleValue">
    <button type="@Type"
            @ref="TriggerElement"
            class="@TriggerCssClass"
            aria-haspopup="menu"
            aria-label="@Label"
            aria-expanded="@AriaExpanded"
            aria-controls="@MenuId"
            disabled="@Disabled"
            @onkeydown="HandleTriggerKeyDownAsync"
            @onclick="ToggleAsync">
        @if (TriggerContent is not null)
        {
            @TriggerContent
        }
        else
        {
            @if (HasIcon)
            {
                <W3Icon IconName="@IconName" IconClass="@IconClass" Class="@IconCssClass" />
            }
            @if (!HideTriggerLabel)
            {
                <span class="w3-menu-trigger-label">@Label</span>
            }
            @if (ShowCaret)
            {
                <span class="w3-menu-caret" aria-hidden="true">▾</span>
            }
        }
    </button>

    @if (CloseOnOutsideClick && currentOpen)
    {
        <div class="w3-menu-close-layer"
             aria-hidden="true"
             @onclick="CloseAsync"></div>
    }

    <CascadingValue Value="this">
        <div id="@MenuId"
             @ref="PanelElement"
             class="@PanelCssClass"
             role="menu"
             aria-label="@EffectiveMenuLabel">
            @ChildContent
        </div>
    </CascadingValue>
</div>

@code {
    private readonly List<W3MenuItem> items = [];
    private readonly string menuId = $"w3-menu-{Guid.NewGuid():N}";

    private ElementReference RootElement { get; set; }

    private ElementReference TriggerElement { get; set; }

    private ElementReference PanelElement { get; set; }

    private IJSObjectReference? Module { get; set; }

    private IJSObjectReference? MenuReference { get; set; }

    private string CssClass => BuildClass(
        "w3-menu",
        "w3-dropdown-click",
        currentOpen ? "w3-dropdown-open w3-menu-open" : null,
        Disabled ? "w3-menu-disabled" : null);

    private string TriggerCssClass => new W3ClassBuilder()
        .Add("w3-button")
        .Add("w3-menu-trigger")
        .AddIf(IconOnly, "w3-menu-trigger-icon-only")
        .Add(TriggerColor.ToBackgroundClass())
        .Add(TriggerTextColor.ToTextClass())
        .Add(TriggerRound.ToClass())
        .AddIf(TriggerBorder, "w3-border")
        .AddIf(Disabled, "w3-disabled")
        .Add(TriggerClass)
        .ToString();

    private string PanelCssClass => new W3ClassBuilder()
        .Add("w3-dropdown-content")
        .Add("w3-bar-block")
        .Add("w3-menu-panel")
        .AddIf(FixedPosition, "w3-menu-panel-fixed")
        .Add(Placement.ToClass())
        .Add(Card ? CardDepth.ToClass() : null)
        .Add(Round.ToClass())
        .AddIf(currentOpen, "w3-show")
        .AddIf(Animate, "w3-animate-opacity")
        .Add(PanelColor.ToBackgroundClass())
        .Add(PanelTextColor.ToTextClass())
        .Add(PanelClass)
        .ToString();

    private string IconCssClass => new W3ClassBuilder()
        .Add("w3-menu-trigger-icon")
        .ToString();

    private string? StyleValue => CombineStyle($"--w3-menu-min-width:{Math.Max(0, MinWidth)}px", Style);

    private string MenuId => string.IsNullOrWhiteSpace(Id) ? menuId : Id;

    private string AriaExpanded => currentOpen ? "true" : "false";

    private string EffectiveMenuLabel => string.IsNullOrWhiteSpace(MenuLabel) ? Label : MenuLabel;

    private bool HasIcon => IconName != W3IconName.None || !string.IsNullOrWhiteSpace(IconClass);

    private bool HideTriggerLabel => IconOnly && HasIcon;

    private bool currentOpen;
    private bool? lastOpenParameter;
    private W3MenuItem? activeItem;
    private W3MenuItem? pendingFocusItem;

    /// <summary>
    /// Gets or sets the rendered element id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Menu";

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string? MenuLabel { get; set; }

    /// <summary>
    /// Gets or sets the built-in icon name.
    /// </summary>
    [Parameter]
    public W3IconName IconName { get; set; } = W3IconName.None;

    /// <summary>
    /// Gets or sets icon classes from an external icon stylesheet.
    /// </summary>
    [Parameter]
    public string? IconClass { get; set; }

    /// <summary>
    /// Gets or sets the trigger content value.
    /// </summary>
    [Parameter]
    public RenderFragment? TriggerContent { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Controls whether the menu panel is open.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the open value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the close on outside click value.
    /// </summary>
    [Parameter]
    public bool CloseOnOutsideClick { get; set; } = true;

    /// <summary>
    /// Gets or sets the close on select value.
    /// </summary>
    [Parameter]
    public bool CloseOnSelect { get; set; } = true;

    /// <summary>
    /// Gets or sets the show caret value.
    /// </summary>
    [Parameter]
    public bool ShowCaret { get; set; } = true;

    /// <summary>
    /// Gets or sets the icon only value.
    /// </summary>
    [Parameter]
    public bool IconOnly { get; set; }

    /// <summary>
    /// Gets or sets the fixed position value.
    /// </summary>
    [Parameter]
    public bool FixedPosition { get; set; }

    /// <summary>
    /// Gets or sets the trigger border value.
    /// </summary>
    [Parameter]
    public bool TriggerBorder { get; set; }

    /// <summary>
    /// Gets or sets the trigger round value.
    /// </summary>
    [Parameter]
    public W3Round TriggerRound { get; set; } = W3Round.Medium;

    /// <summary>
    /// Gets or sets the trigger color value.
    /// </summary>
    [Parameter]
    public W3Color TriggerColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the trigger text color value.
    /// </summary>
    [Parameter]
    public W3Color TriggerTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the trigger class value.
    /// </summary>
    [Parameter]
    public string? TriggerClass { get; set; }

    /// <summary>
    /// Gets or sets the placement value.
    /// </summary>
    [Parameter]
    public W3MenuPlacement Placement { get; set; } = W3MenuPlacement.BottomStart;

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; } = true;

    /// <summary>
    /// Gets or sets the card depth value.
    /// </summary>
    [Parameter]
    public W3CardDepth CardDepth { get; set; } = W3CardDepth.Four;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.Medium;

    /// <summary>
    /// Gets or sets the animate value.
    /// </summary>
    [Parameter]
    public bool Animate { get; set; }

    /// <summary>
    /// Gets or sets the panel color value.
    /// </summary>
    [Parameter]
    public W3Color PanelColor { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the panel text color value.
    /// </summary>
    [Parameter]
    public W3Color PanelTextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the panel class value.
    /// </summary>
    [Parameter]
    public string? PanelClass { get; set; }

    /// <summary>
    /// Gets or sets the min width value.
    /// </summary>
    [Parameter]
    public int MinWidth { get; set; } = 192;

    /// <summary>
    /// Gets or sets the rendered button type.
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "button";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (!FixedPosition)
            {
                await DisposeMenuReferenceAsync();
                await FocusPendingItemAsync();
                return;
            }

            Module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/W3Css.Blazor/w3Menu.js");

            var options = new
            {
                open = currentOpen,
                placement = Placement.ToString()
            };

            if (MenuReference is null)
            {
                MenuReference = await Module.InvokeAsync<IJSObjectReference>("connect", RootElement, TriggerElement, PanelElement, options);
                await FocusPendingItemAsync();
                return;
            }

            await MenuReference.InvokeVoidAsync("update", options);
            await FocusPendingItemAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    protected override void OnParametersSet()
    {
        if (lastOpenParameter is null || Open != lastOpenParameter.Value)
        {
            currentOpen = Open;
            lastOpenParameter = Open;

            if (!currentOpen)
            {
                activeItem = null;
            }
        }
    }

    private async Task ToggleAsync()
    {
        if (Disabled)
        {
            return;
        }

        await SetOpenAsync(!currentOpen);
    }

    internal async Task CloseAsync()
    {
        await SetOpenAsync(false);
    }

    internal void Register(W3MenuItem item)
    {
        if (items.Contains(item))
        {
            return;
        }

        items.Add(item);

        if (currentOpen && activeItem is null && IsSelectable(item))
        {
            activeItem = item;
        }
    }

    internal void Unregister(W3MenuItem item)
    {
        items.Remove(item);

        if (ReferenceEquals(activeItem, item))
        {
            activeItem = currentOpen ? GetFirstSelectableItem() : null;
        }
    }

    internal int? GetItemTabIndex(W3MenuItem item)
    {
        if (!currentOpen || !IsSelectable(item))
        {
            return -1;
        }

        activeItem ??= GetFirstSelectableItem();

        return ReferenceEquals(activeItem, item) ? 0 : -1;
    }

    internal async Task HandleItemKeyDownAsync(W3MenuItem item, KeyboardEventArgs args)
    {
        if (!currentOpen || !IsSelectable(item))
        {
            return;
        }

        activeItem = item;
        await HandleNavigationKeyDownAsync(args);
    }

    private async Task SetOpenAsync(bool open)
    {
        if (currentOpen == open)
        {
            return;
        }

        currentOpen = open;
        Open = open;
        lastOpenParameter = open;
        activeItem = currentOpen ? GetFirstSelectableItem() : null;

        await OpenChanged.InvokeAsync(open);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleTriggerKeyDownAsync(KeyboardEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        if (IsArrowDown(args.Key))
        {
            await OpenAndFocusAsync(GetFirstSelectableItem);
            return;
        }

        if (IsArrowUp(args.Key))
        {
            await OpenAndFocusAsync(GetLastSelectableItem);
        }
    }

    private async Task HandleNavigationKeyDownAsync(KeyboardEventArgs args)
    {
        if (IsArrowDown(args.Key))
        {
            await FocusItemAsync(GetAdjacentSelectableItem(1));
            return;
        }

        if (IsArrowUp(args.Key))
        {
            await FocusItemAsync(GetAdjacentSelectableItem(-1));
            return;
        }

        if (args.Key == "Home")
        {
            await FocusItemAsync(GetFirstSelectableItem());
            return;
        }

        if (args.Key == "End")
        {
            await FocusItemAsync(GetLastSelectableItem());
            return;
        }

        if (args.Key == "Escape")
        {
            await SetOpenAsync(false);
            await TryFocusTriggerAsync();
        }
    }

    private async Task OpenAndFocusAsync(Func<W3MenuItem?> itemSelector)
    {
        if (!currentOpen)
        {
            await SetOpenAsync(true);
        }

        await FocusItemAsync(itemSelector());
    }

    private async Task FocusItemAsync(W3MenuItem? item)
    {
        if (item is null)
        {
            return;
        }

        activeItem = item;
        pendingFocusItem = item;
        await InvokeAsync(StateHasChanged);
    }

    private async Task FocusPendingItemAsync()
    {
        if (pendingFocusItem is null)
        {
            return;
        }

        var item = pendingFocusItem;
        pendingFocusItem = null;
        await TryFocusItemAsync(item);
    }

    private async Task TryFocusItemAsync(W3MenuItem item)
    {
        try
        {
            await item.FocusAsync();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSException)
        {
        }
    }

    private async Task TryFocusTriggerAsync()
    {
        try
        {
            await TriggerElement.FocusAsync();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSException)
        {
        }
    }

    private W3MenuItem? GetAdjacentSelectableItem(int direction)
    {
        var selectableItems = items.Where(IsSelectable).ToList();
        if (selectableItems.Count == 0)
        {
            return null;
        }

        var currentIndex = activeItem is null ? -1 : selectableItems.IndexOf(activeItem);
        if (currentIndex < 0)
        {
            return direction >= 0 ? selectableItems[0] : selectableItems[^1];
        }

        var nextIndex = (currentIndex + direction + selectableItems.Count) % selectableItems.Count;
        return selectableItems[nextIndex];
    }

    private W3MenuItem? GetFirstSelectableItem()
    {
        return items.FirstOrDefault(IsSelectable);
    }

    private W3MenuItem? GetLastSelectableItem()
    {
        return items.LastOrDefault(IsSelectable);
    }

    private static bool IsSelectable(W3MenuItem item)
    {
        return !item.Disabled;
    }

    private static bool IsArrowDown(string key)
    {
        return key is "ArrowDown" or "Down";
    }

    private static bool IsArrowUp(string key)
    {
        return key is "ArrowUp" or "Up";
    }

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }

    private async ValueTask DisposeMenuReferenceAsync()
    {
        if (MenuReference is null)
        {
            return;
        }

        try
        {
            await MenuReference.InvokeVoidAsync("dispose");
            await MenuReference.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        finally
        {
            MenuReference = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeMenuReferenceAsync();

        if (Module is not null)
        {
            try
            {
                await Module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
            catch (ObjectDisposedException)
            {
            }
        }
    }
}
