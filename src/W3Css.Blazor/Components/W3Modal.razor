@using Microsoft.JSInterop
@using W3Css.Blazor.Internal
@inherits W3ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<div @attributes="AdditionalAttributes"
     id="@Id"
     class="@ModalCssClass"
     style="@Style"
     role="dialog"
     aria-modal="@AriaOpen"
     aria-hidden="@AriaHidden"
     aria-labelledby="@AriaLabelledByValue"
     aria-label="@AriaLabelValue"
     tabindex="-1"
     @onclick="CloseFromBackdropAsync"
     @onkeydown="HandleKeyDownAsync">
    <div class="@ContentCssClass"
         style="@ContentStyle"
         @ref="contentElement"
         @onclick:stopPropagation="true">
        @if (ShowCloseButton)
        {
            <button type="button"
                    class="w3-button w3-display-topright"
                    aria-label="@CloseButtonLabel"
                    @onclick="CloseAsync">
                &times;
            </button>
        }

        @if (Header is not null)
        {
            @Header
        }
        else if (!string.IsNullOrWhiteSpace(Title))
        {
            <W3Container Color="HeaderColor" TextColor="HeaderTextColor">
                <h2 id="@TitleId">@Title</h2>
            </W3Container>
        }

        <W3Container>
            @ChildContent
        </W3Container>

        @if (Footer is not null)
        {
            <div class="@FooterCssClass">
                @Footer
            </div>
        }
        else if (Actions is not null)
        {
            <div class="@FooterCssClass">
                <div class="w3-modal-actions">
                    @Actions
                </div>
            </div>
        }
    </div>
</div>

@code {
    private ElementReference contentElement;
    private W3FocusTrapInterop? focusTrap;
    private W3ScrollLockInterop? scrollLock;

    private string TitleId => Id is null ? "w3-modal-title" : $"{Id}-title";
    private string? AriaOpen => Open ? "true" : null;
    private string AriaHidden => Open ? "false" : "true";
    private string? AriaLabelledByValue => !string.IsNullOrWhiteSpace(AriaLabelledBy)
        ? AriaLabelledBy
        : !string.IsNullOrWhiteSpace(Title) ? TitleId : null;
    private string? AriaLabelValue => string.IsNullOrWhiteSpace(AriaLabelledByValue) ? AriaLabel : null;

    private string ModalCssClass => BuildClass(
        "w3-modal",
        Open ? "w3-show" : null);

    private string ContentCssClass => new W3ClassBuilder()
        .Add("w3-modal-content")
        .Add(Card ? "w3-card-4" : null)
        .Add(Animate ? "w3-animate-zoom" : null)
        .Add(ContentColor.ToBackgroundClass())
        .Add(ContentTextColor.ToTextClass())
        .Add(ContentClass)
        .ToString();

    private string FooterCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .Add("w3-modal-footer")
        .Add(FooterColor.ToBackgroundClass())
        .Add(FooterTextColor.ToTextClass())
        .ToString();

    /// <summary>
    /// Gets or sets the rendered element id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the open value.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the open value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the title value.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the AriaLabel attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>
    /// Gets or sets the AriaLabelledBy attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLabelledBy { get; set; }

    /// <summary>
    /// Gets or sets the header value.
    /// </summary>
    [Parameter]
    public RenderFragment? Header { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the footer value.
    /// </summary>
    [Parameter]
    public RenderFragment? Footer { get; set; }

    /// <summary>
    /// Convenience footer actions rendered inside a right-aligned action row when <see cref="Footer"/> is not set.
    /// </summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }

    /// <summary>
    /// Gets or sets the show close button value.
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string CloseButtonLabel { get; set; } = "Close";

    /// <summary>
    /// Gets or sets the close on backdrop value.
    /// </summary>
    [Parameter]
    public bool CloseOnBackdrop { get; set; } = true;

    /// <summary>
    /// Gets or sets the close on escape value.
    /// </summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; } = true;

    /// <summary>
    /// Gets or sets the animate value.
    /// </summary>
    [Parameter]
    public bool Animate { get; set; }

    /// <summary>
    /// Gets or sets the content class value.
    /// </summary>
    [Parameter]
    public string? ContentClass { get; set; }

    /// <summary>
    /// Gets or sets the content style value.
    /// </summary>
    [Parameter]
    public string? ContentStyle { get; set; }

    /// <summary>
    /// Gets or sets the content color value.
    /// </summary>
    [Parameter]
    public W3Color ContentColor { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the content text color value.
    /// </summary>
    [Parameter]
    public W3Color ContentTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the header color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderColor { get; set; } = W3Color.Teal;

    /// <summary>
    /// Gets or sets the header text color value.
    /// </summary>
    [Parameter]
    public W3Color HeaderTextColor { get; set; } = W3Color.White;

    /// <summary>
    /// Gets or sets the footer color value.
    /// </summary>
    [Parameter]
    public W3Color FooterColor { get; set; } = W3Color.LightGrey;

    /// <summary>
    /// Gets or sets the footer text color value.
    /// </summary>
    [Parameter]
    public W3Color FooterTextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets whether keyboard focus is trapped within the open dialog and restored to the previously focused element on close.
    /// </summary>
    [Parameter]
    public bool TrapFocus { get; set; } = true;

    /// <summary>
    /// Gets or sets whether page scrolling behind the open dialog is locked.
    /// </summary>
    [Parameter]
    public bool LockScroll { get; set; } = true;

    private async Task CloseAsync()
    {
        if (!Open)
        {
            return;
        }

        Open = false;
        await OpenChanged.InvokeAsync(false);
    }

    private Task CloseFromBackdropAsync()
    {
        return CloseOnBackdrop ? CloseAsync() : Task.CompletedTask;
    }

    private Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        return CloseOnEscape && args.Key == "Escape" ? CloseAsync() : Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        focusTrap ??= new W3FocusTrapInterop(JS);
        scrollLock ??= new W3ScrollLockInterop(JS);

        await focusTrap.SyncAsync(contentElement, Open && TrapFocus);
        await scrollLock.SyncAsync(Open && LockScroll);
    }

    public async ValueTask DisposeAsync()
    {
        if (focusTrap is not null)
        {
            await focusTrap.DisposeAsync();
        }

        if (scrollLock is not null)
        {
            await scrollLock.DisposeAsync();
        }
    }
}
