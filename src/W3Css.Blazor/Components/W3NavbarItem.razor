@using W3Css.Blazor.Internal
@inherits W3ComponentBase

@if (!string.IsNullOrWhiteSpace(Href))
{
    <a @attributes="AdditionalAttributes"
       href="@ResolvedHref"
       target="@Target"
       aria-current="@AriaCurrent"
       aria-disabled="@AriaDisabled"
       class="@CssClass"
       style="@Style"
       @onclick="HandleClickAsync">
        @ChildContent
    </a>
}
else
{
    <button @attributes="AdditionalAttributes"
            type="@Type"
            disabled="@Disabled"
            aria-current="@AriaCurrent"
            class="@CssClass"
            style="@Style"
            @onclick="HandleClickAsync">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter]
    internal W3Navbar? Owner { get; set; }

    private bool EffectiveMobile => Mobile || Owner?.Mobile == true;
    private bool IsActive => Active || Owner?.IsActive(Value) == true;
    private string? AriaCurrent => IsActive ? "page" : null;
    private string? AriaDisabled => Disabled ? "true" : null;
    private string? ResolvedHref => Disabled ? null : Href;

    private string CssClass => BuildClass(
        "w3-bar-item",
        Button ? "w3-button" : null,
        EffectiveMobile ? "w3-mobile" : null,
        Disabled ? "w3-disabled" : null,
        ResolveColor().ToBackgroundClass(),
        ResolveTextColor().ToTextClass());

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the value value.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the link target URL.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the link target browsing context.
    /// </summary>
    [Parameter]
    public string? Target { get; set; }

    /// <summary>
    /// Gets or sets the button value.
    /// </summary>
    [Parameter]
    public bool Button { get; set; } = true;

    /// <summary>
    /// Gets or sets the mobile value.
    /// </summary>
    [Parameter]
    public bool Mobile { get; set; }

    /// <summary>
    /// Gets or sets the active value.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the rendered button type.
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "button";

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active text color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private W3Color ResolveColor()
    {
        if (!IsActive)
        {
            return Color;
        }

        if (ActiveColor != W3Color.None)
        {
            return ActiveColor;
        }

        return Owner?.ActiveColor ?? W3Color.Green;
    }

    private W3Color ResolveTextColor()
    {
        if (!IsActive)
        {
            return TextColor;
        }

        if (ActiveTextColor != W3Color.None)
        {
            return ActiveTextColor;
        }

        return Owner?.ActiveTextColor ?? W3Color.White;
    }

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(Value) && Owner is not null)
        {
            await Owner.ActivateAsync(Value);
        }

        await OnClick.InvokeAsync(args);
    }
}
