@typeparam TValue
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@inherits W3FormComponentBase<TValue>

<input @attributes="AdditionalAttributes"
       id="@Id"
       name="@NameAttributeValue"
       type="number"
       class="@NumberCssClass"
       style="@Style"
       placeholder="@Placeholder"
       min="@MinAsString"
       max="@MaxAsString"
       step="@Step"
       disabled="@Disabled"
       readonly="@ReadOnly"
       required="@Required"
       aria-required="@AriaRequired"
       aria-invalid="@AriaInvalid"
       value="@CurrentValueAsString"
       @oninput="HandleInput"
       @onchange="HandleChange" />

@code {
    private string NumberCssClass => BuildControlClass("w3-input");
    private string? MinAsString => FormatNumber(Min);
    private string? MaxAsString => FormatNumber(Max);
    private string? AriaRequired => Required ? "true" : null;
    private string? AriaInvalid => EditContext?.GetValidationMessages(FieldIdentifier).Any() == true ? "true" : null;

    /// <summary>
    /// Gets or sets the rendered element id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the placeholder value.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Gets or sets the min value.
    /// </summary>
    [Parameter]
    public TValue? Min { get; set; }

    /// <summary>
    /// Gets or sets the max value.
    /// </summary>
    [Parameter]
    public TValue? Max { get; set; }

    /// <summary>
    /// Gets or sets the step value.
    /// </summary>
    [Parameter]
    public string? Step { get; set; }

    /// <summary>
    /// Gets or sets whether the input is read-only.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Gets or sets whether a value is required for form validation.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Gets or sets the update on input value.
    /// </summary>
    [Parameter]
    public bool UpdateOnInput { get; set; }

    private void HandleInput(ChangeEventArgs args)
    {
        if (UpdateOnInput)
        {
            CurrentValueAsString = args.Value?.ToString();
        }
    }

    private void HandleChange(ChangeEventArgs args)
    {
        if (!UpdateOnInput)
        {
            CurrentValueAsString = args.Value?.ToString();
        }
    }

    protected override string? FormatValueAsString(TValue? value)
    {
        return FormatNumber(value);
    }

    protected override bool TryParseValueFromString(string? value, out TValue result, out string validationErrorMessage)
    {
        if (BindConverter.TryConvertTo<TValue>(value, CultureInfo.InvariantCulture, out var parsedValue))
        {
            result = parsedValue;
            validationErrorMessage = string.Empty;
            return true;
        }

        result = default!;
        validationErrorMessage = $"The {FieldIdentifier.FieldName} field is not a valid number.";
        return false;
    }

    private static string? FormatNumber(TValue? value)
    {
        return value switch
        {
            null => null,
            IFormattable formattable => formattable.ToString(null, CultureInfo.InvariantCulture),
            _ => value.ToString()
        };
    }
}

