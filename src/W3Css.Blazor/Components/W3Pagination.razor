@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<nav @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@Style"
     aria-label="@AriaLabel"
     @onkeydown="HandleKeyDownAsync">
    @if (ShowPreviousNext)
    {
        <button type="button"
                class="@GetPageClass(false, CurrentPage <= 1)"
                disabled="@(CurrentPage <= 1)"
                @onclick="() => SelectPageAsync(CurrentPage - 1)">
            @PreviousText
        </button>
    }

    @foreach (var page in BuildPages())
    {
        if (page is null)
        {
            <span class="w3-button w3-bar-item w3-disabled w3-pagination-ellipsis" aria-hidden="true">&hellip;</span>
        }
        else
        {
            var current = page.Value;
            var active = current == CurrentPage;
            <button type="button"
                    class="@GetPageClass(active, false)"
                    aria-current="@(active ? "page" : null)"
                    @onclick="() => SelectPageAsync(current)">
                @current
            </button>
        }
    }

    @if (ShowPreviousNext)
    {
        <button type="button"
                class="@GetPageClass(false, CurrentPage >= PageCount)"
                disabled="@(CurrentPage >= PageCount)"
                @onclick="() => SelectPageAsync(CurrentPage + 1)">
            @NextText
        </button>
    }
</nav>

@code {
    private string CssClass => BuildClass("w3-bar", Center ? "w3-center" : null);

    /// <summary>
    /// Gets or sets the page count value.
    /// </summary>
    [Parameter]
    public int PageCount { get; set; }

    /// <summary>
    /// Gets or sets the current page value.
    /// </summary>
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Gets or sets the callback raised when the current page value changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> CurrentPageChanged { get; set; }

    /// <summary>
    /// Gets or sets the show previous next value.
    /// </summary>
    [Parameter]
    public bool ShowPreviousNext { get; set; } = true;

    /// <summary>
    /// Gets or sets the center value.
    /// </summary>
    [Parameter]
    public bool Center { get; set; }

    /// <summary>
    /// Gets or sets the previous text value.
    /// </summary>
    [Parameter]
    public string PreviousText { get; set; } = "Previous";

    /// <summary>
    /// Gets or sets the next text value.
    /// </summary>
    [Parameter]
    public string NextText { get; set; } = "Next";

    /// <summary>
    /// Gets or sets the AriaLabel attribute value.
    /// </summary>
    [Parameter]
    public string AriaLabel { get; set; } = "Pagination";

    /// <summary>
    /// Gets or sets the active color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.Primary;

    /// <summary>
    /// Gets or sets the active text color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.White;

    /// <summary>
    /// Number of always-visible pages at the start and end of the pager.
    /// </summary>
    [Parameter]
    public int BoundaryCount { get; set; } = 1;

    /// <summary>
    /// Number of pages shown on each side of the current page.
    /// </summary>
    [Parameter]
    public int SiblingCount { get; set; } = 1;

    // Windowed page list: boundary pages, the current page with its siblings,
    // and an ellipsis (null) wherever there is a gap, so a large page count does
    // not render one button per page. Mirrors the well-known MUI pagination model.
    private IReadOnlyList<int?> BuildPages()
    {
        var count = PageCount;

        if (count <= 0)
        {
            return [];
        }

        var boundary = Math.Max(0, BoundaryCount);
        var sibling = Math.Max(0, SiblingCount);
        var current = Math.Clamp(CurrentPage, 1, count);

        var startPages = Range(1, Math.Min(boundary, count));
        var endPages = Range(Math.Max(count - boundary + 1, boundary + 1), count);

        var siblingsStart = Math.Max(
            Math.Min(current - sibling, count - boundary - (sibling * 2) - 1),
            boundary + 2);

        var siblingsEnd = Math.Min(
            Math.Max(current + sibling, boundary + (sibling * 2) + 2),
            endPages.Count > 0 ? endPages[0] - 2 : count - 1);

        var pages = new List<int?>();
        pages.AddRange(startPages.Select(page => (int?)page));

        if (siblingsStart > boundary + 2)
        {
            pages.Add(null);
        }
        else if (boundary + 1 < count - boundary)
        {
            pages.Add(boundary + 1);
        }

        for (var page = siblingsStart; page <= siblingsEnd; page++)
        {
            pages.Add(page);
        }

        if (siblingsEnd < count - boundary - 1)
        {
            pages.Add(null);
        }
        else if (count - boundary > boundary)
        {
            pages.Add(count - boundary);
        }

        pages.AddRange(endPages.Select(page => (int?)page));

        return pages;
    }

    private static List<int> Range(int start, int end)
    {
        if (end < start)
        {
            return [];
        }

        var values = new List<int>(end - start + 1);

        for (var value = start; value <= end; value++)
        {
            values.Add(value);
        }

        return values;
    }

    private string GetPageClass(bool active, bool disabled)
    {
        return new W3ClassBuilder()
            .Add("w3-button")
            .Add("w3-bar-item")
            .AddIf(active, ActiveColor.ToBackgroundClass())
            .AddIf(active, ActiveTextColor.ToTextClass())
            .AddIf(disabled, "w3-disabled")
            .ToString();
    }

    private async Task SelectPageAsync(int page)
    {
        if (page < 1 || page > PageCount || page == CurrentPage)
        {
            return;
        }

        CurrentPage = page;
        await CurrentPageChanged.InvokeAsync(page);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        switch (args.Key)
        {
            case "ArrowRight":
            case "Right":
            case "ArrowDown":
            case "Down":
                await SelectPageAsync(CurrentPage + 1);
                break;
            case "ArrowLeft":
            case "Left":
            case "ArrowUp":
            case "Up":
                await SelectPageAsync(CurrentPage - 1);
                break;
            case "Home":
                await SelectPageAsync(1);
                break;
            case "End":
                await SelectPageAsync(PageCount);
                break;
        }
    }
}
