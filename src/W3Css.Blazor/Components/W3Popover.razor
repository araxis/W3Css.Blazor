@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@StyleValue"
     @onkeydown="HandleKeyDownAsync">
    <button type="button"
            @ref="TriggerElement"
            class="@TriggerCssClass"
            aria-haspopup="dialog"
            aria-expanded="@AriaExpanded"
            aria-controls="@ContentId"
            disabled="@Disabled"
            @onclick="ToggleAsync">
        @if (TriggerContent is not null)
        {
            @TriggerContent
        }
        else
        {
            @Label
        }
    </button>

    @if (CloseOnOutsideClick && Open)
    {
        <div class="w3-popover-close-layer"
             aria-hidden="true"
             @onclick="CloseAsync"></div>
    }

    <div id="@ContentId"
         class="@ContentCssClass"
         style="@ContentStyleValue"
         role="dialog"
         aria-label="@Label"
         aria-hidden="@AriaHidden"
         @onclick:stopPropagation="true">
        @ChildContent
    </div>
</div>

@code {
    private readonly string contentId = $"w3-popover-{Guid.NewGuid():N}";

    private ElementReference TriggerElement { get; set; }

    private string CssClass => BuildClass(
        "w3-popover",
        $"w3-popover-{Placement.ToString().ToLowerInvariant()}",
        Open ? "w3-popover-open" : null);

    private string TriggerCssClass => new W3ClassBuilder()
        .Add("w3-button")
        .Add(TriggerColor.ToBackgroundClass())
        .Add(TriggerTextColor.ToTextClass())
        .Add(TriggerClass)
        .AddIf(Disabled, "w3-disabled")
        .ToString();

    private string ContentCssClass => new W3ClassBuilder()
        .Add("w3-popover-content")
        .Add(Open ? "w3-show" : null)
        .Add(Card ? "w3-card-4" : null)
        .Add(Animate && Open ? "w3-animate-opacity" : null)
        .Add(ContentColor.ToBackgroundClass())
        .Add(ContentTextColor.ToTextClass())
        .Add(Round.ToClass())
        .Add(ContentClass)
        .ToString();

    private string? StyleValue => CombineStyle(Style);

    private string? ContentStyleValue => CombineStyle(
        Width is null ? null : $"width:{Width}",
        ContentStyle);

    private string AriaExpanded => Open ? "true" : "false";

    private string AriaHidden => Open ? "false" : "true";

    private string ContentId => contentId;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Open popover";

    /// <summary>
    /// Gets or sets the trigger content value.
    /// </summary>
    [Parameter]
    public RenderFragment? TriggerContent { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the open value.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the open value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; } = true;

    /// <summary>
    /// Gets or sets the animate value.
    /// </summary>
    [Parameter]
    public bool Animate { get; set; }

    /// <summary>
    /// Gets or sets the close on outside click value.
    /// </summary>
    [Parameter]
    public bool CloseOnOutsideClick { get; set; } = true;

    /// <summary>
    /// Gets or sets the placement value.
    /// </summary>
    [Parameter]
    public W3PopoverPlacement Placement { get; set; } = W3PopoverPlacement.Bottom;

    /// <summary>
    /// Gets or sets the width value.
    /// </summary>
    [Parameter]
    public string? Width { get; set; } = "18rem";

    /// <summary>
    /// Gets or sets the trigger class value.
    /// </summary>
    [Parameter]
    public string? TriggerClass { get; set; }

    /// <summary>
    /// Gets or sets the content class value.
    /// </summary>
    [Parameter]
    public string? ContentClass { get; set; }

    /// <summary>
    /// Gets or sets the content style value.
    /// </summary>
    [Parameter]
    public string? ContentStyle { get; set; }

    /// <summary>
    /// Gets or sets the trigger color value.
    /// </summary>
    [Parameter]
    public W3Color TriggerColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the trigger text color value.
    /// </summary>
    [Parameter]
    public W3Color TriggerTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the content color value.
    /// </summary>
    [Parameter]
    public W3Color ContentColor { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the content text color value.
    /// </summary>
    [Parameter]
    public W3Color ContentTextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.Medium;

    private async Task ToggleAsync()
    {
        if (Disabled)
        {
            return;
        }

        await SetOpenAsync(!Open);
    }

    private async Task CloseAsync()
    {
        await SetOpenAsync(false);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        if (args.Key == "Escape" && Open)
        {
            await SetOpenAsync(false);
            await TryFocusTriggerAsync();
        }
    }

    private async Task SetOpenAsync(bool open)
    {
        if (Open == open)
        {
            return;
        }

        Open = open;
        await OpenChanged.InvokeAsync(open);
    }

    private async Task TryFocusTriggerAsync()
    {
        try
        {
            await TriggerElement.FocusAsync();
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSException)
        {
        }
    }

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
