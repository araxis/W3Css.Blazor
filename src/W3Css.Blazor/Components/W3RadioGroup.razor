@typeparam TValue
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@using W3Css.Blazor.Internal
@inherits InputBase<TValue?>

<CascadingValue Value="this" Name="W3RadioGroup" IsFixed="false">
    <div @attributes="AdditionalAttributes"
         class="@GroupCssClass"
         style="@Style"
         role="radiogroup"
         aria-label="@Label"
         aria-required="@AriaRequired"
         aria-invalid="@AriaInvalid">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private const string GroupNamePrefix = "w3-radio-group";
    private string? _name;

    private string GroupCssClass => new W3ClassBuilder()
        .Add("w3-radio-group")
        .Add(CssClass)
        .Add(Class)
        .ToString();

    private string? AriaRequired => Required ? "true" : null;
    private string? AriaInvalid => EditContext?.GetValidationMessages(FieldIdentifier).Any() == true ? "true" : null;

    private string NameValue => !string.IsNullOrWhiteSpace(_name)
        ? _name
        : !string.IsNullOrWhiteSpace(NameAttributeValue)
            ? NameAttributeValue
        : $"{GroupNamePrefix}-{GetHashCode()}";

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets additional CSS classes.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Gets or sets inline CSS styles.
    /// </summary>
    [Parameter]
    public string? Style { get; set; }

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Radio Group";

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets whether a value is required for form validation.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Gets or sets the name value.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    internal bool IsSelected(TValue? value) => EqualityComparer<TValue?>.Default.Equals(CurrentValue, value);

    internal void NotifySelection(TValue? value)
    {
        if (Disabled)
        {
            return;
        }

        CurrentValue = value;
        InvokeAsync(StateHasChanged);
    }

    internal string GroupName => NameValue;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _name = string.IsNullOrWhiteSpace(Name)
            ? null
            : Name.Trim();
    }

    protected override bool TryParseValueFromString(string? value, out TValue? result, out string validationErrorMessage)
    {
        if (BindConverter.TryConvertTo<TValue?>(value, CultureInfo.CurrentCulture, out var parsedValue))
        {
            result = parsedValue;
            validationErrorMessage = string.Empty;
            return true;
        }

        result = default;
        validationErrorMessage = $"The {FieldIdentifier.FieldName} field is not valid.";
        return false;
    }
}
