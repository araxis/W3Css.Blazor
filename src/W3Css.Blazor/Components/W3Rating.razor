@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms
@using W3Css.Blazor.Internal
@inherits W3ComponentBase
@implements IDisposable

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@StyleValue"
     role="radiogroup"
     aria-label="@Label"
     aria-required="@AriaRequired"
     aria-invalid="@AriaInvalid"
     aria-readonly="@AriaReadOnly"
     aria-disabled="@AriaDisabled">
    @for (var index = 1; index <= SafeMax; index++)
    {
        var rating = index;
        <button type="button"
                class="@GetButtonClass(rating)"
                role="radio"
                aria-checked="@GetAriaChecked(rating)"
                aria-label="@GetRatingLabel(rating)"
                disabled="@IsInteractionDisabled"
                @onclick="() => SetValueAsync(rating)"
                @onkeydown="HandleKeyDownAsync">
            <span class="@GetIconClass(rating)" aria-hidden="true"></span>
        </button>
    }
    @if (ShowValue)
    {
        <span class="w3-rating-value" aria-hidden="true">@ClampedValue / @SafeMax</span>
    }
</div>

@code {
    private int SafeMax => Max < 1 ? 1 : Max;

    private int ClampedValue => Math.Clamp(Value, 0, SafeMax);

    private bool IsInteractionDisabled => Disabled || ReadOnly;

    private string AriaReadOnly => ReadOnly ? "true" : "false";

    private string AriaDisabled => Disabled ? "true" : "false";
    private string? AriaRequired => Required ? "true" : null;
    private string? AriaInvalid => HasFieldIdentifier && CascadedEditContext?.GetValidationMessages(fieldIdentifier).Any() == true ? "true" : null;
    private string? ValidationCssClass => HasFieldIdentifier ? CascadedEditContext?.FieldCssClass(fieldIdentifier) : null;
    private bool HasFieldIdentifier => CascadedEditContext is not null && ValueExpression is not null;

    private string CssClass => BuildClass(
        "w3-rating",
        ReadOnly ? "w3-rating-readonly" : null,
        Disabled ? "w3-rating-disabled" : null,
        ValidationCssClass);

    private string? StyleValue => CombineStyle(Gap >= 0 ? $"--w3-rating-gap:{Gap}px" : null, Style);

    private string GetButtonClass(int rating)
    {
        var selected = rating <= ClampedValue;

        return new W3ClassBuilder()
            .Add("w3-button")
            .Add("w3-rating-button")
            .Add(selected ? Color.ToTextClass() : EmptyColor.ToTextClass())
            .Add(Size.ToClass())
            .AddIf(!IsInteractionDisabled, "w3-hover-opacity")
            .AddIf(IsInteractionDisabled, "w3-disabled")
            .ToString();
    }

    private string GetIconClass(int rating)
    {
        return rating <= ClampedValue ? IconClass : EmptyIconClass;
    }

    private string GetAriaChecked(int rating)
    {
        return rating == ClampedValue ? "true" : "false";
    }

    private string GetRatingLabel(int rating)
    {
        return $"{rating} of {SafeMax}";
    }

    private async Task SetValueAsync(int rating)
    {
        if (IsInteractionDisabled)
        {
            return;
        }

        var nextValue = Clearable && rating == ClampedValue ? 0 : rating;
        await ApplyValueAsync(nextValue);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (IsInteractionDisabled)
        {
            return;
        }

        switch (args.Key)
        {
            case "ArrowRight":
            case "Right":
            case "ArrowUp":
            case "Up":
                await ApplyValueAsync(Math.Min(SafeMax, ClampedValue + 1));
                break;
            case "ArrowLeft":
            case "Left":
            case "ArrowDown":
            case "Down":
                await ApplyValueAsync(Math.Max(Clearable ? 0 : 1, ClampedValue - 1));
                break;
            case "Home":
                await ApplyValueAsync(1);
                break;
            case "End":
                await ApplyValueAsync(SafeMax);
                break;
            case "Backspace":
            case "Delete":
            case "Del":
                if (Clearable)
                {
                    await ApplyValueAsync(0);
                }

                break;
        }
    }

    private async Task ApplyValueAsync(int nextValue)
    {
        nextValue = Math.Clamp(nextValue, 0, SafeMax);
        Value = nextValue;
        await ValueChanged.InvokeAsync(nextValue);

        if (HasFieldIdentifier)
        {
            CascadedEditContext!.NotifyFieldChanged(fieldIdentifier);
        }
    }

    private FieldIdentifier fieldIdentifier;
    private EditContext? previousEditContext;

    [CascadingParameter]
    private EditContext? CascadedEditContext { get; set; }

    /// <summary>
    /// Gets or sets the value value.
    /// </summary>
    [Parameter]
    public int Value { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the value value changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the value expression value.
    /// </summary>
    [Parameter]
    public Expression<Func<int>>? ValueExpression { get; set; }

    /// <summary>
    /// Gets or sets the max value.
    /// </summary>
    [Parameter]
    public int Max { get; set; } = 5;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Rating";

    /// <summary>
    /// Gets or sets whether the input is read-only.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets whether a value is required for form validation.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Gets or sets the clearable value.
    /// </summary>
    [Parameter]
    public bool Clearable { get; set; }

    /// <summary>
    /// Gets or sets the show value value.
    /// </summary>
    [Parameter]
    public bool ShowValue { get; set; }

    /// <summary>
    /// Gets or sets the icon class value.
    /// </summary>
    [Parameter]
    public string IconClass { get; set; } = "fa fa-star";

    /// <summary>
    /// Gets or sets the empty icon class value.
    /// </summary>
    [Parameter]
    public string EmptyIconClass { get; set; } = "fa fa-star-o";

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.Amber;

    /// <summary>
    /// Gets or sets the empty color value.
    /// </summary>
    [Parameter]
    public W3Color EmptyColor { get; set; } = W3Color.Grey;

    /// <summary>
    /// Gets or sets the size value.
    /// </summary>
    [Parameter]
    public W3Size Size { get; set; } = W3Size.Large;

    /// <summary>
    /// Gets or sets the gap value.
    /// </summary>
    [Parameter]
    public int Gap { get; set; } = 2;

    protected override void OnParametersSet()
    {
        if (previousEditContext != CascadedEditContext)
        {
            if (previousEditContext is not null)
            {
                previousEditContext.OnValidationStateChanged -= HandleValidationStateChanged;
            }

            if (CascadedEditContext is not null)
            {
                CascadedEditContext.OnValidationStateChanged += HandleValidationStateChanged;
            }

            previousEditContext = CascadedEditContext;
        }

        if (CascadedEditContext is not null && ValueExpression is not null)
        {
            fieldIdentifier = FieldIdentifier.Create(ValueExpression);
        }
    }

    private void HandleValidationStateChanged(object? sender, ValidationStateChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (previousEditContext is not null)
        {
            previousEditContext.OnValidationStateChanged -= HandleValidationStateChanged;
        }
    }

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
