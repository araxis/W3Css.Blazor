@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@StyleValue">
    @ChildContent
</div>

@code {
    private string CssClass => BuildClass(
        "w3-stack",
        Horizontal ? "w3-stack-horizontal" : "w3-stack-vertical",
        Wrap ? "w3-stack-wrap" : null,
        AlignCenter ? "w3-stack-align-center" : null,
        JustifyCenter ? "w3-stack-justify-center" : null,
        JustifyEnd ? "w3-stack-justify-end" : null,
        JustifyBetween ? "w3-stack-justify-between" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string? StyleValue => CombineStyle(Gap >= 0 ? $"--w3-stack-gap:{Gap}px" : null, Style);

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the horizontal value.
    /// </summary>
    [Parameter]
    public bool Horizontal { get; set; }

    /// <summary>
    /// Gets or sets the wrap value.
    /// </summary>
    [Parameter]
    public bool Wrap { get; set; }

    /// <summary>
    /// Gets or sets the align center value.
    /// </summary>
    [Parameter]
    public bool AlignCenter { get; set; }

    /// <summary>
    /// Gets or sets the justify center value.
    /// </summary>
    [Parameter]
    public bool JustifyCenter { get; set; }

    /// <summary>
    /// Gets or sets the justify end value.
    /// </summary>
    [Parameter]
    public bool JustifyEnd { get; set; }

    /// <summary>
    /// Gets or sets the justify between value.
    /// </summary>
    [Parameter]
    public bool JustifyBetween { get; set; }

    /// <summary>
    /// Gets or sets the gap value.
    /// </summary>
    [Parameter]
    public int Gap { get; set; } = 16;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
