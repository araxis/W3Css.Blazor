@using W3Css.Blazor.Internal
@inherits W3ComponentBase

@if (Responsive)
{
    <div class="w3-responsive">
        <table @attributes="AdditionalAttributes"
               class="@CssClass"
               style="@Style">
            @ChildContent
        </table>
    </div>
}
else
{
    <table @attributes="AdditionalAttributes"
           class="@CssClass"
           style="@Style">
        @ChildContent
    </table>
}

@code {
    private string CssClass => BuildClass(
        "w3-table",
        Color.ToBackgroundClass(),
        TextColor.ToTextClass(),
        Striped ? "w3-striped" : null,
        Bordered ? "w3-bordered" : null,
        Border ? "w3-border" : null,
        Hoverable ? "w3-hoverable" : null,
        Centered ? "w3-centered" : null,
        Dense ? "w3-small" : null);

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the striped value.
    /// </summary>
    [Parameter]
    public bool Striped { get; set; }

    /// <summary>
    /// Gets or sets the bordered value.
    /// </summary>
    [Parameter]
    public bool Bordered { get; set; }

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the hoverable value.
    /// </summary>
    [Parameter]
    public bool Hoverable { get; set; }

    /// <summary>
    /// Gets or sets the centered value.
    /// </summary>
    [Parameter]
    public bool Centered { get; set; }

    /// <summary>
    /// Gets or sets the responsive value.
    /// </summary>
    [Parameter]
    public bool Responsive { get; set; }

    /// <summary>
    /// Compact row density using the W3.CSS <c>w3-small</c> text class.
    /// </summary>
    [Parameter]
    public bool Dense { get; set; }
}
