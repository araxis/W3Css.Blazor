@using Microsoft.JSInterop
@using W3Css.Blazor.Internal
@inherits W3ComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JS

<CascadingValue Value="this" IsFixed="true">
    <section @attributes="AdditionalAttributes"
             class="@CssClass"
             style="@Style">
        <div class="@BarCssClass" role="tablist">
            @foreach (var panel in panels)
            {
                var active = IsActive(panel);
                <button type="button"
                        class="@GetTabButtonClass(active)"
                        role="tab"
                        aria-selected="@ToAriaBool(active)"
                        aria-controls="@panel.PanelId"
                        id="@panel.TabId"
                        tabindex="@(active ? 0 : -1)"
                        disabled="@panel.Disabled"
                        @onclick="() => ActivateAsync(panel)"
                        @onkeydown="args => HandleTabKeyDownAsync(panel, args)">
                    @panel.Title
                </button>
                @if (ShowCloseButtons && (Closeable || panel.Closeable))
                {
                    <button type="button"
                            class="w3-bar-item w3-button w3-tab-close"
                            aria-label="@($"{CloseButtonLabel} {panel.Title}")"
                            @onclick="() => CloseAsync(panel)">&times;</button>
                }
            }
            @if (ShowAddButton)
            {
                <button type="button"
                        class="w3-bar-item w3-button"
                        aria-label="@AddButtonLabel"
                        @onclick="AddAsync">+</button>
            }
        </div>

        @if (ActivePanel is not null)
        {
            <div class="@PanelCssClass"
                 id="@ActivePanel.PanelId"
                 role="tabpanel"
                 aria-labelledby="@ActivePanel.TabId">
                @ActivePanel.ChildContent
            </div>
        }
    </section>

    @ChildContent
</CascadingValue>

@code {
    private readonly List<W3TabPanel> panels = [];

    private W3FocusInterop? focusInterop;

    private W3TabPanel? ActivePanel => panels.FirstOrDefault(IsActive) ?? panels.FirstOrDefault(panel => !panel.Disabled);

    private string CssClass => BuildClass("w3-section");

    private string BarCssClass => new W3ClassBuilder()
        .Add("w3-bar")
        .AddIf(Border, "w3-border")
        .Add(Color.ToBackgroundClass())
        .Add(TextColor.ToTextClass())
        .ToString();

    private string PanelCssClass => new W3ClassBuilder()
        .Add("w3-container")
        .AddIf(PanelBorder, "w3-border")
        .Add(PanelColor.ToBackgroundClass())
        .Add(PanelTextColor.ToTextClass())
        .ToString();

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Value of the active tab panel. Two-way bindable with <see cref="ActiveValueChanged"/>.
    /// </summary>
    [Parameter]
    public string? ActiveValue { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the active value value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> ActiveValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; } = true;

    /// <summary>
    /// Gets or sets the panel border value.
    /// </summary>
    [Parameter]
    public bool PanelBorder { get; set; } = true;

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the active color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveColor { get; set; } = W3Color.Primary;

    /// <summary>
    /// Gets or sets the active text color value.
    /// </summary>
    [Parameter]
    public W3Color ActiveTextColor { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the panel color value.
    /// </summary>
    [Parameter]
    public W3Color PanelColor { get; set; } = W3Color.Surface;

    /// <summary>
    /// Gets or sets the panel text color value.
    /// </summary>
    [Parameter]
    public W3Color PanelTextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Shows a trailing add (+) button. Handle <see cref="OnAddTab"/> to append a panel.
    /// </summary>
    [Parameter]
    public bool ShowAddButton { get; set; }

    /// <summary>
    /// Shows a close (×) button on every tab. Individual panels can also opt in via <c>W3TabPanel.Closeable</c>.
    /// </summary>
    [Parameter]
    public bool ShowCloseButtons { get; set; } = true;

    /// <summary>
    /// Marks all tabs closeable (combined with <see cref="ShowCloseButtons"/>).
    /// </summary>
    [Parameter]
    public bool Closeable { get; set; }

    /// <summary>
    /// Accessible label for the add button.
    /// </summary>
    [Parameter]
    public string AddButtonLabel { get; set; } = "Add tab";

    /// <summary>
    /// Accessible label prefix for close buttons.
    /// </summary>
    [Parameter]
    public string CloseButtonLabel { get; set; } = "Close";

    /// <summary>
    /// Invoked when the add (+) button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnAddTab { get; set; }

    /// <summary>
    /// Invoked with the tab value when a tab's close (×) button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnCloseTab { get; set; }

    internal void Register(W3TabPanel panel)
    {
        if (panels.Contains(panel))
        {
            return;
        }

        panels.Add(panel);

        if (string.IsNullOrWhiteSpace(ActiveValue) && !panel.Disabled)
        {
            ActiveValue = panel.Value;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    internal void Unregister(W3TabPanel panel)
    {
        if (panels.Remove(panel))
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private bool IsActive(W3TabPanel panel)
    {
        return string.Equals(ActiveValue, panel.Value, StringComparison.Ordinal);
    }

    private string GetTabButtonClass(bool active)
    {
        return new W3ClassBuilder()
            .Add("w3-bar-item")
            .Add("w3-button")
            .AddIf(active, ActiveColor.ToBackgroundClass())
            .AddIf(active, ActiveTextColor.ToTextClass())
            .ToString();
    }

    private static string ToAriaBool(bool value)
    {
        return value ? "true" : "false";
    }

    private async Task ActivateAsync(W3TabPanel panel)
    {
        if (panel.Disabled)
        {
            return;
        }

        ActiveValue = panel.Value;
        await ActiveValueChanged.InvokeAsync(panel.Value);
    }

    private async Task HandleTabKeyDownAsync(W3TabPanel panel, KeyboardEventArgs args)
    {
        switch (args.Key)
        {
            case "ArrowRight":
            case "Right":
            case "ArrowDown":
            case "Down":
                await ActivateAdjacentAsync(1);
                await FocusActiveTabAsync();
                break;
            case "ArrowLeft":
            case "Left":
            case "ArrowUp":
            case "Up":
                await ActivateAdjacentAsync(-1);
                await FocusActiveTabAsync();
                break;
            case "Home":
                await ActivateBoundaryAsync(first: true);
                await FocusActiveTabAsync();
                break;
            case "End":
                await ActivateBoundaryAsync(first: false);
                await FocusActiveTabAsync();
                break;
            case "Delete":
            case "Del":
                if (CanClose(panel))
                {
                    await CloseAsync(panel);
                }

                break;
        }
    }

    private async Task FocusActiveTabAsync()
    {
        var active = ActivePanel;
        if (active is null)
        {
            return;
        }

        focusInterop ??= new W3FocusInterop(JS);
        await focusInterop.FocusIdAsync(active.TabId);
    }

    public async ValueTask DisposeAsync()
    {
        if (focusInterop is not null)
        {
            await focusInterop.DisposeAsync();
        }
    }

    private async Task ActivateAdjacentAsync(int offset)
    {
        var enabledPanels = panels.Where(panel => !panel.Disabled).ToArray();

        if (enabledPanels.Length == 0)
        {
            return;
        }

        var current = ActivePanel;
        var currentIndex = current is null ? -1 : Array.IndexOf(enabledPanels, current);
        var nextIndex = currentIndex < 0
            ? 0
            : (currentIndex + offset + enabledPanels.Length) % enabledPanels.Length;

        await ActivateAsync(enabledPanels[nextIndex]);
    }

    private Task ActivateBoundaryAsync(bool first)
    {
        var panel = first
            ? panels.FirstOrDefault(panel => !panel.Disabled)
            : panels.LastOrDefault(panel => !panel.Disabled);

        return panel is null ? Task.CompletedTask : ActivateAsync(panel);
    }

    private bool CanClose(W3TabPanel panel)
    {
        return ShowCloseButtons && (Closeable || panel.Closeable);
    }

    private Task CloseAsync(W3TabPanel panel) => OnCloseTab.InvokeAsync(panel.Value);

    private Task AddAsync() => OnAddTab.InvokeAsync();
}
