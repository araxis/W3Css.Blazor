@inherits W3FormComponentBase<string?>

<textarea @attributes="AdditionalAttributes"
          id="@Id"
          name="@NameAttributeValue"
          class="@TextAreaCssClass"
          style="@Style"
          placeholder="@Placeholder"
          rows="@Rows"
          disabled="@Disabled"
          readonly="@ReadOnly"
          @oninput="HandleInput"
          @onchange="HandleChange">@CurrentValueAsString</textarea>

@code {
    private string TextAreaCssClass => BuildControlClass("w3-input");

    /// <summary>
    /// Gets or sets the rendered element id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the placeholder value.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Gets or sets the rows value.
    /// </summary>
    [Parameter]
    public int? Rows { get; set; }

    /// <summary>
    /// Gets or sets whether the input is read-only.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Gets or sets the update on input value.
    /// </summary>
    [Parameter]
    public bool UpdateOnInput { get; set; }

    private void HandleInput(ChangeEventArgs args)
    {
        if (UpdateOnInput)
        {
            CurrentValueAsString = args.Value?.ToString();
        }
    }

    private void HandleChange(ChangeEventArgs args)
    {
        if (!UpdateOnInput)
        {
            CurrentValueAsString = args.Value?.ToString();
        }
    }

    protected override bool TryParseValueFromString(string? value, out string? result, out string validationErrorMessage)
    {
        result = value;
        validationErrorMessage = string.Empty;
        return true;
    }
}
