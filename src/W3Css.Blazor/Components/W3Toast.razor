@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@Style"
     role="@RoleValue"
     aria-live="@AriaLiveValue">
    <div class="w3-toast-main">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <strong class="w3-toast-title">@Title</strong>
        }
        <div class="w3-toast-message">
            @ChildContent
        </div>
    </div>

    @if (HasAction || ShowCloseButton)
    {
        <div class="w3-toast-actions">
            @if (HasAction)
            {
                <button type="button"
                        class="w3-button w3-toast-action"
                        @onclick="InvokeActionAsync">
                    @ActionText
                </button>
            }

            @if (ShowCloseButton)
            {
                <button type="button"
                        class="w3-button w3-toast-close"
                        aria-label="@CloseButtonLabel"
                        @onclick="DismissAsync">
                    &times;
                </button>
            }
        </div>
    }
</div>

@code {
    private bool HasAction => !string.IsNullOrWhiteSpace(ActionText);

    private string CssClass => BuildClass(
        "w3-toast",
        "w3-panel",
        Kind.ToClass(),
        Round.ToClass(),
        Card ? "w3-card-4" : null,
        Animate ? "w3-animate-right" : null);

    private string RoleValue => Role ?? (Kind == W3AlertKind.Danger ? "alert" : "status");
    private string AriaLiveValue => AriaLive ?? (Kind == W3AlertKind.Danger ? "assertive" : "polite");

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the title value.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the kind value.
    /// </summary>
    [Parameter]
    public W3AlertKind Kind { get; set; } = W3AlertKind.Info;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.Medium;

    /// <summary>
    /// Gets or sets the card value.
    /// </summary>
    [Parameter]
    public bool Card { get; set; } = true;

    /// <summary>
    /// Gets or sets the animate value.
    /// </summary>
    [Parameter]
    public bool Animate { get; set; } = true;

    /// <summary>
    /// Gets or sets the show close button value.
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string CloseButtonLabel { get; set; } = "Dismiss notification";

    /// <summary>
    /// Gets or sets the action text value.
    /// </summary>
    [Parameter]
    public string? ActionText { get; set; }

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback OnAction { get; set; }

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback OnDismiss { get; set; }

    /// <summary>
    /// Gets or sets the role value.
    /// </summary>
    [Parameter]
    public string? Role { get; set; }

    /// <summary>
    /// Gets or sets the AriaLive attribute value.
    /// </summary>
    [Parameter]
    public string? AriaLive { get; set; }

    private Task InvokeActionAsync()
    {
        return OnAction.InvokeAsync();
    }

    private Task DismissAsync()
    {
        return OnDismiss.InvokeAsync();
    }
}

