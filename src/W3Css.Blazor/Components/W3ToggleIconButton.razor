@using Microsoft.AspNetCore.Components.Web
@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<button @attributes="AdditionalAttributes"
        type="@Type"
        class="@CssClass"
        style="@Style"
        aria-label="@EffectiveLabel"
        aria-pressed="@AriaPressed"
        title="@EffectiveTitle"
        disabled="@Disabled"
        @onclick="HandleClickAsync">
    <W3Icon IconClass="@EffectiveIconClass" Class="@IconCssClass">
        @if (!string.IsNullOrWhiteSpace(EffectiveIconText))
        {
            @EffectiveIconText
        }
        else
        {
            @ChildContent
        }
    </W3Icon>
</button>

@code {
    private bool _pressed;
    private bool _initialized;
    private string? _value;

    private string CssClass => BuildClass(
        "w3-button",
        "w3-icon-button",
        Circle ? "w3-icon-button-circle w3-circle" : null,
        Border ? "w3-border" : null,
        _pressedState ? "w3-icon-button-pressed" : null,
        Color.ToBackgroundClass(),
        TextColor.ToTextClass(),
        Size.ToClass(),
        Round.ToClass(),
        Disabled ? "w3-disabled" : null);

    private string IconCssClass => new W3ClassBuilder()
        .Add("w3-icon-button-icon")
        .Add(EffectiveIconElementClass)
        .ToString();

    private IReadOnlyList<W3ToggleIconButtonState> EffectiveStates => States ?? [];

    private bool HasStates => EffectiveStates.Count > 0;

    private W3ToggleIconButtonState? CurrentState => HasStates
        ? EffectiveStates.FirstOrDefault(state => string.Equals(state.Value, CurrentValue, StringComparison.Ordinal))
            ?? EffectiveStates[0]
        : null;

    private string? CurrentValue
    {
        get
        {
            if (ValueChanged.HasDelegate)
            {
                return Value;
            }

            return _value ?? Value;
        }
    }

    private bool _pressedState => PressedChanged.HasDelegate ? Pressed : _pressed;

    private string EffectiveLabel => CurrentState is { } state && !string.IsNullOrWhiteSpace(state.Label)
        ? state.Label
        : string.IsNullOrWhiteSpace(Label) ? "Icon action" : Label;

    private string? EffectiveTitle => CurrentState?.Title ?? Title;

    private string? EffectiveIconClass => CurrentState?.IconClass ?? IconClass;

    private string? EffectiveIconElementClass => CurrentState?.IconElementClass ?? IconElementClass;

    private string? EffectiveIconText => CurrentState?.IconText;

    private string? AriaPressed => HasStates ? null : _pressedState.ToString().ToLowerInvariant();

    /// <summary>
    /// Gets or sets the accessible label text.
    /// </summary>
    [Parameter]
    public string Label { get; set; } = "Icon action";

    /// <summary>
    /// Gets or sets the title value.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the icon class value.
    /// </summary>
    [Parameter]
    public string? IconClass { get; set; }

    /// <summary>
    /// Gets or sets the icon element class value.
    /// </summary>
    [Parameter]
    public string? IconElementClass { get; set; }

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    /// <summary>
    /// Gets or sets the size value.
    /// </summary>
    [Parameter]
    public W3Size Size { get; set; } = W3Size.Default;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.Medium;

    /// <summary>
    /// Gets or sets the border value.
    /// </summary>
    [Parameter]
    public bool Border { get; set; }

    /// <summary>
    /// Gets or sets the circle value.
    /// </summary>
    [Parameter]
    public bool Circle { get; set; }

    /// <summary>
    /// Gets or sets whether the component is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the pressed value.
    /// </summary>
    [Parameter]
    public bool Pressed { get; set; }

    /// <summary>
    /// Gets or sets the available states for multi-state cycling.
    /// </summary>
    [Parameter]
    public IReadOnlyList<W3ToggleIconButtonState>? States { get; set; }

    /// <summary>
    /// Gets or sets the current state value when <see cref="States"/> is supplied.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the multi-state value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the rendered button type.
    /// </summary>
    [Parameter]
    public string Type { get; set; } = "button";

    /// <summary>
    /// Gets or sets the callback raised by the component action.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// Gets or sets the callback raised when the pressed value changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    protected override void OnParametersSet()
    {
        if (HasStates && string.IsNullOrWhiteSpace(_value))
        {
            _value = CurrentState?.Value ?? EffectiveStates[0].Value;
        }

        if (!_initialized || PressedChanged.HasDelegate)
        {
            _pressed = Pressed;
            _initialized = true;
        }
    }

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (Disabled)
        {
            return;
        }

        if (HasStates)
        {
            var nextValue = GetNextStateValue();
            if (ValueChanged.HasDelegate)
            {
                await ValueChanged.InvokeAsync(nextValue);
            }
            else
            {
                _value = nextValue;
            }

            await OnClick.InvokeAsync(args);
            return;
        }

        var next = !_pressedState;
        if (PressedChanged.HasDelegate)
        {
            await PressedChanged.InvokeAsync(next);
        }
        else
        {
            _pressed = next;
        }

        await OnClick.InvokeAsync(args);
    }

    private string GetNextStateValue()
    {
        var states = EffectiveStates;
        var currentIndex = states
            .Select((state, index) => new { state, index })
            .FirstOrDefault(pair => string.Equals(pair.state.Value, CurrentState?.Value, StringComparison.Ordinal))
            ?.index ?? 0;
        var nextIndex = (currentIndex + 1) % states.Count;
        return states[nextIndex].Value;
    }
}
