@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<div @attributes="AdditionalAttributes"
     class="@CssClass"
     style="@StyleValue"
     role="toolbar"
     aria-label="@Label">
    @if (ChildContent is not null)
    {
        <div class="w3-toolbar-content">
            @ChildContent
        </div>
    }

    @if (Actions is not null)
    {
        <div class="w3-toolbar-actions">
            @Actions
        </div>
    }
</div>

@code {
    private string CssClass => BuildClass(
        "w3-toolbar",
        Dense ? "w3-toolbar-dense" : null,
        Wrap ? "w3-toolbar-wrap" : null,
        Border ? "w3-border" : null,
        Card ? CardDepth.ToClass() : null,
        Round.ToClass(),
        Color.ToBackgroundClass(),
        TextColor.ToTextClass());

    private string? StyleValue => CombineStyle(Gap >= 0 ? $"--w3-toolbar-gap:{Gap}px" : null, Style);

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public string Label { get; set; } = "Toolbar";

    [Parameter]
    public bool Dense { get; set; }

    [Parameter]
    public bool Wrap { get; set; } = true;

    [Parameter]
    public bool Border { get; set; }

    [Parameter]
    public bool Card { get; set; }

    [Parameter]
    public W3CardDepth CardDepth { get; set; } = W3CardDepth.Two;

    [Parameter]
    public W3Round Round { get; set; } = W3Round.None;

    [Parameter]
    public int Gap { get; set; } = 8;

    [Parameter]
    public W3Color Color { get; set; } = W3Color.Surface;

    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.None;

    private static string? CombineStyle(params string?[] styles)
    {
        var style = string.Join(';', styles
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim().TrimEnd(';')));

        return string.IsNullOrWhiteSpace(style) ? null : style;
    }
}
