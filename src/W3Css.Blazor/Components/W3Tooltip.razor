@using W3Css.Blazor.Internal
@inherits W3ComponentBase

<span @attributes="AdditionalAttributes"
      class="@TooltipCssClass"
      style="@Style">
    @ChildContent
    <span class="@TextCssClass" style="@TooltipStyle">
        @if (TooltipContent is not null)
        {
            @TooltipContent
        }
        else
        {
            @Text
        }
    </span>
</span>

@code {
    private string TooltipCssClass => BuildClass("w3-tooltip");

    private string TextCssClass => new W3ClassBuilder()
        .Add("w3-text")
        .Add("w3-tag")
        .Add(Color.ToBackgroundClass())
        .Add(TextColor.ToTextClass())
        .Add(Round.ToClass())
        .Add(TextClass)
        .ToString();

    /// <summary>
    /// Gets or sets the content rendered inside the component.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the text value.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    /// <summary>
    /// Gets or sets the tooltip content value.
    /// </summary>
    [Parameter]
    public RenderFragment? TooltipContent { get; set; }

    /// <summary>
    /// Gets or sets the text class value.
    /// </summary>
    [Parameter]
    public string? TextClass { get; set; }

    /// <summary>
    /// Gets or sets the tooltip style value.
    /// </summary>
    [Parameter]
    public string? TooltipStyle { get; set; }

    /// <summary>
    /// Gets or sets the background color class.
    /// </summary>
    [Parameter]
    public W3Color Color { get; set; } = W3Color.Black;

    /// <summary>
    /// Gets or sets the text color class.
    /// </summary>
    [Parameter]
    public W3Color TextColor { get; set; } = W3Color.White;

    /// <summary>
    /// Gets or sets the round value.
    /// </summary>
    [Parameter]
    public W3Round Round { get; set; } = W3Round.Medium;
}
