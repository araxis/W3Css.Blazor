@namespace W3Css.Blazor.Tests
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using W3Css.Blazor.Components

<EditForm EditContext="@EditContext">
    <DataAnnotationsValidator />

    <W3Field TValue="bool"
             For="@(() => Model.Accepted)"
             HelpText="Required before continuing.">
        <W3Checkbox Id="terms"
                    @bind-Value="Model.Accepted"
                    Label="I accept the terms"
                    Required="true" />
    </W3Field>

    <W3Field TValue="string"
             Label="Contact method"
             ForId="contact-email"
             For="@(() => Model.Contact)"
             HelpText="Choose one option.">
        <W3RadioGroup TValue="string"
                      Label="Contact method"
                      @bind-Value="Model.Contact"
                      Name="contact-method"
                      Required="true">
            <W3Radio TValue="string" Id="contact-email" OptionValue="@EmailOption">Email</W3Radio>
            <W3Radio TValue="string" Id="contact-sms" OptionValue="@SmsOption">SMS</W3Radio>
        </W3RadioGroup>
    </W3Field>
</EditForm>

@code {
    private const string EmailOption = "email";
    private const string SmsOption = "sms";

    public ChoiceValidationModel Model { get; } = new();

    public EditContext EditContext { get; private set; } = default!;

    protected override void OnInitialized()
    {
        EditContext = new EditContext(Model);
    }

    public bool Validate()
    {
        return EditContext.Validate();
    }

    public sealed class ChoiceValidationModel
    {
        [Range(typeof(bool), "true", "true", ErrorMessage = "Accept terms to continue.")]
        public bool Accepted { get; set; }

        [Required(ErrorMessage = "Choose a contact method.")]
        public string Contact { get; set; } = string.Empty;
    }
}
